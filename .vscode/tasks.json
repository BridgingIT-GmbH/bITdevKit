      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/examples/WeatherForecast.Presentation.Web.Server/WeatherForecast.Presentation.Web.Server.csproj",
        "--nologo"
      ],
      "problemMatcher": "$msCompile"
    },
