","description":"The endpoint-specific route name."}],"returns":{"type":"System.String","description":"The unmodified name when no prefix is configured; the prefix when name is empty; otherwise the prefix and name joined by a single period."},"parent":"BridgingIT.DevKit.Presentation.Web.EndpointsBase","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.EndpointsBase.html#BridgingIT.DevKit.Presentation.Web.EndpointsBase.BuildRouteName%28BridgingIT.DevKit.Presentation.Web.EndpointsOptionsBase%2CSystem.String%29","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.EndpointsBase.#ctor","name":"EndpointsBase()","fullName":"BridgingIT.DevKit.Presentation.Web.EndpointsBase.EndpointsBase()","kind":"Constructor","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":null,"remarks":null,"syntax":{"content":"protected EndpointsBase()","parameters":[],"returns":null},"parameters":[],"returns":null,"parent":"BridgingIT.DevKit.Presentation.Web.EndpointsBase","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.EndpointsBase.html#BridgingIT.DevKit.Presentation.Web.EndpointsBase.%23ctor","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.EndpointsBase.Enabled","name":"Enabled","fullName":"BridgingIT.DevKit.Presentation.Web.EndpointsBase.Enabled","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets whether this endpoint set should be mapped.","remarks":"The endpoint mapping extension skips endpoint instances whose value is false. The default value is true.","syntax":{"content":"public bool Enabled { get; set; }","parameters":[],"returns":{"type":"System.Boolean","description":null}},"parameters":[],"returns":{"type":"System