PS and reject HTTP metadata endpoints; false to allow HTTP. Defaults to false. Should be set to true in production environments for security."},"parent":"BridgingIT.DevKit.Presentation.Web.AuthenticationOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.html#BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.RequireHttpsMetadata","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.SaveToken","name":"SaveToken","fullName":"BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.SaveToken","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether the access token should be stored in the HTTP context.","remarks":null,"syntax":{"content":"public bool SaveToken { get; set; }","parameters":[],"returns":{"type":"System.Boolean","description":"True to save the token in the authentication properties, making it accessible via the HTTP context; false to discard the token after validation. Useful for accessing the token in application code. Defaults to false."}},"parameters":[],"returns":{"type":"System.Boolean","description":"True to save the token in the authentication properties, making it accessible via the HTTP context; false to discard the token after validation. Useful for accessing the token in application code. Defaults to false."},"parent":"BridgingIT.DevKit.Presentation.Web.AuthenticationOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.html#BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.SaveToken","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.AuthenticationOptions.SigningKey","name":"SigningKey","fullName":"BridgingIT.DevKit.Pre