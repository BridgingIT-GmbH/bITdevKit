em.Object.BridgingIT.DevKit.Common.TypeExtensions.IsNotOfType(System.Type)","System.Object.BridgingIT.DevKit.Common.TypeExtensions.IsOfType(System.Type)","System.Object.BridgingIT.DevKit.Common.UtilitiesExtensions.AsReflectionDynamic"],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.#ctor","name":"CorsPolicyOptions()","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.CorsPolicyOptions()","kind":"Constructor","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":null,"remarks":null,"syntax":{"content":"public CorsPolicyOptions()","parameters":[],"returns":null},"parameters":[],"returns":null,"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.%23ctor","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins","name":"AllowedOrigins","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets the array of allowed origins (e.g., \u0022https://example.com\u0022).","remarks":"Specifies which origins are allowed to make cross-origin requests. Origins must include scheme, host, and optionally port (e.g., \u0022https://localhost:5001\u0022). Do not include trailing slashes. Cannot be used when BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin is true. When BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowWildcardSubdomains is true, specify base domain (e.g., \u0022https://example.com\u0022 allows https://*.example.com). Example: [\u0022https://example.com\u0022, \u0022https://app.example.com\u0022, \u0022https://localhost:3000\u0022]","syntax":{"content":"public string[] AllowedOrigins { get; set; }","parameters":[],"returns":{"type":"System.String[]","description":null}},"parameters":[],"returns":{"type":"System.String[]","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedMethods","name":"AllowedMethods","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedMethods","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets the array of allowed HTTP methods (e.g., \u0022GET\u0022, \u0022POST\u0022, \u0022PUT\u0022).","remarks":"Specifies which HTTP methods are allowed for cross-origin requests. Cannot be used when BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyMethod is true. If not specified and BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyMethod is false, defaults to GET only. Common values: \u0022GET\u0022, \u0022POST\u0022, \u0022PUT\u0022, \u0022DELETE\u0022, \u0022PATCH\u0022, \u0022OPTIONS\u0022 Example: [\u0022GET\u0022, \u0022POST\u0022, \u0022PUT\u0022, \u0022DELETE\u0022]","syntax":{"content":"public string[] AllowedMethods { get; set; }","parameters":[],"returns":{"type":"System.String[]","description":null}},"parameters":[],"returns":{"type":"System.String[]","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedMethods","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedHeaders","name":"AllowedHeaders","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedHeaders","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets the array of allowed request headers (e.g., \u0022Content-Type\u0022, \u0022Authorization\u0022).","remarks":"Specifies which headers can be sent in cross-origin requests. Cannot be used when BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyHeader is true. Simple headers (Accept, Accept-Language, Content-Language, Content-Type) are always allowed. Example: [\u0022Content-Type\u0022, \u0022Authorization\u0022, \u0022X-Custom-Header\u0022]","syntax":{"content":"public string[] AllowedHeaders { get; set; }","parameters":[],"returns":{"type":"System.String[]","description":null}},"parameters":[],"returns":{"type":"System.String[]","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedHeaders","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.ExposeHeaders","name":"ExposeHeaders","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.ExposeHeaders","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets the array of headers exposed to the browser (e.g., \u0022X-Total-Count\u0022).","remarks":"Specifies which response headers the browser should expose to JavaScript. By default, only simple response headers are exposed (Cache-Control, Content-Language, Content-Type, Expires, Last-Modified, Pragma). Use this to expose custom headers like pagination info or request IDs. Example: [\u0022X-Total-Count\u0022, \u0022X-Page-Number\u0022, \u0022X-Request-Id\u0022]","syntax":{"content":"public string[] ExposeHeaders { get; set; }","parameters":[],"returns":{"type":"System.String[]","description":null}},"parameters":[],"returns":{"type":"System.String[]","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.ExposeHeaders","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowCredentials","name":"AllowCredentials","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowCredentials","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether credentials (cookies, authorization headers) are allowed.","remarks":"When true, allows credentials to be sent in cross-origin requests. WARNING: Cannot be used with BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin = true (violates CORS specification). When using credentials, BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins must specify exact origins (no wildcards except subdomains). Use Cases: - Frontend applications that send authentication tokens or cookies - APIs that require user authentication for cross-origin requests Default: false (null treated as false)","syntax":{"content":"public bool? AllowCredentials { get; set; }","parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null}},"parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowCredentials","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin","name":"AllowAnyOrigin","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether any origin is allowed.","remarks":"When true, allows cross-origin requests from any origin (*). WARNING: Cannot be used with BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowCredentials = true (violates CORS specification). SECURITY: Only use in development or for public APIs that don\u0027t require authentication. For production applications with user data, always specify exact origins in BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins. Overrides BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins when true. Default: false (null treated as false)","syntax":{"content":"public bool? AllowAnyOrigin { get; set; }","parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null}},"parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyMethod","name":"AllowAnyMethod","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyMethod","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether any HTTP method is allowed.","remarks":"When true, allows all HTTP methods (GET, POST, PUT, DELETE, PATCH, etc.). Overrides BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedMethods when true. Simplifies configuration for APIs that support multiple methods. Default: false (null treated as false)","syntax":{"content":"public bool? AllowAnyMethod { get; set; }","parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null}},"parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyMethod","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyHeader","name":"AllowAnyHeader","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyHeader","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether any header is allowed.","remarks":"When true, allows any header in cross-origin requests. Overrides BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedHeaders when true. Simplifies configuration but reduces control over what headers clients can send. Default: false (null treated as false)","syntax":{"content":"public bool? AllowAnyHeader { get; set; }","parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null}},"parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyHeader","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowWildcardSubdomains","name":"AllowWildcardSubdomains","fullName":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowWildcardSubdomains","kind":"Property","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Gets or sets a value indicating whether wildcard subdomain matching is enabled.","remarks":"When true, origins in BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins are treated as base domains allowing any subdomain. Example: \u0022https://example.com\u0022 allows: - \u0022https://api.example.com\u0022 - \u0022https://app.example.com\u0022 - \u0022https://admin.example.com\u0022 Requires BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowedOrigins to be specified (does not work with BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowAnyOrigin). Compatible with BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowCredentials = true. Default: false (null treated as false)","syntax":{"content":"public bool? AllowWildcardSubdomains { get; set; }","parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null}},"parameters":[],"returns":{"type":"System.Nullable{System.Boolean}","description":null},"parent":"BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.html#BridgingIT.DevKit.Presentation.Web.CorsPolicyOptions.AllowWildcardSubdomains","topics":["domain","presentation"]}]}