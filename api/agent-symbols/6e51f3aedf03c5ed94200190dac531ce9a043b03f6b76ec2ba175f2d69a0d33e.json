ntation.Web.SystemEndpoints%7D%29","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.Map(Microsoft.AspNetCore.Routing.IEndpointRouteBuilder)","name":"Map(IEndpointRouteBuilder)","fullName":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.Map(Microsoft.AspNetCore.Routing.IEndpointRouteBuilder)","kind":"Method","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Maps the enabled system routes into the supplied route builder.","remarks":"The method returns without mapping routes when BridgingIT.DevKit.Presentation.Web.EndpointsOptionsBase.Enabled is false. The root system route is always mapped when enabled; echo, info, and modules are mapped only when their corresponding option flags are enabled. Routes inherit the group configuration applied by BridgingIT.DevKit.Presentation.Web.EndpointsBase.MapGroup(Microsoft.AspNetCore.Routing.IEndpointRouteBuilder%2cBridgingIT.DevKit.Presentation.Web.EndpointsOptionsBase).","syntax":{"content":"public override void Map(IEndpointRouteBuilder app)","parameters":[{"id":"app","type":"Microsoft.AspNetCore.Routing.IEndpointRouteBuilder","description":"The route builder that receives the system endpoint mappings."}],"returns":null},"parameters":[{"id":"app","type":"Microsoft.AspNetCore.Routing.IEndpointRouteBuilder","description":"The route builder that receives the system endpoint mappings."}],"returns":null,"parent":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.SystemEndpoints.html#BridgingIT.DevKit.Presentation.Web.SystemEndpoints.Map%28Microsoft.AspNetCore.Routing.IEndpointRouteBuilder%29","topics":["mapping","presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetSystem(Microsoft.AspNetCore.Http.HttpContext)","name":"GetSystem(HttpContext)","fullName":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetSystem(Microsoft.AspNetCore.Http.HttpContext)","kind":"Method","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Returns links to the enabled system endpoint routes for the current request host.","remarks":"The response includes only links for routes enabled in the options. URLs are built from the request scheme, request host, and configured group path.","syntax":{"content":"public IResult GetSystem(HttpContext httpContext)","parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context used to build absolute endpoint URLs."}],"returns":{"type":"Microsoft.AspNetCore.Http.IResult","description":"An HTTP 200 result containing a dictionary of enabled system route names and URLs."}},"parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context used to build absolute endpoint URLs."}],"returns":{"type":"Microsoft.AspNetCore.Http.IResult","description":"An HTTP 200 result containing a dictionary of enabled system route names and URLs."},"parent":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.SystemEndpoints.html#BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetSystem%28Microsoft.AspNetCore.Http.HttpContext%29","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetEcho(Microsoft.AspNetCore.Http.HttpContext)","name":"GetEcho(HttpContext)","fullName":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetEcho(Microsoft.AspNetCore.Http.HttpContext)","kind":"Method","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Handles the system echo route.","remarks":"The current implementation does not inspect the request and is intended as a lightweight availability probe for the system endpoint group.","syntax":{"content":"public IResult GetEcho(HttpContext httpContext)","parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context."}],"returns":{"type":"Microsoft.AspNetCore.Http.IResult","description":"An HTTP 200 result with no response body."}},"parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context."}],"returns":{"type":"Microsoft.AspNetCore.Http.IResult","description":"An HTTP 200 result with no response body."},"parent":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.SystemEndpoints.html#BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetEcho%28Microsoft.AspNetCore.Http.HttpContext%29","topics":["presentation"]},{"uid":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetInfo(Microsoft.AspNetCore.Http.HttpContext,System.Threading.CancellationToken)","name":"GetInfo(HttpContext, CancellationToken)","fullName":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetInfo(Microsoft.AspNetCore.Http.HttpContext, System.Threading.CancellationToken)","kind":"Method","namespace":"BridgingIT.DevKit.Presentation.Web","assembly":"BridgingIT.DevKit.Presentation.Web","summary":"Returns runtime, request, memory, configuration, custom metadata, and uptime information for the application.","remarks":"The method collects process, runtime, operating system, memory, configuration, and uptime values. When BridgingIT.DevKit.Presentation.Web.SystemEndpointsOptions.HideSensitiveInformation is enabled, machine, network, process, runtime, memory, and configuration details are returned as empty strings while custom metadata and uptime are still included. DNS lookup failures for host addresses are logged as warnings and represented as N/A. Unexpected collection failures are logged as errors and returned as problem details.","syntax":{"content":"public Task GetInfo(HttpContext httpContext, CancellationToken cancellationToken)","parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context used to determine request-local information."},{"id":"cancellationToken","type":"System.Threading.CancellationToken","description":"A cancellation token used while resolving host addresses."}],"returns":{"type":"System.Threading.Tasks.Task{Microsoft.AspNetCore.Http.IResult}","description":"An HTTP 200 result containing BridgingIT.DevKit.Presentation.SystemInfo on success; otherwise an HTTP 500 problem result when system information cannot be collected."}},"parameters":[{"id":"httpContext","type":"Microsoft.AspNetCore.Http.HttpContext","description":"The current HTTP context used to determine request-local information."},{"id":"cancellationToken","type":"System.Threading.CancellationToken","description":"A cancellation token used while resolving host addresses."}],"returns":{"type":"System.Threading.Tasks.Task{Microsoft.AspNetCore.Http.IResult}","description":"An HTTP 200 result containing BridgingIT.DevKit.Presentation.SystemInfo on success; otherwise an HTTP 500 problem result when system information cannot be collected."},"parent":"BridgingIT.DevKit.Presentation.Web.SystemEndpoints","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Presentation.Web.SystemEndpoints.html#BridgingIT.DevKit.Presentation.Web.SystemEndpoints.GetInfo%28Microsoft.AspNetCore.Http.HttpContext%2CSystem.Threading.CancellationToken%29","topics":["presentation"]}]}