mon.DatabaseTransactionIsolationLevel.Chaos","name":"Chaos","fullName":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.Chaos","kind":"Field","namespace":"BridgingIT.DevKit.Common","assembly":"BridgingIT.DevKit.Common.Utilities","summary":"The pending changes from more highly isolated transactions cannot be overwritten.","remarks":null,"syntax":{"content":"Chaos = 16","parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null}},"parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null},"parent":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.html#BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.Chaos","topics":["common","utilities"]},{"uid":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadUncommitted","name":"ReadUncommitted","fullName":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadUncommitted","kind":"Field","namespace":"BridgingIT.DevKit.Common","assembly":"BridgingIT.DevKit.Common.Utilities","summary":"A dirty read is possible, meaning that no shared locks are issued and no exclusive locks are honored.","remarks":null,"syntax":{"content":"ReadUncommitted = 256","parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null}},"parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null},"parent":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.html#BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadUncommitted","topics":["common","utilities"]},{"uid":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadCommitted","name":"ReadCommitted","fullName":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadCommitted","kind":"Field","namespace":"BridgingIT.DevKit.Common","assembly":"BridgingIT.DevKit.Common.Utilities","summary":"Shared locks are held while the data is being read to avoid dirty reads, but the data can be changed before the end of the transaction, resulting in non-repeatable reads or phantom data.","remarks":null,"syntax":{"content":"ReadCommitted = 4096","parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null}},"parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null},"parent":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.html#BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.ReadCommitted","topics":["common","utilities"]},{"uid":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.RepeatableRead","name":"RepeatableRead","fullName":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.RepeatableRead","kind":"Field","namespace":"BridgingIT.DevKit.Common","assembly":"BridgingIT.DevKit.Common.Utilities","summary":"Locks are placed on all data that is used in a query, preventing other users from updating the data. Prevents non-repeatable reads but phantom rows are still possible.","remarks":null,"syntax":{"content":"RepeatableRead = 65536","parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null}},"parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null},"parent":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.html#BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.RepeatableRead","topics":["common","utilities"]},{"uid":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.Serializable","name":"Serializable","fullName":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.Serializable","kind":"Field","namespace":"BridgingIT.DevKit.Common","assembly":"BridgingIT.DevKit.Common.Utilities","summary":"A range lock is placed on the dataset, preventing other users from updating or inserting rows into the dataset until the transaction is complete.","remarks":null,"syntax":{"content":"Serializable = 1048576","parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null}},"parameters":[],"returns":{"type":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","description":null},"parent":"BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel","children":[],"extensionMethods":[],"examples":[],"url":"https://bridgingit-gmbh.github.io/bITdevKit/api/obj/api/BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.html#BridgingIT.DevKit.Common.DatabaseTransactionIsolationLevel.Serializable","topics":["common","serialization","utilities"]}]}