        {
            MessageStatus.Pending => Color.Info,
            MessageStatus.Processing => Color.Warning,
            MessageStatus.Succeeded => Color.Success,
            MessageStatus.Failed => Color.Error,
            MessageStatus.DeadLettered => Color.Error,
            MessageStatus.Expired => Color.Default,
            _ => Color.Default,
        };
