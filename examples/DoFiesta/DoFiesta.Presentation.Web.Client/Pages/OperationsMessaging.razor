@page "/operations/messaging"
@using BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen
@using Microsoft.AspNetCore.Authorization
@using KiotaApiException = Microsoft.Kiota.Abstractions.ApiException
@using BrokerSummary = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageBrokerSummary
@using MessageContentInfo = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageContentInfo
@using MessageHandlerInfo = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageHandlerInfo
@using MessageHandlerStatus = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageHandlerStatus
@using MessageInfo = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageInfo
@using MessageRetryModel = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.RetryBrokerMessageHandlerModel
@using MessageStats = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageStats
@using MessageStatus = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageStatus
@using SubscriptionInfo = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models.BrokerMessageSubscriptionInfo
@inject BackendApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IAsyncDisposable
@attribute [RequireAuthentication]

<PageTitle>DoFiesta - Operations Messages</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudPaper Class="pa-6 mb-4">
        <div class="d-flex flex-wrap align-center gap-4">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Messages</MudText>
            </div>
            <MudSpacer />
            <MudSelect T="int?" Label="Auto refresh" Variant="Variant.Outlined" Margin="Margin.Dense" Value="autoRefreshIntervalSeconds" ValueChanged="OnAutoRefreshIntervalChanged" Style="min-width: 170px;">
                <MudSelectItem T="int?" Value="@((int?)null)">Off</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)1)">1 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)5)">5 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)15)">15 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)30)">30 sec</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync">
                Refresh
            </MudButton>
        </div>
    </MudPaper>

    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Total</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(stats?.Total)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Pending</MudText>
                <MudText Typo="Typo.h4" Color="Color.Info">@DisplayCount(stats?.Pending)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Processing</MudText>
                <MudText Typo="Typo.h4" Color="Color.Warning">@DisplayCount(stats?.Processing)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Succeeded</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@DisplayCount(stats?.Succeeded)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Failed</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@DisplayCount(stats?.Failed)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Archived</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(stats?.Archived)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (waitingMessages is not null && waitingMessages.Count > 0)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Waiting Messages (No Handlers)</MudText>
            <MudTable Items="@waitingMessages" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Type</MudTh>
                    <MudTh>Message Id</MudTh>
                    <MudTh>Created</MudTh>
                </HeaderContent>
                <RowTemplate Context="msg">
                    <MudTd DataLabel="Type">@TrimValue(msg.Type, 64)</MudTd>
                    <MudTd DataLabel="Message Id">@TrimValueFromStart(msg.MessageId, 28)</MudTd>
                    <MudTd DataLabel="Created">
                        <MudTooltip Text="@FormatTimestamp(msg.CreatedDate)">
                            <MudText Typo="Typo.body2">@FormatRelativeTimestamp(msg.CreatedDate)</MudText>
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <MudPaper Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect T="string" Label="Status" @bind-Value="statusFilter">
                    <MudSelectItem Value="@AllStatusesValue">All statuses</MudSelectItem>
                    @foreach (var status in FilterStatuses)
                    {
                        <MudSelectItem Value="@status.ToString()">@status.Humanize()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string" Label="Archive scope" @bind-Value="archiveFilter">
                    <MudSelectItem Value="@ArchiveActiveValue">Active only</MudSelectItem>
                    <MudSelectItem Value="@ArchiveArchivedValue">Archived only</MudSelectItem>
                    <MudSelectItem Value="@ArchiveAllValue">Active and archived</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int" Label="Rows" @bind-Value="take">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                    <MudSelectItem Value="250">250</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="typeFilter" Label="Type contains" Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="messageIdFilter" Label="Message Id" Clearable="true" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudGrid>
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="createdStartDate" Label="Created from" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="createdEndDate" Label="Created to" />
            </MudItem>
        </MudGrid>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="ReloadAsync">
                Apply
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ResetFiltersAsync">
                Reset
            </MudButton>
        </div>
    </MudPaper>

    <MudGrid Class="mb-4">
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-2">
                @if (!string.IsNullOrWhiteSpace(loadError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-2">@loadError</MudAlert>
                }
                else if (loading && messages.Count == 0)
                {
                    <div class="pa-4">
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                    </div>
                }
                else if (messages.Count == 0)
                {
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Class="ma-2">
                        No messages matched the current filters.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@messages"
                              Dense="true"
                              Hover="true"
                              Loading="@loading"
                              LoadingProgressColor="Color.Info"
                              Elevation="0">
                        <HeaderContent>
                            <MudTh>Status</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Message Id</MudTh>
                            <MudTh>Attempts</MudTh>
                            <MudTh>Processed</MudTh>
                            <MudTh>Lease</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="message">
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Color="@GetStatusColor(message.Status)" Variant="Variant.Filled" Size="Size.Small">
                                    @GetStatusLabel(message.Status)
                                </MudChip>
                                @if (message.IsArchived == true)
                                {
                                    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="ml-2">
                                        Archived
                                    </MudChip>
                                }
                            </MudTd>
                            <MudTd DataLabel="Created">
                                <MudTooltip Text="@FormatTimestamp(message.CreatedDate)">
                                    <MudText Typo="Typo.body2">@FormatRelativeTimestamp(message.CreatedDate)</MudText>
                                </MudTooltip>
                            </MudTd>
                            <MudTd DataLabel="Type">@TrimValue(message.Type, 48)</MudTd>
                            <MudTd DataLabel="Message Id">@TrimValueFromStart(message.MessageId, 28)</MudTd>
                            <MudTd DataLabel="Attempts">@DisplayCount(message.AttemptCountSummary)</MudTd>
                            <MudTd DataLabel="Processed">@FormatRelativeTimestamp(message.ProcessedDate)</MudTd>
                            <MudTd DataLabel="Lease">
                                @if (!string.IsNullOrWhiteSpace(message.LockedBy))
                                {
                                    <MudTooltip Text="@($"{message.LockedBy} until {FormatTimestamp(message.LockedUntil)}")">
                                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Leased</MudChip>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">-</MudText>
                                }
                            </MudTd>
                            <MudTd>
                                <div class="d-flex justify-end gap-1">
                                    <MudTooltip Text="Open details">
                                        <MudIconButton Icon="@Icons.Material.Filled.Info"
                                                       Color="Color.Info"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OpenDetailsAsync(message))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View content">
                                        <MudIconButton Icon="@Icons.Material.Filled.Article"
                                                       Color="Color.Secondary"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OpenContentAsync(message))" />
                                    </MudTooltip>
                                    @if (CanRetryMessage(message))
                                    {
                                        <MudTooltip Text="Retry message">
                                            <MudIconButton Icon="@Icons.Material.Filled.RestartAlt"
                                                           Color="Color.Warning"
                                                           Size="Size.Small"
                                                           OnClick="@(() => RetryMessageAsync(message))" />
                                        </MudTooltip>
                                    }
                                    @if (CanArchiveMessage(message))
                                    {
                                        <MudTooltip Text="Archive message">
                                            <MudIconButton Icon="@Icons.Material.Filled.Archive"
                                                           Color="Color.Default"
                                                           Size="Size.Small"
                                                           OnClick="@(() => ArchiveMessageAsync(message))" />
                                        </MudTooltip>
                                    }
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Subscriptions</MudText>
                @if (subscriptions is null || subscriptions.Count == 0)
                {
                    <MudText Typo="Typo.body2">No message subscriptions are registered.</MudText>
                }
                else
                {
                    @foreach (var subscription in subscriptions)
                    {
                        <MudPaper Class="pa-3 mb-2" Outlined="true">
                            <MudText Typo="Typo.subtitle2">@subscription.MessageType</MudText>
                            <MudText Typo="Typo.body2">Handler: @TrimValue(subscription.HandlerType, 48)</MudText>
                            <div class="d-flex flex-wrap gap-1 mt-2">
                                @if (subscription.IsMessageTypePaused == true)
                                {
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Type paused</MudChip>
                                }
                            </div>
                            <div class="d-flex flex-wrap gap-1 mt-2">
                                @if (subscription.IsMessageTypePaused == true)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.PlayCircleOutline" OnClick="@(() => ResumeTypeAsync(subscription.MessageType))">
                                        Resume Type
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" StartIcon="@Icons.Material.Filled.PauseCircleOutline" OnClick="@(() => PauseTypeAsync(subscription.MessageType))">
                                        Pause Type
                                    </MudButton>
                                }
                            </div>
                        </MudPaper>
                    }
                }
            </MudPaper>

        </MudItem>
    </MudGrid>
</MudContainer>

<MudDialog @bind-Visible="detailsDialogVisible" Options="new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Large }">
    <TitleContent>
        <MudText Typo="Typo.h6">Message Details</MudText>
    </TitleContent>
    <DialogContent>
        @if (detailsLoading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Info" />
        }
        else if (selectedMessage is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No message details are loaded.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Overview</MudText>
                        <MudText><strong>Status:</strong> @GetStatusLabel(selectedMessage.Status)</MudText>
                        <MudText><strong>Type:</strong> @DisplayValue(selectedMessage.Type)</MudText>
                        <MudText><strong>Message Id:</strong> @DisplayValue(selectedMessage.MessageId)</MudText>
                        <MudText><strong>Created:</strong> @FormatTimestamp(selectedMessage.CreatedDate)</MudText>
                        <MudText><strong>Processed:</strong> @FormatTimestamp(selectedMessage.ProcessedDate)</MudText>
                        <MudText><strong>Expires:</strong> @FormatTimestamp(selectedMessage.ExpiresOn)</MudText>
                        <MudText><strong>Locked Until:</strong> @FormatTimestamp(selectedMessage.LockedUntil)</MudText>
                        <MudText><strong>Locked By:</strong> @DisplayValue(selectedMessage.LockedBy)</MudText>
                        <MudText><strong>Archived:</strong> @(selectedMessage.IsArchived == true ? "Yes" : "No")</MudText>
                        <MudText><strong>Archived At:</strong> @FormatTimestamp(selectedMessage.ArchivedDate)</MudText>
                    </MudPaper>

                    @if (!string.IsNullOrWhiteSpace(selectedMessage.LastError))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@selectedMessage.LastError</MudAlert>
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Actions</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.Article"
                                       OnClick="OpenSelectedContentAsync">
                                View Content
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.RestartAlt"
                                       Disabled="@(!CanRetryMessage(selectedMessage))"
                                       OnClick="@(() => RetryMessageAsync(selectedMessage))">
                                Retry Message
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.Archive"
                                       Disabled="@(!CanArchiveMessage(selectedMessage))"
                                       OnClick="@(() => ArchiveMessageAsync(selectedMessage))">
                                Archive Message
                            </MudButton>
                            @if (!string.IsNullOrWhiteSpace(selectedMessage.Type))
                            {
                                <MudDivider Class="my-2" />
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Pause"
                                           OnClick="@(() => PauseTypeAsync(selectedMessage.Type))">
                                    Pause Type
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="@(() => ResumeTypeAsync(selectedMessage.Type))">
                                    Resume Type
                                </MudButton>
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Handlers</MudText>
                        @if (GetHandlers(selectedMessage).Count == 0)
                        {
                            <MudText Typo="Typo.body2">No handler details are available for this message.</MudText>
                        }
                        else
                        {
                            <MudTable Items="@GetHandlers(selectedMessage)" Dense="true" Hover="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Handler</MudTh>
                                    <MudTh>Subscription</MudTh>
                                    <MudTh>Attempts</MudTh>
                                    <MudTh>Processed</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate Context="handler">
                                    <MudTd DataLabel="Status">
                                        <MudChip T="string" Color="@GetHandlerStatusColor(handler.Status)" Variant="Variant.Filled" Size="Size.Small">
                                            @GetHandlerStatusLabel(handler.Status)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Handler">@DisplayValue(handler.HandlerType)</MudTd>
                                    <MudTd DataLabel="Subscription">@DisplayValue(handler.SubscriptionKey)</MudTd>
                                    <MudTd DataLabel="Attempts">@DisplayCount(handler.AttemptCount)</MudTd>
                                    <MudTd DataLabel="Processed">@FormatTimestamp(handler.ProcessedDate)</MudTd>
                                    <MudTd>
                                        @if (!string.IsNullOrWhiteSpace(handler.LastError))
                                        {
                                            <MudTooltip Text="@handler.LastError">
                                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" />
                                            </MudTooltip>
                                        }
                                        @if (CanRetryHandler(handler))
                                        {
                                            <MudTooltip Text="Retry handler">
                                                <MudIconButton Icon="@Icons.Material.Filled.RestartAlt"
                                                               Color="Color.Warning"
                                                               Size="Size.Small"
                                                               OnClick="@(() => RetryHandlerAsync(handler))" />
                                            </MudTooltip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
</MudDialog>

<MudDialog @bind-Visible="contentDialogVisible" Options="new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Large }">
    <TitleContent>
        <MudText Typo="Typo.h6">Message Content</MudText>
    </TitleContent>
    <DialogContent>
        @if (contentLoading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Info" />
        }
        else if (selectedContent is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No message content is loaded.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Metadata</MudText>
                        <MudText><strong>Type:</strong> @DisplayValue(selectedContent.Type)</MudText>
                        <MudText><strong>Message Id:</strong> @DisplayValue(selectedContent.MessageId)</MudText>
                        <MudText><strong>Created:</strong> @FormatTimestamp(selectedContent.CreatedDate)</MudText>
                        <MudText><strong>Content Hash:</strong> @DisplayValue(selectedContent.ContentHash)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Payload</MudText>
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: Consolas, monospace;">
                            @DisplayValue(selectedContent.Content)
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
</MudDialog>

@code {
    private const string AllStatusesValue = "__all";
    private const string ArchiveActiveValue = "active";
    private const string ArchiveArchivedValue = "archived";
    private const string ArchiveAllValue = "all";

    private static readonly MessageStatus[] FilterStatuses =
    [
        MessageStatus.Pending,
        MessageStatus.Processing,
        MessageStatus.Succeeded,
        MessageStatus.Failed,
        MessageStatus.DeadLettered,
        MessageStatus.Expired,
    ];

    private readonly List<MessageInfo> messages = [];
    private MessageStats stats;
    private BrokerSummary summary;
    private List<SubscriptionInfo> subscriptions;
    private List<MessageInfo> waitingMessages;
    private bool loading;
    private string loadError;
    private string statusFilter = AllStatusesValue;
    private string archiveFilter = ArchiveActiveValue;
    private string typeFilter;
    private string messageIdFilter;
    private int take = 50;
    private DateTime? createdStartDate = DateTime.Today;
    private DateTime? createdEndDate = DateTime.Today;
    private bool detailsDialogVisible;
    private bool detailsLoading;
    private MessageInfo selectedMessage;
    private bool contentDialogVisible;
    private bool contentLoading;
    private MessageContentInfo selectedContent;
    private int? autoRefreshIntervalSeconds = 5;
    private PeriodicTimer autoRefreshTimer;
    private CancellationTokenSource autoRefreshCancellation;
    private bool isDisposed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await this.JS.InvokeAsync<string>("localStorage.getItem", "dofiesta:autoRefreshInterval");
            if (!string.IsNullOrWhiteSpace(saved) && int.TryParse(saved, out var parsed) && parsed >= 0)
            {
                this.autoRefreshIntervalSeconds = parsed == 0 ? null : parsed;
            }
        }
        catch
        {
            // localStorage not available (e.g., prerendering)
        }

        this.StartAutoRefresh();
        await this.ReloadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        this.isDisposed = true;
        this.StopAutoRefresh();
        await Task.CompletedTask;
    }

    private async Task ReloadAsync()
    {
        this.loading = true;
        this.loadError = null;

        try
        {
            await this.LoadStatsAsync();
            await this.LoadMessagesAsync();
            await this.LoadSummaryAsync();
            await this.LoadSubscriptionsAsync();
            await this.LoadWaitingMessagesAsync();
        }
        catch (KiotaApiException ex)
        {
            this.loadError = $"Loading broker messages failed: {ex.Message}";
            this.Snackbar.Add(this.loadError, Severity.Error);
        }
        catch (Exception ex)
        {
            this.loadError = $"Loading broker messages failed: {ex.Message}";
            this.Snackbar.Add(this.loadError, Severity.Error);
        }
        finally
        {
            this.loading = false;
        }
    }

    private async Task ResetFiltersAsync()
    {
        this.statusFilter = AllStatusesValue;
        this.archiveFilter = ArchiveActiveValue;
        this.typeFilter = null;
        this.messageIdFilter = null;
        this.take = 50;
        this.createdStartDate = DateTime.Today;
        this.createdEndDate = DateTime.Today;

        await this.ReloadAsync();
    }

    private async Task OnAutoRefreshIntervalChanged(int? value)
    {
        this.autoRefreshIntervalSeconds = value;
        this.StartAutoRefresh();

        try
        {
            if (value.HasValue && value.Value > 0)
            {
                await this.JS.InvokeVoidAsync("localStorage.setItem", "dofiesta:autoRefreshInterval", value.Value.ToString());
            }
            else
            {
                await this.JS.InvokeVoidAsync("localStorage.setItem", "dofiesta:autoRefreshInterval", "0");
            }
        }
        catch
        {
            // localStorage not available
        }
    }

    private async Task LoadStatsAsync()
    {
        this.stats = await this.Api.Api._system.Messaging.Messages.Stats.GetAsync(config =>
        {
            config.QueryParameters.IsArchived = this.GetArchiveFilter();
            config.QueryParameters.StartDate = this.ToStartDateOffset(this.createdStartDate);
            config.QueryParameters.EndDate = this.ToEndDateOffset(this.createdEndDate);
        });
    }

    private async Task LoadMessagesAsync()
    {
        var result = await this.Api.Api._system.Messaging.Messages.GetAsync(config =>
        {
            config.QueryParameters.IncludeHandlers = false;
            config.QueryParameters.IsArchived = this.GetArchiveFilter();
            config.QueryParameters.CreatedAfter = this.ToStartDateOffset(this.createdStartDate);
            config.QueryParameters.CreatedBefore = this.ToEndDateOffset(this.createdEndDate);
            config.QueryParameters.Take = this.take;

            if (!string.IsNullOrWhiteSpace(this.typeFilter))
            {
                config.QueryParameters.Type = this.typeFilter;
            }

            if (!string.IsNullOrWhiteSpace(this.messageIdFilter))
            {
                config.QueryParameters.MessageId = this.messageIdFilter;
            }

            if (Enum.TryParse<MessageStatus>(this.statusFilter, true, out var status))
            {
                config.QueryParameters.StatusAsBrokerMessageStatus = status;
            }
        });

        this.messages.Clear();
        this.messages.AddRange(result?.OrderByDescending(m => m.CreatedDate ?? DateTimeOffset.MinValue).ToList() ?? []);
    }

