    private async Task RefreshStateAsync(Guid messageId)
    {
        await this.ReloadAsync();

        if (this.detailsDialogVisible)
        {
            var message = this.messages.FirstOrDefault(m => m.Id == messageId) ?? new MessageInfo { Id = messageId };
            await this.OpenDetailsAsync(message);
        }

        if (this.contentDialogVisible)
        {
            var message = this.messages.FirstOrDefault(m => m.Id == messageId) ?? new MessageInfo { Id = messageId };
            await this.OpenContentAsync(message);
        }
    }

    private bool? GetArchiveFilter()
    {
        return this.archiveFilter switch
        {
            ArchiveActiveValue => false,
            ArchiveArchivedValue => true,
            _ => null,
        };
    }

    private static List<MessageHandlerInfo> GetHandlers(MessageInfo message)
    {
        return message.Handlers ?? [];
    }

    private static bool CanRetryMessage(MessageInfo message)
    {
        return message.IsArchived != true &&
               (message.Status == MessageStatus.Failed || message.Status == MessageStatus.DeadLettered);
    }

    private static bool CanArchiveMessage(MessageInfo message)
    {
        return message.IsArchived != true &&
               (message.Status == MessageStatus.Succeeded ||
                message.Status == MessageStatus.DeadLettered ||
                message.Status == MessageStatus.Expired);
    }

    private static bool CanRetryHandler(MessageHandlerInfo handler)
    {
        return handler.Status == MessageHandlerStatus.Failed || handler.Status == MessageHandlerStatus.DeadLettered;
    }

