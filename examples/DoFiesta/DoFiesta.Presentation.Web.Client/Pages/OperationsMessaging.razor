    private static Color GetHandlerStatusColor(MessageHandlerStatus? status)
    {
        return status switch
        {
            MessageHandlerStatus.Pending => Color.Info,
            MessageHandlerStatus.Processing => Color.Warning,
            MessageHandlerStatus.Succeeded => Color.Success,
            MessageHandlerStatus.Failed => Color.Error,
            MessageHandlerStatus.DeadLettered => Color.Error,
            MessageHandlerStatus.Expired => Color.Default,
            _ => Color.Default,
