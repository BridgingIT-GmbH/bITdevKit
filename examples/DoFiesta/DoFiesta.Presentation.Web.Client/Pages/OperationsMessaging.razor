    private async Task RetryHandlerAsync(MessageHandlerInfo handler)
    {
        if (this.selectedMessage?.Id is null || string.IsNullOrWhiteSpace(handler.HandlerType))
        {
            return;
        }

        try
        {
            await this.Api.Api._system.Messaging.Messages[this.selectedMessage.Id.Value].Handlers.Retry.PostAsync(
                new MessageRetryModel { HandlerType = handler.HandlerType });

            this.Snackbar.Add("Handler retry requested.", Severity.Success);
            await this.RefreshStateAsync(this.selectedMessage.Id.Value);
        }
        catch (KiotaApiException ex)
        {
            this.Snackbar.Add($"Handler retry failed: {ex.Message}", Severity.Error);
        }
