    private Dictionary<string, double> ReadDoubleDictionary(object value)
    {
        return this.ReadAdditionalData(value)
            .Select(entry => new KeyValuePair<string, double?>(entry.Key, this.ReadDouble(entry.Value)))
            .Where(entry => entry.Value.HasValue)
            .ToDictionary(entry => entry.Key, entry => entry.Value.Value, StringComparer.OrdinalIgnoreCase);
    }

    private IDictionary<string, object> ReadAdditionalData(IAdditionalDataHolder holder)
    {
        return holder?.AdditionalData ?? new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);
    }

    private IDictionary<string, object> ReadAdditionalData(object value)
    {
        return value switch
        {
            null => new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase),
            IDictionary<string, object> dictionary => dictionary,
            IAdditionalDataHolder holder => holder.AdditionalData ?? new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase),
            UntypedObject untypedObject => untypedObject.GetValue()
                .ToDictionary(entry => entry.Key, entry => (object)entry.Value, StringComparer.OrdinalIgnoreCase),
            _ => new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase),
        };
    }

    private IEnumerable<object> ReadSequence(object value)
    {
        return value switch
        {
            null => [],
            UntypedArray untypedArray => untypedArray.GetValue().Cast<object>(),
            IEnumerable<object> items => items,
            System.Collections.IEnumerable items => items.Cast<object>(),
            _ => [],
        };
    }

    private object ReadValue(IDictionary<string, object> data, string key)
    {
        return data.TryGetValue(key, out var value) ? value : null;
    }

    private string ReadString(IDictionary<string, object> data, string key)
    {
        return this.ReadString(this.ReadValue(data, key));
    }

    private string ReadString(object value)
    {
        return value switch
        {
            null => null,
            UntypedString stringValue => stringValue.GetValue(),
            string stringValue => stringValue,
            _ => Convert.ToString(value, CultureInfo.InvariantCulture),
        };
    }

    private double? ReadNullableDouble(IDictionary<string, object> data, string key)
    {
        return this.ReadDouble(this.ReadValue(data, key));
    }

    private double? ReadDouble(object value)
    {
        return value switch
        {
            null => null,
            UntypedDouble doubleValue => doubleValue.GetValue(),
            UntypedFloat floatValue => Convert.ToDouble(floatValue.GetValue(), CultureInfo.InvariantCulture),
            UntypedDecimal decimalValue => Convert.ToDouble(decimalValue.GetValue(), CultureInfo.InvariantCulture),
            UntypedInteger intValue => intValue.GetValue(),
            UntypedLong longValue => longValue.GetValue(),
            double doubleValue => doubleValue,
            float floatValue => Convert.ToDouble(floatValue, CultureInfo.InvariantCulture),
            decimal decimalValue => Convert.ToDouble(decimalValue, CultureInfo.InvariantCulture),
            int intValue => intValue,
            long longValue => longValue,
            short shortValue => shortValue,
            byte byteValue => byteValue,
            string stringValue when double.TryParse(stringValue, NumberStyles.Any, CultureInfo.InvariantCulture, out var parsed) => parsed,
            _ => null,
        };
    }

    private long? ReadNullableLong(IDictionary<string, object> data, string key)
    {
        return this.ReadLong(this.ReadValue(data, key));
    }

    private long? ReadLong(object value)
    {
        return value switch
        {
            null => null,
            UntypedLong longValue => longValue.GetValue(),
            UntypedInteger intValue => intValue.GetValue(),
            UntypedDouble doubleValue => Convert.ToInt64(doubleValue.GetValue(), CultureInfo.InvariantCulture),
            UntypedDecimal decimalValue => Convert.ToInt64(decimalValue.GetValue(), CultureInfo.InvariantCulture),
            long longValue => longValue,
            int intValue => intValue,
            short shortValue => shortValue,
            byte byteValue => byteValue,
            double doubleValue => Convert.ToInt64(doubleValue, CultureInfo.InvariantCulture),
            decimal decimalValue => Convert.ToInt64(decimalValue, CultureInfo.InvariantCulture),
            string stringValue when long.TryParse(stringValue, NumberStyles.Any, CultureInfo.InvariantCulture, out var parsed) => parsed,
            _ => null,
        };
    }

    private double GetSummaryCard(string key)
    {
        return this.overview.SummaryCards.TryGetValue(key, out var value) ? value : 0;
    }

    private DateTimeOffset? GetLatestCapturedAt()
    {
        var latest = new[] { this.overview.CapturedAtUtc, this.dotNetSnapshot.CapturedAtUtc, this.aspNetSnapshot.CapturedAtUtc }
            .Where(value => value.HasValue)
            .Select(value => value.Value)
            .OrderByDescending(value => value)
            .FirstOrDefault();

        return latest == default ? null : latest;
    }

    private static string FormatMetricPair(MetricValueViewModel metric)
    {
        return string.IsNullOrWhiteSpace(metric?.Name)
            ? "-"
            : $"{metric.Name} ({FormatMetricNumber(metric.Value)})";
    }

    private static string FormatLatencyPair(MetricLatencyViewModel metric)
    {
        return string.IsNullOrWhiteSpace(metric?.Name)
            ? "-"
            : $"{metric.Name} ({FormatMetricNumber(metric.Average)} ms avg)";
    }

    private static string DisplayCount(double? value)
    {
        return FormatMetricNumber(value);
    }

    private static string DisplayCount(long? value)
    {
        return value.HasValue ? value.Value.ToString("N0", CultureInfo.InvariantCulture) : "0";
    }

    private static string DisplayCount(int? value)
    {
        return value.HasValue ? value.Value.ToString("N0", CultureInfo.InvariantCulture) : "0";
    }

    private static string FormatMetricNumber(double? value)
    {
        if (!value.HasValue)
        {
            return "0";
        }

        var rounded = Math.Round(value.Value, 2);
        return Math.Abs(rounded % 1) < 0.0001
            ? rounded.ToString("N0", CultureInfo.InvariantCulture)
            : rounded.ToString("N2", CultureInfo.InvariantCulture);
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue ? value.Value.LocalDateTime.ToString("g", CultureInfo.InvariantCulture) : "-";
    }

    private static string FormatUptime(double? uptimeSeconds)
    {
        if (!uptimeSeconds.HasValue || uptimeSeconds <= 0)
        {
            return "-";
        }

        return TimeSpan.FromSeconds(uptimeSeconds.Value).Humanize(2);
    }

    private void StartAutoRefresh()
    {
        this.StopAutoRefresh();

        if (!this.autoRefreshIntervalSeconds.HasValue || this.autoRefreshIntervalSeconds.Value <= 0)
        {
            return;
        }

        this.autoRefreshCancellation = new CancellationTokenSource();
        this.autoRefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(this.autoRefreshIntervalSeconds.Value));
        _ = this.RunAutoRefreshAsync(this.autoRefreshTimer, this.autoRefreshCancellation.Token);
    }

    private void StopAutoRefresh()
    {
        if (this.autoRefreshCancellation is not null)
        {
            this.autoRefreshCancellation.Cancel();
            this.autoRefreshCancellation.Dispose();
            this.autoRefreshCancellation = null;
        }

        this.autoRefreshTimer?.Dispose();
        this.autoRefreshTimer = null;
    }

    private async Task RunAutoRefreshAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (!this.loading)
                {
                    await this.LoadAsync();
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private Task InvokeSafeStateHasChangedAsync()
    {
        return this.isDisposed ? Task.CompletedTask : this.InvokeAsync(this.StateHasChanged);
    }

