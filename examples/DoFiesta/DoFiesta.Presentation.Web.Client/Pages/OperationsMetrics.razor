    private async Task OnAutoRefreshIntervalChanged(int? value)
    {
        this.autoRefreshIntervalSeconds = value;
        this.StartAutoRefresh();

        try
        {
            await this.JS.InvokeVoidAsync(
                "localStorage.setItem",
                "dofiesta:metrics:autoRefreshInterval",
                value.HasValue && value.Value > 0 ? value.Value.ToString(CultureInfo.InvariantCulture) : "0");
        }
        catch
        {
        }
    }

    private async Task LoadAsync()
    {
        this.loading = true;
        this.loadError = null;

        try
        {
            var overviewTask = this.Api.Bdk.Api.Metrics.Overview.GetAsync();
            var appTask = this.Api.Bdk.Api.Metrics.Bdk.GetAsync();
            var dotNetTask = this.Api.Bdk.Api.Metrics.Dotnet.GetAsync();
            var aspNetTask = this.Api.Bdk.Api.Metrics.Aspnet.GetAsync();
            var aspNetRoutesTask = this.Api.Bdk.Api.Metrics.Aspnet.Routes.GetAsync();

            await Task.WhenAll(overviewTask, appTask, dotNetTask, aspNetTask, aspNetRoutesTask);

            this.overview = this.MapOverviewSnapshot(overviewTask.Result);
            this.appSnapshot = this.MapBdkSnapshot(appTask.Result);
            this.dotNetSnapshot = this.MapDotNetSnapshot(dotNetTask.Result);
            this.aspNetSnapshot = this.MapAspNetSnapshot(aspNetTask.Result);
            this.aspNetRoutesSnapshot = this.MapAspNetRouteSnapshot(aspNetRoutesTask.Result);

            this.SyncFilters();
            this.RebuildViewModels();
        }
        catch (Exception ex)
        {
            this.loadError = ex.Message;
            this.Snackbar.Add($"Failed to load metrics: {ex.Message}", Severity.Error);
        }
        finally
        {
            this.loading = false;
            await this.InvokeSafeStateHasChangedAsync();
        }
    }

    private void SyncFilters()
    {
        this.availableFeatures.Clear();
        this.availableFeatures.AddRange(this.appSnapshot.AvailableMetrics
            .Select(metric => metric.Feature)
            .Where(feature => !string.IsNullOrWhiteSpace(feature))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(feature => feature, StringComparer.OrdinalIgnoreCase));

        this.availableKinds.Clear();
        this.availableKinds.AddRange(this.appSnapshot.AvailableMetrics
            .Select(metric => metric.Kind)
            .Where(kind => !string.IsNullOrWhiteSpace(kind))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(kind => kind, StringComparer.OrdinalIgnoreCase));

        if (!string.Equals(this.selectedFeatureFilter, AllFilterValue, StringComparison.Ordinal)
            && !this.availableFeatures.Contains(this.selectedFeatureFilter, StringComparer.OrdinalIgnoreCase))
        {
            this.selectedFeatureFilter = AllFilterValue;
        }

        if (!string.Equals(this.selectedKindFilter, AllFilterValue, StringComparison.Ordinal)
            && !this.availableKinds.Contains(this.selectedKindFilter, StringComparer.OrdinalIgnoreCase))
        {
            this.selectedKindFilter = AllFilterValue;
        }

        var availableMetricNames = this.appSnapshot.AvailableMetrics.Select(metric => metric.Name).ToHashSet(StringComparer.Ordinal);
        this.selectedMetricNames.RemoveWhere(name => !availableMetricNames.Contains(name));
    }

    private void RebuildViewModels()
    {
        this.featureRows.Clear();
        this.featureRows.AddRange(this.overview.Features.Values
            .OrderBy(feature => feature.Name, StringComparer.OrdinalIgnoreCase)
            .Select(feature => new FeatureRowModel
            {
                Name = feature.Name,
                SuccessTotal = feature.SuccessTotal,
                FailureTotal = feature.FailureTotal,
                CurrentTotal = feature.CurrentTotal,
                TopThroughput = feature.TopThroughput,
                TopCurrent = feature.TopCurrent,
                SlowestSeries = feature.SlowestSeries,
            }));

        this.filteredAvailableMetrics.Clear();
        this.filteredAvailableMetrics.AddRange(this.appSnapshot.AvailableMetrics
            .Where(this.MatchesMetricFilter)
            .OrderBy(metric => metric.Feature, StringComparer.OrdinalIgnoreCase)
            .ThenBy(metric => metric.Kind, StringComparer.OrdinalIgnoreCase)
            .ThenBy(metric => metric.Name, StringComparer.OrdinalIgnoreCase)
            .Select(metric => new MetricDescriptorViewModel
            {
                Name = metric.Name,
                Feature = metric.Feature,
                Kind = metric.Kind,
                Unit = metric.Unit,
            }));

        this.selectedMetricRows.Clear();
        this.selectedMetricRows.AddRange(this.appSnapshot.AvailableMetrics
            .Where(metric => this.selectedMetricNames.Contains(metric.Name))
            .Select(this.BuildSelectedMetricRow)
            .Where(metric => metric is not null)
            .OrderBy(metric => metric.Feature, StringComparer.OrdinalIgnoreCase)
            .ThenBy(metric => metric.Kind, StringComparer.OrdinalIgnoreCase)
            .ThenBy(metric => metric.Name, StringComparer.OrdinalIgnoreCase));
    }

    private bool MatchesMetricFilter(BdkMetricDescriptorViewModel metric)
    {
        if (!string.Equals(this.selectedFeatureFilter, AllFilterValue, StringComparison.Ordinal)
            && !string.Equals(metric.Feature, this.selectedFeatureFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.Equals(this.selectedKindFilter, AllFilterValue, StringComparison.Ordinal)
            && !string.Equals(metric.Kind, this.selectedKindFilter, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(this.metricSearch))
        {
            return true;
        }

        return metric.Name.Contains(this.metricSearch, StringComparison.OrdinalIgnoreCase)
            || metric.Feature.Contains(this.metricSearch, StringComparison.OrdinalIgnoreCase)
            || metric.Kind.Contains(this.metricSearch, StringComparison.OrdinalIgnoreCase);
    }

    private SelectedMetricRowModel BuildSelectedMetricRow(BdkMetricDescriptorViewModel metric)
    {
        if (!this.appSnapshot.Features.TryGetValue(metric.Feature, out var feature))
        {
            return null;
        }

        if (string.Equals(metric.Kind, "duration", StringComparison.OrdinalIgnoreCase)
            && feature.Durations.TryGetValue(metric.Name, out var histogram))
        {
            return new SelectedMetricRowModel
            {
                Name = metric.Name,
                Feature = metric.Feature,
                Kind = metric.Kind,
                Value = $"avg {FormatMetricNumber(histogram.Average)} {metric.Unit ?? "ms"}",
                Detail = $"max {FormatMetricNumber(histogram.Max)} {metric.Unit ?? "ms"}, count {DisplayCount(histogram.Count)}",
            };
        }

        if (string.Equals(metric.Kind, "current", StringComparison.OrdinalIgnoreCase)
            && feature.Current.TryGetValue(metric.Name, out var currentValue))
        {
            return new SelectedMetricRowModel
            {
                Name = metric.Name,
                Feature = metric.Feature,
                Kind = metric.Kind,
                Value = FormatMetricNumber(currentValue),
                Detail = "Current live value",
            };
        }

        if (feature.Counters.TryGetValue(metric.Name, out var counterValue))
        {
            return new SelectedMetricRowModel
            {
                Name = metric.Name,
                Feature = metric.Feature,
                Kind = metric.Kind,
                Value = FormatMetricNumber(counterValue),
                Detail = string.Equals(metric.Kind, "total", StringComparison.OrdinalIgnoreCase)
                    ? "Cumulative total"
                    : "Snapshot counter",
            };
        }

        return new SelectedMetricRowModel
        {
            Name = metric.Name,
            Feature = metric.Feature,
            Kind = metric.Kind,
            Value = "-",
            Detail = "Not present in current snapshot",
        };
    }

    private void ToggleMetric(string name, bool value)
    {
        if (value)
        {
            this.selectedMetricNames.Add(name);
        }
        else
        {
            this.selectedMetricNames.Remove(name);
        }

        this.RebuildViewModels();
    }

    private void ClearMetricSelection()
    {
        this.selectedMetricNames.Clear();
        this.RebuildViewModels();
    }

