@page "/operations/metrics"
@using System.Globalization
@using BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen
@using Microsoft.Kiota.Abstractions.Serialization
@using Models = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models
@inject BackendApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IAsyncDisposable
@attribute [RequireAuthentication]

<PageTitle>DoFiesta - Operations Metrics</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-6">
    <MudPaper Class="pa-6 mb-4">
        <div class="d-flex flex-wrap align-center gap-4">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Metrics</MudText>
                @* <MudText Typo="Typo.body2">Inspect live devkit, .NET runtime, and ASP.NET request metrics from the current system snapshot.</MudText> *@
            </div>
            <MudSpacer />
            <MudSelect T="int?" Label="Auto refresh" Variant="Variant.Outlined" Margin="Margin.Dense" Value="autoRefreshIntervalSeconds" ValueChanged="OnAutoRefreshIntervalChanged" Style="min-width: 170px;">
                <MudSelectItem T="int?" Value="@((int?)null)">Off</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)1)">1 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)5)">5 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)15)">15 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)30)">30 sec</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" Disabled="@loading">
                Refresh
            </MudButton>
        </div>
    </MudPaper>

    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">App Success</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(this.GetSummaryCard("totalSuccess"))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">App Failure</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@DisplayCount(this.GetSummaryCard("totalFailure"))</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">.NET CPU</MudText>
                <MudText Typo="Typo.h4" Color="Color.Info">@FormatMetricNumber(this.dotNetSnapshot.CpuUsagePercent)%</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Working Set</MudText>
                <MudText Typo="Typo.h6">@FormatMetricNumber(this.dotNetSnapshot.WorkingSetMb) MB</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">ASP.NET Requests</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(this.aspNetSnapshot.TotalRequests)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Avg Latency</MudText>
                <MudText Typo="Typo.h6">@FormatMetricNumber(this.aspNetSnapshot.AverageLatencyMs) ms</MudText>
                <MudText Typo="Typo.caption">@FormatTimestamp(this.GetLatestCapturedAt())</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@loadError</MudAlert>
    }

    <MudTabs Rounded="true" Elevation="1">
        <MudTabPanel Text="App">
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Top Current</MudText>
                        @if (this.appSnapshot.TopCurrent.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No live current metrics are available.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var metric in this.appSnapshot.TopCurrent.Take(5))
                                {
                                    <MudListItem T="string">
                                        <div class="w-100 d-flex justify-space-between gap-4">
                                            <MudText Typo="Typo.body2">@metric.Name</MudText>
                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@FormatMetricNumber(metric.Value)</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Top Failures</MudText>
                        @if (this.overview.TopFailures.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No failure metrics are currently recorded.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var metric in this.overview.TopFailures.Take(5))
                                {
                                    <MudListItem T="string">
                                        <div class="w-100 d-flex justify-space-between gap-4">
                                            <MudText Typo="Typo.body2">@metric.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Error" Class="font-weight-medium">@FormatMetricNumber(metric.Value)</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Latency Highlights</MudText>
                        @if (this.overview.LatencyHighlights.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No latency histograms are available yet.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var metric in this.overview.LatencyHighlights.Take(5))
                                {
                                    <MudListItem T="string">
                                        <div class="w-100">
                                            <MudText Typo="Typo.body2">@metric.Name</MudText>
                                            <MudText Typo="Typo.caption">avg @FormatMetricNumber(metric.Average) ms, max @FormatMetricNumber(metric.Max) ms</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Feature Overview</MudText>

                @if (loading && this.featureRows.Count == 0)
                {
                    <div class="pa-2">
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                    </div>
                }
                else if (this.featureRows.Count == 0)
                {
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">
                        No feature overview data is available.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@this.featureRows" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Feature</MudTh>
                            <MudTh>Success</MudTh>
                            <MudTh>Failure</MudTh>
                            <MudTh>Current</MudTh>
                            <MudTh>Top Throughput</MudTh>
                            <MudTh>Top Current</MudTh>
                            <MudTh>Slowest Series</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="feature">
                            <MudTd DataLabel="Feature">@feature.Name</MudTd>
                            <MudTd DataLabel="Success">@DisplayCount(feature.SuccessTotal)</MudTd>
                            <MudTd DataLabel="Failure">
                                <MudText Color="@(feature.FailureTotal > 0 ? Color.Error : Color.Inherit)">@DisplayCount(feature.FailureTotal)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Current">
                                <MudText Color="@(feature.CurrentTotal > 0 ? Color.Info : Color.Inherit)">@DisplayCount(feature.CurrentTotal)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Top Throughput">@FormatMetricPair(feature.TopThroughput)</MudTd>
                            <MudTd DataLabel="Top Current">@FormatMetricPair(feature.TopCurrent)</MudTd>
                            <MudTd DataLabel="Slowest Series">@FormatLatencyPair(feature.SlowestSeries)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Metric Explorer</MudText>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="MetricSearch" Label="Search metric series" Clearable="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" Label="Feature" @bind-Value="SelectedFeatureFilter">
                            <MudSelectItem Value="@AllFilterValue">All features</MudSelectItem>
                            @foreach (var feature in this.availableFeatures)
                            {
                                <MudSelectItem Value="@feature">@feature</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" Label="Kind" @bind-Value="SelectedKindFilter">
                            <MudSelectItem Value="@AllFilterValue">All kinds</MudSelectItem>
                            @foreach (var kind in this.availableKinds)
                            {
                                <MudSelectItem Value="@kind">@kind</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ClearAll" OnClick="ClearMetricSelection" Disabled="@(this.selectedMetricNames.Count == 0)">
                            Clear
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudGrid>
                    <MudItem xs="12" lg="6">
                        <MudText Typo="Typo.subtitle1" GutterBottom="true">Available Metrics (@this.filteredAvailableMetrics.Count)</MudText>
                        <MudTable Items="@this.filteredAvailableMetrics" Dense="true" Hover="true" Elevation="0" RowsPerPage="10">
                            <HeaderContent>
                                <MudTh></MudTh>
                                <MudTh>Feature</MudTh>
                                <MudTh>Kind</MudTh>
                                <MudTh>Series</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="metric">
                                <MudTd DataLabel="Selected">
                                    <MudCheckBox T="bool" Value="@this.selectedMetricNames.Contains(metric.Name)" ValueChanged="@((bool value) => ToggleMetric(metric.Name, value))" />
                                </MudTd>
                                <MudTd DataLabel="Feature">@metric.Feature</MudTd>
                                <MudTd DataLabel="Kind">@metric.Kind</MudTd>
                                <MudTd DataLabel="Series">@metric.Name</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <MudText Typo="Typo.subtitle1" GutterBottom="true">Selected Metrics (@this.selectedMetricRows.Count)</MudText>
                        @if (this.selectedMetricRows.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                Select one or more metric series to inspect the current snapshot values.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@this.selectedMetricRows" Dense="true" Hover="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Series</MudTh>
                                    <MudTh>Feature</MudTh>
                                    <MudTh>Kind</MudTh>
                                    <MudTh>Value</MudTh>
                                    <MudTh>Detail</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="metric">
                                    <MudTd DataLabel="Series">@metric.Name</MudTd>
                                    <MudTd DataLabel="Feature">@metric.Feature</MudTd>
                                    <MudTd DataLabel="Kind">@metric.Kind</MudTd>
                                    <MudTd DataLabel="Value">@metric.Value</MudTd>
                                    <MudTd DataLabel="Detail">@metric.Detail</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text=".NET">
            <MudGrid Class="mb-4">
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">CPU</MudText>
                        <MudText Typo="Typo.h4">@FormatMetricNumber(this.dotNetSnapshot.CpuUsagePercent)%</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Working Set</MudText>
                        <MudText Typo="Typo.h6">@FormatMetricNumber(this.dotNetSnapshot.WorkingSetMb) MB</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Managed Heap</MudText>
                        <MudText Typo="Typo.h6">@FormatMetricNumber(this.dotNetSnapshot.HeapSizeMb) MB</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Allocated</MudText>
                        <MudText Typo="Typo.h6">@FormatMetricNumber(this.dotNetSnapshot.TotalAllocatedMb) MB</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Worker Used</MudText>
                        <MudText Typo="Typo.h4">@DisplayCount(this.dotNetSnapshot.WorkerThreadsUsed)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Pending Work</MudText>
                        <MudText Typo="Typo.h4">@DisplayCount(this.dotNetSnapshot.PendingWorkItems)</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4 mb-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Memory & GC</MudText>
                        <table class="mud-table-root w-100">
                            <tbody>
                                <tr><td>Working Set</td><td>@FormatMetricNumber(this.dotNetSnapshot.WorkingSetMb) MB</td></tr>
                                <tr><td>Private Memory</td><td>@FormatMetricNumber(this.dotNetSnapshot.PrivateMemoryMb) MB</td></tr>
                                <tr><td>Managed Memory</td><td>@FormatMetricNumber(this.dotNetSnapshot.ManagedMemoryMb) MB</td></tr>
                                <tr><td>Heap Size</td><td>@FormatMetricNumber(this.dotNetSnapshot.HeapSizeMb) MB</td></tr>
                                <tr><td>Fragmented Memory</td><td>@FormatMetricNumber(this.dotNetSnapshot.FragmentedMemoryMb) MB</td></tr>
                                <tr><td>Total Allocated</td><td>@FormatMetricNumber(this.dotNetSnapshot.TotalAllocatedMb) MB</td></tr>
                                <tr><td>GC Gen0</td><td>@DisplayCount(this.dotNetSnapshot.Gen0Collections)</td></tr>
                                <tr><td>GC Gen1</td><td>@DisplayCount(this.dotNetSnapshot.Gen1Collections)</td></tr>
                                <tr><td>GC Gen2</td><td>@DisplayCount(this.dotNetSnapshot.Gen2Collections)</td></tr>
                            </tbody>
                        </table>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4 mb-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Threads & Runtime</MudText>
                        <table class="mud-table-root w-100">
                            <tbody>
                                <tr><td>Thread Count</td><td>@DisplayCount(this.dotNetSnapshot.ThreadCount)</td></tr>
                                <tr><td>Worker Threads Used</td><td>@DisplayCount(this.dotNetSnapshot.WorkerThreadsUsed)</td></tr>
                                <tr><td>Worker Threads Available</td><td>@DisplayCount(this.dotNetSnapshot.WorkerThreadsAvailable)</td></tr>
                                <tr><td>IO Threads Used</td><td>@DisplayCount(this.dotNetSnapshot.IoThreadsUsed)</td></tr>
                                <tr><td>IO Threads Available</td><td>@DisplayCount(this.dotNetSnapshot.IoThreadsAvailable)</td></tr>
                                <tr><td>Pending Work Items</td><td>@DisplayCount(this.dotNetSnapshot.PendingWorkItems)</td></tr>
                                <tr><td>Process Uptime</td><td>@FormatUptime(this.dotNetSnapshot.UptimeSeconds)</td></tr>
                                <tr><td>Captured</td><td>@FormatTimestamp(this.dotNetSnapshot.CapturedAtUtc)</td></tr>
                            </tbody>
                        </table>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="ASP.NET">
            <MudGrid Class="mb-4">
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Requests</MudText>
                        <MudText Typo="Typo.h4">@DisplayCount(this.aspNetSnapshot.TotalRequests)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Active</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Info">@DisplayCount(this.aspNetSnapshot.ActiveRequests)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Failures</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Error">@DisplayCount(this.aspNetSnapshot.FailedRequests)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Avg Latency</MudText>
                        <MudText Typo="Typo.h6">@FormatMetricNumber(this.aspNetSnapshot.AverageLatencyMs) ms</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Req/Minute</MudText>
                        <MudText Typo="Typo.h6">@FormatMetricNumber(this.aspNetSnapshot.RequestsPerMinute)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.caption">Routes</MudText>
                        <MudText Typo="Typo.h4">@DisplayCount(this.aspNetRoutesSnapshot.TrackedRouteCount)</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4 mb-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">HTTP Status Classes</MudText>
                        <table class="mud-table-root w-100">
                            <tbody>
                                <tr><td>1xx Informational</td><td>@DisplayCount(this.aspNetSnapshot.Status1xx)</td></tr>
                                <tr><td>2xx Success</td><td>@DisplayCount(this.aspNetSnapshot.Status2xx)</td></tr>
                                <tr><td>3xx Redirect</td><td>@DisplayCount(this.aspNetSnapshot.Status3xx)</td></tr>
                                <tr><td>4xx Client Error</td><td>@DisplayCount(this.aspNetSnapshot.Status4xx)</td></tr>
                                <tr><td>5xx Server Error</td><td><MudText Color="Color.Error">@DisplayCount(this.aspNetSnapshot.Status5xx)</MudText></td></tr>
                            </tbody>
                        </table>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4 mb-4 metric-panel-fill">
                        <MudText Typo="Typo.h6" GutterBottom="true">Request Health</MudText>
                        <table class="mud-table-root w-100">
                            <tbody>
                                <tr><td>Failure Rate</td><td>@FormatMetricNumber(this.aspNetSnapshot.FailureRatePercent)%</td></tr>
                                <tr><td>Total Latency</td><td>@DisplayCount(this.aspNetSnapshot.TotalLatencyMs) ms</td></tr>
                                <tr><td>Max Active</td><td>@DisplayCount(this.aspNetSnapshot.MaxObservedConcurrentRequests)</td></tr>
                                <tr><td>Process Uptime</td><td>@FormatUptime(this.aspNetSnapshot.UptimeSeconds)</td></tr>
                                <tr><td>Last Request</td><td>@FormatTimestamp(this.aspNetSnapshot.LastRequestAtUtc)</td></tr>
                                <tr><td>Captured</td><td>@FormatTimestamp(this.aspNetSnapshot.CapturedAtUtc)</td></tr>
                            </tbody>
                        </table>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Per Route</MudText>

                @if (this.aspNetRoutesSnapshot.Routes.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        No route metrics have been captured yet.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@this.aspNetRoutesSnapshot.Routes" Dense="true" Hover="true" Elevation="0" RowsPerPage="10">
                        <HeaderContent>
                            <MudTh>Method</MudTh>
                            <MudTh>Route</MudTh>
                            <MudTh>Count</MudTh>
                            <MudTh>1xx</MudTh>
                            <MudTh>2xx</MudTh>
                            <MudTh>3xx</MudTh>
                            <MudTh>4xx</MudTh>
                            <MudTh>5xx</MudTh>
                            <MudTh>Failure Rate</MudTh>
                            <MudTh>Total Latency</MudTh>
                            <MudTh>Avg Latency</MudTh>
                            <MudTh>Last Request</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="route">
                            <MudTd DataLabel="Method">@route.Method</MudTd>
                            <MudTd DataLabel="Route"><code>@route.Route</code></MudTd>
                            <MudTd DataLabel="Count">@DisplayCount(route.RequestCount)</MudTd>
                            <MudTd DataLabel="1xx">@DisplayCount(route.Status1xx)</MudTd>
                            <MudTd DataLabel="2xx">@DisplayCount(route.Status2xx)</MudTd>
                            <MudTd DataLabel="3xx">@DisplayCount(route.Status3xx)</MudTd>
                            <MudTd DataLabel="4xx">@DisplayCount(route.Status4xx)</MudTd>
                            <MudTd DataLabel="5xx">
                                <MudText Color="@(route.Status5xx > 0 ? Color.Error : Color.Inherit)">@DisplayCount(route.Status5xx)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Failure Rate">
                                <MudText Color="@(route.FailureRatePercent > 0 ? Color.Error : Color.Inherit)">@FormatMetricNumber(route.FailureRatePercent)%</MudText>
                            </MudTd>
                            <MudTd DataLabel="Total Latency">@DisplayCount(route.TotalLatencyMs) ms</MudTd>
                            <MudTd DataLabel="Avg Latency">@FormatMetricNumber(route.AverageLatencyMs) ms</MudTd>
                            <MudTd DataLabel="Last Request">@FormatTimestamp(route.LastRequestAtUtc)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private const string AllFilterValue = "__all";

    private readonly HashSet<string> selectedMetricNames = new(StringComparer.Ordinal);
    private readonly List<FeatureRowModel> featureRows = [];
    private readonly List<MetricDescriptorViewModel> filteredAvailableMetrics = [];
    private readonly List<SelectedMetricRowModel> selectedMetricRows = [];
    private readonly List<string> availableFeatures = [];
    private readonly List<string> availableKinds = [];

    private MetricsOverviewSnapshotViewModel overview = new();
    private BdkMetricsSnapshotViewModel appSnapshot = new();
    private DotNetMetricsSnapshotViewModel dotNetSnapshot = new();
    private AspNetMetricsSnapshotViewModel aspNetSnapshot = new();
    private AspNetRouteMetricsSnapshotViewModel aspNetRoutesSnapshot = new();
    private bool loading;
    private string loadError;
    private string metricSearch;
    private string selectedFeatureFilter = AllFilterValue;
    private string selectedKindFilter = AllFilterValue;
    private int? autoRefreshIntervalSeconds = 5;
    private PeriodicTimer autoRefreshTimer;
    private CancellationTokenSource autoRefreshCancellation;
    private bool isDisposed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await this.JS.InvokeAsync<string>("localStorage.getItem", "dofiesta:metrics:autoRefreshInterval");
            if (!string.IsNullOrWhiteSpace(saved) && int.TryParse(saved, out var parsed) && parsed >= 0)
            {
                this.autoRefreshIntervalSeconds = parsed == 0 ? null : parsed;
            }
        }
        catch
        {
        }

        this.StartAutoRefresh();
        await this.LoadAsync();
    }

    public ValueTask DisposeAsync()
    {
        this.isDisposed = true;
        this.StopAutoRefresh();

        return ValueTask.CompletedTask;
    }

    private Task ReloadAsync()
    {
        return this.LoadAsync();
    }

    private string MetricSearch
    {
        get => this.metricSearch;
        set
        {
            if (string.Equals(this.metricSearch, value, StringComparison.Ordinal))
            {
                return;
            }

            this.metricSearch = value;
            this.RebuildViewModels();
        }
    }

