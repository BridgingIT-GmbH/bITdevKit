    private async Task LoadAsync()
    {
        this.loading = true;
        this.loadError = null;

        try
        {
            var instancesTask = this.LoadInstancesAsync();
            var metricsTask = this.LoadMetricsAsync();

            await Task.WhenAll(instancesTask, metricsTask);

            this.metrics = metricsTask.Result ?? new GenModels.OrchestrationMetricsModel();

            this.instances.Clear();
            this.instances.AddRange(instancesTask.Result ?? []);

            if (this.selectedInstance is not null)
            {
                var selectedId = this.selectedInstance.InstanceId;
                var refreshed = selectedId.HasValue ? this.instances.FirstOrDefault(i => i.InstanceId == selectedId) : null;
                if (refreshed is null)
                {
                    this.ClearSelection();
                }
                else
                {
                    await this.LoadDetailsAsync(refreshed.InstanceId.GetValueOrDefault());
                }
            }
        }
        catch (KiotaApiException ex)
        {
            this.loadError = ex.Message;
            this.ShowError("Failed to load orchestration data", ex);
        }
        catch (Exception ex)
        {
            this.loadError = ex.Message;
            this.ShowError("Failed to load orchestration data", ex);
        }
        finally
        {
            this.loading = false;
            await this.InvokeSafeStateHasChangedAsync();
        }
    }

