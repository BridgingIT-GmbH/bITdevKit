            var timersTask = this.Api.Api._system.Orchestrations[instanceId].Timers.GetAsync();

            await Task.WhenAll(detailTask, contextTask, historyTask, signalsTask, timersTask);

            this.selectedInstance = detailTask.Result;
            this.selectedContext = contextTask.Result;

            this.selectedHistory.Clear();
            this.selectedHistory.AddRange(historyTask.Result ?? []);

            this.selectedSignals.Clear();
            this.selectedSignals.AddRange(signalsTask.Result ?? []);

            this.selectedTimers.Clear();
            this.selectedTimers.AddRange(timersTask.Result ?? []);

            if (this.selectedInstance is not null)
            {
                this.signalName ??= this.selectedInstance.Status?.Equals("Waiting", StringComparison.OrdinalIgnoreCase) == true
                    ? "TodoUpdated"
                    : string.Empty;

                await this.LoadDiagramAsync(instanceId, this.selectedInstance.OrchestrationName);
            }
        }
        catch (Exception ex)
