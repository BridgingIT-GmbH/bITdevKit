    private async Task LoadDiagramAsync(Guid instanceId, string orchestrationName)
    {
        this.diagramLoading = true;
        this.diagramLoadError = null;
        this.selectedInstanceDiagram = null;
        this.selectedInstanceDiagramSvg = null;

        try
        {
            var instanceTask = this.TryGetDiagramAsync(
                () => this.Api.Api._system.Orchestrations[instanceId].Diagram.GetAsync(),
                "Instance Mermaid diagram");
            var instanceSvgTask = this.TryGetDiagramAsync(
                () => this.TryReadDiagramStreamAsync(() => this.Api.Api._system.Orchestrations[instanceId].Diagram.Svg.GetAsync()),
                "Instance SVG diagram");

            await Task.WhenAll(instanceTask, instanceSvgTask);

            var instanceResult = await instanceTask;
            var instanceSvgResult = await instanceSvgTask;

            this.selectedInstanceDiagram = instanceResult.Text;
            this.selectedInstanceDiagramSvg = instanceSvgResult.Text;

            var errors = new[] { instanceResult.Error, instanceSvgResult.Error }
                .Where(error => !string.IsNullOrWhiteSpace(error))
                .ToArray();

            this.diagramLoadError = errors.Length == 0 ? null : string.Join(Environment.NewLine, errors);
        }
        finally
        {
            this.diagramLoading = false;
        }
    }

    private async Task<(string Text, string Error)> TryGetDiagramAsync(Func<Task<string>> action, string label)
    {
        try
        {
            return (await action(), null);
        }
        catch (Exception ex)
        {
            return (null, $"{label}: {ex.Message}");
        }
    }

    private async Task<string> TryReadDiagramStreamAsync(Func<Task<global::System.IO.Stream>> action)
    {
        await using var stream = await action();
        if (stream is null)
        {
            return null;
        }

        using var reader = new global::System.IO.StreamReader(stream);
        return await reader.ReadToEndAsync();
    }

    private string BuildOrchestrationsUrl()
    {
        var query = this.ToQueryString(this.BuildQueryParameters());
        return string.IsNullOrWhiteSpace(query) ? "/_bdk/api/orchestrations" : $"/_bdk/api/orchestrations?{query}";
    }

    private string BuildMetricsUrl()
    {
        var query = this.ToQueryString(this.BuildQueryParameters(includePaging: false, includeCorrelation: false, includeSorting: false));
        return string.IsNullOrWhiteSpace(query) ? "/_bdk/api/orchestrations/metrics" : $"/_bdk/api/orchestrations/metrics?{query}";
    }

    private string BuildAbsoluteUrl(string relativeUrl)
    {
        return new Uri(new Uri(this.Navigation.BaseUri), relativeUrl.TrimStart('/')).ToString();
    }

    private string ToQueryString(Dictionary<string, object> queryParameters)
    {
        return string.Join("&", queryParameters.Select(pair => $"{Uri.EscapeDataString(pair.Key)}={Uri.EscapeDataString(pair.Value?.ToString() ?? string.Empty)}"));
    }

    private Dictionary<string, object> BuildQueryParameters(bool includePaging = true, bool includeCorrelation = true, bool includeSorting = true)
    {
        var query = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);

        this.AddQuery(query, "orchestrationName", this.orchestrationNameFilter);
        this.AddQuery(query, "states", this.stateFilter);

        if (!string.Equals(this.statusFilter, AllFilterValue, StringComparison.Ordinal))
        {
            this.AddQuery(query, "statuses", this.statusFilter);
        }

        if (includeCorrelation)
        {
            this.AddQuery(query, "correlationId", this.correlationIdFilter);
            this.AddQuery(query, "concurrencyKey", this.concurrencyKeyFilter);
        }

        this.AddQuery(query, "startedFrom", this.ToStartDateOffset(this.startedFromFilter)?.ToString("O"));
        this.AddQuery(query, "startedTo", this.ToEndDateOffset(this.startedToFilter)?.ToString("O"));
        this.AddQuery(query, "completedFrom", this.ToStartDateOffset(this.completedFromFilter)?.ToString("O"));
        this.AddQuery(query, "completedTo", this.ToEndDateOffset(this.completedToFilter)?.ToString("O"));

        if (includePaging)
        {
            query["take"] = this.take;
            query["skip"] = 0;
        }

        if (includeSorting)
        {
            this.AddQuery(query, "sortBy", this.sortBy);
            query["sortDescending"] = this.sortDescending;
        }

        return query;
    }

    private void AddQuery(Dictionary<string, object> query, string name, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        query[name] = value;
    }

    private DateTimeOffset? ToStartDateOffset(DateTime? value)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var local = DateTime.SpecifyKind(value.Value.Date, DateTimeKind.Local);
        return new DateTimeOffset(local);
    }

    private DateTimeOffset? ToEndDateOffset(DateTime? value)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var local = DateTime.SpecifyKind(value.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Local);
        return new DateTimeOffset(local);
    }

    private GenModels.OrchestrationSignalRequest.OrchestrationSignalRequest_payload CreateSignalPayload(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return null;
        }

        using var document = JsonDocument.Parse(json);
        if (document.RootElement.ValueKind != JsonValueKind.Object)
        {
            throw new JsonException("The signal payload must be a JSON object when sent through the Kiota client.");
        }

        return new GenModels.OrchestrationSignalRequest.OrchestrationSignalRequest_payload
        {
            OrchestrationSignalRequestPayloadMember1 = new GenModels.OrchestrationSignalRequest_payloadMember1
            {
                AdditionalData = this.ConvertJsonObjectToAdditionalData(document.RootElement),
            },
        };
    }

    private Dictionary<string, object> ConvertJsonObjectToAdditionalData(System.Text.Json.JsonElement element)
    {
        return element.EnumerateObject().ToDictionary(
            property => property.Name,
            property => this.ConvertJsonElementToObject(property.Value));
    }

    private object ConvertJsonElementToObject(System.Text.Json.JsonElement element)
    {
        return element.ValueKind switch
        {
            JsonValueKind.Object => this.ConvertJsonObjectToAdditionalData(element),
            JsonValueKind.Array => element.EnumerateArray().Select(this.ConvertJsonElementToObject).ToList(),
            JsonValueKind.String => element.GetString(),
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            JsonValueKind.Null => null,
            JsonValueKind.Number when element.TryGetInt32(out var intValue) => intValue,
            JsonValueKind.Number when element.TryGetInt64(out var longValue) => longValue,
            JsonValueKind.Number when element.TryGetDecimal(out var decimalValue) => decimalValue,
            JsonValueKind.Number => element.GetDouble(),
            _ => element.GetRawText(),
        };
    }

