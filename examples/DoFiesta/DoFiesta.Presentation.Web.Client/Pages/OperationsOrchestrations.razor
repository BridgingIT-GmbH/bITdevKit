            && !string.Equals(instance.Status, "Paused", StringComparison.OrdinalIgnoreCase);
    }

    private bool CanResume(GenModels.OrchestrationInstanceModel instance)
    {
        return string.Equals(instance?.Status, "Paused", StringComparison.OrdinalIgnoreCase);
    }

    private bool CanStop(GenModels.OrchestrationInstanceModel instance)
