        return instance is not null && !this.IsTerminal(instance.Status);
    }

    private bool CanArchive(GenModels.OrchestrationInstanceModel instance)
    {
        return instance is not null && this.IsTerminal(instance.Status);
    }

    private bool IsTerminal(string status)
    {
        return string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Failed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Cancelled", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Terminated", StringComparison.OrdinalIgnoreCase);
    }

    private Color GetStatusColor(string status)
    {
        if (string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Info;
        }

        if (string.Equals(status, "Waiting", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Warning;
        }

        if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Success;
        }

        if (string.Equals(status, "Failed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Cancelled", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Terminated", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Error;
        }

        return Color.Default;
    }

    private string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private string TrimValue(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return this.DisplayValue(value);
        }

        return value[..maxLength] + "...";
    }

    private string FormatTimestamp(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "-";
    }

    private string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue ? value.Value.LocalDateTime.ToString("g") : "-";
    }

    private string FormatRelativeTimestamp(DateTimeOffset? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        var span = DateTimeOffset.UtcNow - value.Value.ToUniversalTime();
        if (span.TotalMinutes < 1)
        {
            return "just now";
        }

        if (span.TotalHours < 1)
        {
            return $"{Math.Max(1, (int)span.TotalMinutes)} min ago";
        }

        if (span.TotalDays < 1)
        {
            return $"{Math.Max(1, (int)span.TotalHours)} h ago";
        }

        return $"{Math.Max(1, (int)span.TotalDays)} d ago";
    }

    private string PrettyPrintJson(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return "-";
        }

        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private void StartAutoRefresh()
    {
        this.StopAutoRefresh();

        if (!this.autoRefreshIntervalSeconds.HasValue || this.autoRefreshIntervalSeconds.Value <= 0)
        {
            return;
        }

        this.autoRefreshCancellation = new CancellationTokenSource();
        this.autoRefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(this.autoRefreshIntervalSeconds.Value));
        _ = this.RunAutoRefreshAsync(this.autoRefreshTimer, this.autoRefreshCancellation.Token);
    }

    private void StopAutoRefresh()
    {
        if (this.autoRefreshCancellation is not null)
        {
            this.autoRefreshCancellation.Cancel();
            this.autoRefreshCancellation.Dispose();
            this.autoRefreshCancellation = null;
        }

        this.autoRefreshTimer?.Dispose();
        this.autoRefreshTimer = null;
    }

    private async Task RunAutoRefreshAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (!this.loading && !this.detailsLoading)
                {
                    await this.LoadAsync();
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private Task InvokeSafeStateHasChangedAsync()
    {
        return this.isDisposed ? Task.CompletedTask : this.InvokeAsync(this.StateHasChanged);
    }

