    private bool? GetArchiveFilter()
    {
        return this.archiveFilter switch
        {
            ArchiveActiveValue => false,
            ArchiveArchivedValue => true,
            _ => null,
        };
    }

    private static bool CanRetryMessage(GenModels.QueueMessageInfo message)
    {
        return message?.Status is GenModels.QueueMessageStatus.Failed or GenModels.QueueMessageStatus.DeadLettered or GenModels.QueueMessageStatus.Expired or GenModels.QueueMessageStatus.WaitingForHandler;
    }

    private static bool CanArchiveMessage(GenModels.QueueMessageInfo message)
    {
        return message is not null && message.IsArchived != true && (message.Status is GenModels.QueueMessageStatus.Succeeded or GenModels.QueueMessageStatus.DeadLettered or GenModels.QueueMessageStatus.Expired);
    }

    private static List<KeyValuePair<string, object>> GetProperties(GenModels.QueueMessageInfo message)
    {
        return message?.Properties?.AdditionalData?.ToList() ?? [];
    }

    private static string DisplayCount(int? value) => value?.ToString() ?? "-";

    private static string FormatTimestamp(DateTimeOffset? value) => value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "-";

    private static string FormatRelativeTimestamp(DateTimeOffset? value) => value?.ToLocalTime().Humanize() ?? "-";

    private static string DisplayValue(string value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetStatusLabel(GenModels.QueueMessageStatus? status) => status?.Humanize() ?? "Unknown";

    private static string TrimValue(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return DisplayValue(value);
        }

        return value[..maxLength] + "...";
    }

    private static string TrimValueFromStart(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return DisplayValue(value);
        }

        return "..." + value[^maxLength..];
    }

    private static Color GetStatusColor(GenModels.QueueMessageStatus? status)
    {
        return status switch
        {
            GenModels.QueueMessageStatus.Pending => Color.Info,
            GenModels.QueueMessageStatus.WaitingForHandler => Color.Warning,
            GenModels.QueueMessageStatus.Processing => Color.Warning,
            GenModels.QueueMessageStatus.Succeeded => Color.Success,
            GenModels.QueueMessageStatus.Failed => Color.Error,
            GenModels.QueueMessageStatus.DeadLettered => Color.Error,
            GenModels.QueueMessageStatus.Expired => Color.Default,
            _ => Color.Default,
        };
    }

    private void StartAutoRefresh()
    {
        this.StopAutoRefresh();

        if (!this.autoRefreshIntervalSeconds.HasValue || this.autoRefreshIntervalSeconds.Value <= 0)
        {
            return;
        }

        this.autoRefreshCancellation = new CancellationTokenSource();
        this.autoRefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(this.autoRefreshIntervalSeconds.Value));
        _ = this.RunAutoRefreshAsync(this.autoRefreshTimer, this.autoRefreshCancellation.Token);
    }

    private void StopAutoRefresh()
    {
        if (this.autoRefreshCancellation is not null)
        {
            this.autoRefreshCancellation.Cancel();
            this.autoRefreshCancellation.Dispose();
            this.autoRefreshCancellation = null;
        }

        this.autoRefreshTimer?.Dispose();
        this.autoRefreshTimer = null;
    }

    private async Task RunAutoRefreshAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (this.isDisposed || this.loading)
                {
                    continue;
                }

                await this.InvokeAsync(this.ReloadAsync);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }
