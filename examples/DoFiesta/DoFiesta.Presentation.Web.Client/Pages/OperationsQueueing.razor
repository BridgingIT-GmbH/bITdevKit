    private async Task ReloadSelectionAsync(Guid? selectedId)
    {
        await this.LoadAsync();

        if (selectedId.HasValue && this.detailsDialogVisible)
        {
            await this.OpenDetailsAsync(selectedId.Value);
        }

        if (selectedId.HasValue && this.contentDialogVisible)
        {
            await this.OpenContentAsync(selectedId.Value);
        }
    }

