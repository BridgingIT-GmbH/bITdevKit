@page "/operations/queueing"
@using BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen
@using GenModels = BridgingIT.DevKit.Examples.DoFiesta.Presentation.Gen.Models
@using Microsoft.AspNetCore.Authorization
@using KiotaApiException = Microsoft.Kiota.Abstractions.ApiException
@inject BackendApiClient Api
@inject ISnackbar Snackbar
@implements IAsyncDisposable
@attribute [Authorize]

<PageTitle>DoFiesta - Operations Queueing</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-6">
    <MudPaper Class="pa-6 mb-4">
        <div class="d-flex flex-wrap align-center gap-4">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Queueing</MudText>
                <MudText Typo="Typo.body2">Inspect retained queue messages, operate queue flow controls, and observe the DoFiesta echo queue demo.</MudText>
            </div>
            <MudSpacer />
            <MudSelect T="int?" Label="Auto refresh" Variant="Variant.Outlined" Margin="Margin.Dense" Value="autoRefreshIntervalSeconds" ValueChanged="OnAutoRefreshIntervalChanged" Style="min-width: 170px;">
                <MudSelectItem T="int?" Value="@((int?)null)">Off</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)15)">15 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)30)">30 sec</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)60)">60 sec</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" Disabled="@loading">
                Refresh
            </MudButton>
        </div>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        Creating, updating, or deleting a todo item enqueues a <strong>TodoItemEchoQueueMessage</strong>. Use that flow to generate queue traffic for this dashboard.
    </MudAlert>

    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Total</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(stats?.Total)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Pending</MudText>
                <MudText Typo="Typo.h4" Color="Color.Info">@DisplayCount(stats?.Pending)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Waiting</MudText>
                <MudText Typo="Typo.h4" Color="Color.Warning">@DisplayCount(stats?.WaitingForHandler)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Succeeded</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@DisplayCount(stats?.Succeeded)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Failed</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@DisplayCount(stats?.Failed)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.caption">Archived</MudText>
                <MudText Typo="Typo.h4">@DisplayCount(stats?.Archived)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="2">
                <MudSelect T="string" Label="Status" @bind-Value="statusFilter">
                    <MudSelectItem Value="@AllStatusesValue">All statuses</MudSelectItem>
                    @foreach (var status in FilterStatuses)
                    {
                        <MudSelectItem Value="@status.ToString()">@status.Humanize()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string" Label="Archive scope" @bind-Value="archiveFilter">
                    <MudSelectItem Value="@ArchiveActiveValue">Active only</MudSelectItem>
                    <MudSelectItem Value="@ArchiveArchivedValue">Archived only</MudSelectItem>
                    <MudSelectItem Value="@ArchiveAllValue">Active and archived</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int" Label="Rows" @bind-Value="take">
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                    <MudSelectItem Value="250">250</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="queueFilter" Label="Queue contains" Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="typeFilter" Label="Type contains" Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField @bind-Value="messageIdFilter" Label="Message Id" Clearable="true" />
            </MudItem>
        </MudGrid>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="ReloadAsync" Disabled="@loading">
                Apply
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ResetFiltersAsync" Disabled="@loading">
                Reset
            </MudButton>
        </div>
    </MudPaper>

    <MudGrid Class="mb-4">
        <MudItem xs="12" lg="8">
            <MudPaper Class="pa-2">
                @if (!string.IsNullOrWhiteSpace(loadError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="ma-2">@loadError</MudAlert>
                }
                else if (loading && messages.Count == 0)
                {
                    <div class="pa-4">
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                        <MudSkeleton Height="72px" Animation="Animation.Pulse" Class="mt-2" />
                    </div>
                }
                else if (messages.Count == 0)
                {
                    <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Class="ma-2">
                        No queue messages matched the current filters.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@messages" Dense="true" Hover="true" Loading="@loading" LoadingProgressColor="Color.Info" Elevation="0">
                        <HeaderContent>
                            <MudTh>Status</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh>Queue</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Message Id</MudTh>
                            <MudTh>Attempts</MudTh>
                            <MudTh>Lease</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="message">
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Color="@GetStatusColor(message.Status)" Variant="Variant.Filled" Size="Size.Small">
                                    @GetStatusLabel(message.Status)
                                </MudChip>
                                @if (message.IsArchived == true)
                                {
                                    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Class="ml-2">
                                        Archived
                                    </MudChip>
                                }
                            </MudTd>
                            <MudTd DataLabel="Created">
                                <MudTooltip Text="@FormatTimestamp(message.CreatedDate)">
                                    <MudText Typo="Typo.body2">@FormatRelativeTimestamp(message.CreatedDate)</MudText>
                                </MudTooltip>
                            </MudTd>
                            <MudTd DataLabel="Queue">@DisplayValue(message.QueueName)</MudTd>
                            <MudTd DataLabel="Type">@TrimValue(message.Type, 40)</MudTd>
                            <MudTd DataLabel="Message Id">@TrimValueFromStart(message.MessageId, 24)</MudTd>
                            <MudTd DataLabel="Attempts">@DisplayCount(message.AttemptCount)</MudTd>
                            <MudTd DataLabel="Lease">
                                @if (!string.IsNullOrWhiteSpace(message.LockedBy))
                                {
                                    <MudTooltip Text="@($"{message.LockedBy} until {FormatTimestamp(message.LockedUntil)}")">
                                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Leased</MudChip>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">-</MudText>
                                }
                            </MudTd>
                            <MudTd>
                                <div class="d-flex justify-end gap-1">
                                    <MudTooltip Text="Open details">
                                        <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" Disabled="@(!message.Id.HasValue)" OnClick="@(() => OpenDetailsAsync(message.Id.GetValueOrDefault()))" />
                                    </MudTooltip>
                                    <MudTooltip Text="View content">
                                        <MudIconButton Icon="@Icons.Material.Filled.Article" Color="Color.Secondary" Size="Size.Small" Disabled="@(!message.Id.HasValue)" OnClick="@(() => OpenContentAsync(message.Id.GetValueOrDefault()))" />
                                    </MudTooltip>
                                    @if (CanRetryMessage(message) && message.Id.HasValue)
                                    {
                                        <MudTooltip Text="Retry message">
                                            <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Color="Color.Warning" Size="Size.Small" OnClick="@(() => RetryMessageAsync(message.Id.GetValueOrDefault()))" />
                                        </MudTooltip>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(message.LockedBy) && message.Id.HasValue)
                                    {
                                        <MudTooltip Text="Release lease">
                                            <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Warning" Size="Size.Small" OnClick="@(() => ReleaseLeaseAsync(message.Id.GetValueOrDefault()))" />
                                        </MudTooltip>
                                    }
                                    @if (CanArchiveMessage(message) && message.Id.HasValue)
                                    {
                                        <MudTooltip Text="Archive message">
                                            <MudIconButton Icon="@Icons.Material.Filled.Archive" Color="Color.Default" Size="Size.Small" OnClick="@(() => ArchiveMessageAsync(message.Id.GetValueOrDefault()))" />
                                        </MudTooltip>
                                    }
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Subscriptions</MudText>
                @if (subscriptions.Count == 0)
                {
                    <MudText Typo="Typo.body2">No queue subscriptions are registered.</MudText>
                }
                else
                {
                    @foreach (var subscription in subscriptions)
                    {
                        <MudPaper Class="pa-3 mb-2" Outlined="true">
                            <MudText Typo="Typo.subtitle2">@subscription.MessageType</MudText>
                            <MudText Typo="Typo.body2">Queue: @DisplayValue(subscription.QueueName)</MudText>
                            <MudText Typo="Typo.body2">Handler: @TrimValue(subscription.HandlerType, 48)</MudText>
                            <div class="d-flex flex-wrap gap-1 mt-2">
                                @if (subscription.IsQueuePaused == true)
                                {
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Queue paused</MudChip>
                                }
                                @if (subscription.IsMessageTypePaused == true)
                                {
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Type paused</MudChip>
                                }
                            </div>
                        </MudPaper>
                    }
                }
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Flow Controls</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">Paused queues and types are reflected from the live queue stats.</MudText>

                <MudText Typo="Typo.subtitle2">Paused queues</MudText>
                <div class="d-flex flex-wrap gap-1 mb-3 mt-1">
                    @if (stats?.PausedQueues?.Count > 0)
                    {
                        @foreach (var queue in stats.PausedQueues)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@queue</MudChip>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">None</MudText>
                    }
                </div>

                <MudText Typo="Typo.subtitle2">Paused types</MudText>
                <div class="d-flex flex-wrap gap-1 mt-1">
                    @if (stats?.PausedTypes?.Count > 0)
                    {
                        @foreach (var type in stats.PausedTypes)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@type</MudChip>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">None</MudText>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<MudDialog @bind-Visible="detailsDialogVisible" Options="new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Large }">
    <TitleContent>
        <MudText Typo="Typo.h6">Queue Message Details</MudText>
    </TitleContent>
    <DialogContent>
        @if (detailsLoading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Info" />
        }
        else if (selectedMessage is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No queue message details are loaded.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Overview</MudText>
                        <MudText><strong>Status:</strong> @GetStatusLabel(selectedMessage.Status)</MudText>
                        <MudText><strong>Queue:</strong> @DisplayValue(selectedMessage.QueueName)</MudText>
                        <MudText><strong>Type:</strong> @DisplayValue(selectedMessage.Type)</MudText>
                        <MudText><strong>Message Id:</strong> @DisplayValue(selectedMessage.MessageId)</MudText>
                        <MudText><strong>Created:</strong> @FormatTimestamp(selectedMessage.CreatedDate)</MudText>
                        <MudText><strong>Processed:</strong> @FormatTimestamp(selectedMessage.ProcessedDate)</MudText>
                        <MudText><strong>Expires:</strong> @FormatTimestamp(selectedMessage.ExpiresOn)</MudText>
                        <MudText><strong>Locked Until:</strong> @FormatTimestamp(selectedMessage.LockedUntil)</MudText>
                        <MudText><strong>Locked By:</strong> @DisplayValue(selectedMessage.LockedBy)</MudText>
                        <MudText><strong>Archived:</strong> @(selectedMessage.IsArchived == true ? "Yes" : "No")</MudText>
                        <MudText><strong>Archived At:</strong> @FormatTimestamp(selectedMessage.ArchivedDate)</MudText>
                        <MudText><strong>Registered Handler:</strong> @DisplayValue(selectedMessage.RegisteredHandlerType)</MudText>
                    </MudPaper>

                    @if (!string.IsNullOrWhiteSpace(selectedMessage.LastError))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@selectedMessage.LastError</MudAlert>
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Actions</MudText>
                        <div class="d-flex flex-column gap-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Article" OnClick="OpenSelectedContentAsync">
                                View Content
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.RestartAlt" Disabled="@(!CanRetryMessage(selectedMessage) || !selectedMessage.Id.HasValue)" OnClick="@(() => RetryMessageAsync(selectedMessage.Id.GetValueOrDefault()))">
                                Retry Message
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Archive" Disabled="@(!CanArchiveMessage(selectedMessage) || !selectedMessage.Id.HasValue)" OnClick="@(() => ArchiveMessageAsync(selectedMessage.Id.GetValueOrDefault()))">
                                Archive Message
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.LockOpen" Disabled="@(string.IsNullOrWhiteSpace(selectedMessage.LockedBy) || !selectedMessage.Id.HasValue)" OnClick="@(() => ReleaseLeaseAsync(selectedMessage.Id.GetValueOrDefault()))">
                                Release Lease
                            </MudButton>
                            <MudDivider Class="my-2" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Pause" OnClick="@(() => PauseQueueAsync(selectedMessage.QueueName))">
                                Pause Queue
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="@(() => ResumeQueueAsync(selectedMessage.QueueName))">
                                Resume Queue
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.PauseCircleOutline" OnClick="@(() => PauseTypeAsync(selectedMessage.Type))">
                                Pause Type
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.PlayCircleOutline" OnClick="@(() => ResumeTypeAsync(selectedMessage.Type))">
                                Resume Type
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Restore" OnClick="@(() => ResetCircuitAsync(selectedMessage.Type))">
                                Reset Circuit
                            </MudButton>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Properties</MudText>
                        @if (GetProperties(selectedMessage).Count > 0)
                        {
                            <MudTable Items="@GetProperties(selectedMessage)" Dense="true" Hover="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Key</MudTh>
                                    <MudTh>Value</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd DataLabel="Key">@item.Key</MudTd>
                                    <MudTd DataLabel="Value">@DisplayValue(item.Value?.ToString())</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">No queue message properties are available.</MudText>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
</MudDialog>

<MudDialog @bind-Visible="contentDialogVisible" Options="new DialogOptions { CloseButton = true, FullWidth = true, MaxWidth = MaxWidth.Large }">
    <TitleContent>
        <MudText Typo="Typo.h6">Queue Message Content</MudText>
    </TitleContent>
    <DialogContent>
        @if (contentLoading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Info" />
        }
        else if (selectedContent is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No queue message content is loaded.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Metadata</MudText>
                        <MudText><strong>Queue:</strong> @DisplayValue(selectedContent.QueueName)</MudText>
                        <MudText><strong>Type:</strong> @DisplayValue(selectedContent.Type)</MudText>
                        <MudText><strong>Message Id:</strong> @DisplayValue(selectedContent.MessageId)</MudText>
                        <MudText><strong>Created:</strong> @FormatTimestamp(selectedContent.CreatedDate)</MudText>
                        <MudText><strong>Content Hash:</strong> @DisplayValue(selectedContent.ContentHash)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.h6" GutterBottom="true">Payload</MudText>
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: Consolas, monospace;">
                            @DisplayValue(selectedContent.Content)
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
</MudDialog>

@code {
    private const string AllStatusesValue = "__all";
    private const string ArchiveActiveValue = "active";
    private const string ArchiveArchivedValue = "archived";
    private const string ArchiveAllValue = "all";

    private static readonly GenModels.QueueMessageStatus[] FilterStatuses =
    [
        GenModels.QueueMessageStatus.Pending,
        GenModels.QueueMessageStatus.WaitingForHandler,
        GenModels.QueueMessageStatus.Processing,
        GenModels.QueueMessageStatus.Succeeded,
        GenModels.QueueMessageStatus.Failed,
        GenModels.QueueMessageStatus.DeadLettered,
        GenModels.QueueMessageStatus.Expired,
    ];

    private readonly List<GenModels.QueueMessageInfo> messages = [];
    private readonly List<GenModels.QueueSubscriptionInfo> subscriptions = [];
    private GenModels.QueueMessageStats stats = new();
    private bool loading;
    private string loadError;
    private string statusFilter = AllStatusesValue;
    private string archiveFilter = ArchiveActiveValue;
    private string queueFilter;
    private string typeFilter;
    private string messageIdFilter;
    private int take = 50;
    private bool detailsDialogVisible;
    private bool detailsLoading;
    private GenModels.QueueMessageInfo selectedMessage;
    private bool contentDialogVisible;
    private bool contentLoading;
    private GenModels.QueueMessageContentInfo selectedContent;
    private int? autoRefreshIntervalSeconds = 30;
    private PeriodicTimer autoRefreshTimer;
    private CancellationTokenSource autoRefreshCancellation;
    private bool isDisposed;

    protected override async Task OnInitializedAsync()
    {
        this.StartAutoRefresh();
        await this.LoadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        this.isDisposed = true;
        this.StopAutoRefresh();
        await Task.CompletedTask;
    }

    private async Task ReloadAsync()
    {
        await this.LoadAsync();
    }

    private Task OnAutoRefreshIntervalChanged(int? value)
    {
        this.autoRefreshIntervalSeconds = value;
        this.StartAutoRefresh();

        return Task.CompletedTask;
    }

    private async Task ResetFiltersAsync()
    {
        this.statusFilter = AllStatusesValue;
        this.archiveFilter = ArchiveActiveValue;
        this.queueFilter = null;
        this.typeFilter = null;
        this.messageIdFilter = null;
        this.take = 50;
        await this.LoadAsync();
    }

    private async Task LoadAsync()
    {
        this.loading = true;
        this.loadError = null;

        try
        {
            var archiveScope = this.GetArchiveFilter();
            this.stats = await Api.Api._system.Queueing.Messages.Stats.GetAsync(config =>
            {
                config.QueryParameters.IsArchived = archiveScope;
            }) ?? new GenModels.QueueMessageStats();

            var loadedMessages = await Api.Api._system.Queueing.Messages.GetAsync(config =>
            {
                config.QueryParameters.IsArchived = archiveScope;
                config.QueryParameters.Take = this.take;

                if (!string.IsNullOrWhiteSpace(this.queueFilter))
                {
                    config.QueryParameters.QueueName = this.queueFilter;
                }

                if (!string.IsNullOrWhiteSpace(this.typeFilter))
                {
                    config.QueryParameters.Type = this.typeFilter;
                }

                if (!string.IsNullOrWhiteSpace(this.messageIdFilter))
                {
                    config.QueryParameters.MessageId = this.messageIdFilter;
                }

                if (Enum.TryParse<GenModels.QueueMessageStatus>(this.statusFilter, true, out var status))
                {
                    config.QueryParameters.StatusAsQueueMessageStatus = status;
                }
            }) ?? [];
            this.messages.Clear();
            this.messages.AddRange(loadedMessages);

            var loadedSubscriptions = await Api.Api._system.Queueing.Subscriptions.GetAsync() ?? [];
            this.subscriptions.Clear();
            this.subscriptions.AddRange(loadedSubscriptions);
        }
        catch (KiotaApiException ex)
        {
            this.loadError = ex.Message;
            Snackbar.Add($"Failed to load queueing data: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            this.loadError = ex.Message;
            Snackbar.Add($"Failed to load queueing data: {ex.Message}", Severity.Error);
        }
        finally
        {
            this.loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenDetailsAsync(Guid id)
    {
        this.detailsDialogVisible = true;
        this.detailsLoading = true;
        this.selectedMessage = null;

        try
        {
            this.selectedMessage = await Api.Api._system.Queueing.Messages[id].GetAsync();
        }
        catch (KiotaApiException ex)
        {
            Snackbar.Add($"Failed to load queue message details: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load queue message details: {ex.Message}", Severity.Error);
        }
        finally
        {
            this.detailsLoading = false;
        }
    }

