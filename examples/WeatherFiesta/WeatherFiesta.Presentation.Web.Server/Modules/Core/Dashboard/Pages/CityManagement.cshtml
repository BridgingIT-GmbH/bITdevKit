@using BridgingIT.DevKit.Presentation.Web.Dashboard
@inherits DashboardPageSlice

@{
    var pagePath = this.Dashboard.Url("city-management");
    var contentPath = this.Dashboard.Url("city-management", "content");
    var suggestionsPath = DashboardPath.Combine(pagePath, "suggestions");
    var addPath = DashboardPath.Combine(pagePath, "add");
}

<div class="d-flex justify-content-between align-items-center py-2 mb-2 border-bottom">
    <div>
        <h4 class="m-0">City Management</h4>
        <div class="text-muted small">Search and add WeatherFiesta cities</div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span id="weatherfiesta-city-management-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <button type="button" id="weatherfiesta-city-management-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh cities">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div class="card mb-2">
    <div class="card-body p-3">
        <form id="weatherfiesta-city-add-form" class="row g-2 align-items-end">
            <div class="col-12 col-lg-5">
                <label for="weatherfiesta-city-search" class="form-label small text-muted mb-1">City</label>
                <input id="weatherfiesta-city-search" name="search" class="form-control form-control-sm" autocomplete="off" placeholder="Search city name" />
            </div>
            <div class="col-6 col-lg-2">
                <label for="weatherfiesta-city-country" class="form-label small text-muted mb-1">Country code</label>
                <input id="weatherfiesta-city-country" name="countryCode" class="form-control form-control-sm text-uppercase" maxlength="2" placeholder="DE" />
            </div>
            <div class="col-6 col-lg-2">
                <button id="weatherfiesta-city-add" class="btn btn-primary btn-sm w-100" type="submit" disabled>
                    <i class="bi bi-plus-lg me-1"></i>Add city
                </button>
            </div>
            <div class="col-12 col-lg-3">
                <div id="weatherfiesta-city-add-status" class="small text-muted"></div>
            </div>
        </form>
        <div id="weatherfiesta-city-suggestions" class="list-group list-group-flush mt-2"></div>
    </div>
</div>

<div id="weatherfiesta-city-management-content">
    <div class="text-muted small py-2">Loading city management content...</div>
</div>

<style>
    #weatherfiesta-city-suggestions .weatherfiesta-city-suggestion-selected {
        background-color: var(--bs-tertiary-bg);
        border-color: var(--bs-border-color);
        border-left-color: var(--dashboard-active-fg);
        color: var(--bs-body-color);
        box-shadow: inset .18rem 0 0 var(--dashboard-active-fg);
    }

    #weatherfiesta-city-suggestions .weatherfiesta-city-suggestion-selected .text-muted {
        color: var(--bs-secondary-color) !important;
    }

    #weatherfiesta-city-suggestions .weatherfiesta-city-suggestion-selected .badge {
        border-color: rgba(var(--bs-primary-rgb), .35);
        color: var(--bs-primary) !important;
    }
</style>

<script>
    (() => {
        window.bdkDashboard.createRefresher({
            contentUrl: '@contentPath',
            contentSelector: '#weatherfiesta-city-management-content',
            statusSelector: '#weatherfiesta-city-management-refresh-status',
            refreshButtonSelector: '#weatherfiesta-city-management-refresh-now'
        }).refresh(true);
    })();
</script>

<script>
    (() => {
        const searchElement = document.getElementById('weatherfiesta-city-search');
        const countryElement = document.getElementById('weatherfiesta-city-country');
        const suggestionsElement = document.getElementById('weatherfiesta-city-suggestions');
        const addButton = document.getElementById('weatherfiesta-city-add');
        const statusElement = document.getElementById('weatherfiesta-city-add-status');
        const formElement = document.getElementById('weatherfiesta-city-add-form');

        let selectedSuggestion = null;
        let searchTimer = null;
        let abortController = null;

        function setStatus(text, isError) {
            statusElement.textContent = text || '';
            statusElement.classList.toggle('text-danger', isError === true);
            statusElement.classList.toggle('text-muted', isError !== true);
        }

        function clearSuggestions() {
            suggestionsElement.innerHTML = '';
            selectedSuggestion = null;
            addButton.disabled = true;
        }

        function renderSuggestions(items) {
            suggestionsElement.innerHTML = '';
            selectedSuggestion = null;
            addButton.disabled = true;

            if (items.length === 0) {
                suggestionsElement.innerHTML = '<div class="text-muted small py-2">No city suggestions found.</div>';
                return;
            }

            for (const item of items) {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2';
                button.innerHTML = `
                    <span>
                        <span class="fw-semibold">${item.name || '-'}</span>
                        <span class="text-muted small ms-1">${item.country || '-'} (${item.countryCode || '-'})</span>
                        <span class="text-muted small d-block">${item.timeZone || '-'} · ${item.latitude}, ${item.longitude}</span>
                    </span>
                    <span class="badge text-bg-secondary">${item.admin1 || 'Select'}</span>`;
                button.addEventListener('click', () => {
                    selectedSuggestion = item;
                    searchElement.value = item.name || '';
                    countryElement.value = item.countryCode || '';
                    addButton.disabled = false;
                    suggestionsElement.querySelectorAll('.weatherfiesta-city-suggestion-selected')
                        .forEach(element => element.classList.remove('weatherfiesta-city-suggestion-selected'));
                    button.classList.add('weatherfiesta-city-suggestion-selected');
                    setStatus(`Selected ${item.name}`, false);
                });
                suggestionsElement.appendChild(button);
            }
        }

        async function searchSuggestions() {
            const search = searchElement.value.trim();
            const countryCode = countryElement.value.trim();
            clearSuggestions();

            if (search.length < 3) {
                setStatus('Type at least 3 characters.', false);
                return;
            }

            if (abortController !== null) {
                abortController.abort();
            }

            abortController = new AbortController();
            const url = new URL('@suggestionsPath', window.location.origin);
            url.searchParams.set('search', search);
            if (countryCode) {
                url.searchParams.set('countryCode', countryCode);
            }

            try {
                setStatus('Searching...', false);
                const response = await fetch(url, {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'fetch' },
                    signal: abortController.signal
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                renderSuggestions(await response.json());
                setStatus('', false);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    setStatus('Suggestion lookup failed.', true);
                }
            } finally {
                abortController = null;
            }
        }

        function scheduleSearch() {
            window.clearTimeout(searchTimer);
            searchTimer = window.setTimeout(searchSuggestions, 350);
        }

        searchElement.addEventListener('input', scheduleSearch);
        countryElement.addEventListener('input', () => {
            countryElement.value = countryElement.value.toUpperCase();
            scheduleSearch();
        });

        formElement.addEventListener('submit', async event => {
            event.preventDefault();
            const name = selectedSuggestion?.name || searchElement.value.trim();
            const countryCode = selectedSuggestion?.countryCode || countryElement.value.trim();
            if (!selectedSuggestion || !name || !countryCode) {
                setStatus('Select a suggestion before adding.', true);
                return;
            }

            addButton.disabled = true;
            try {
                setStatus('Adding city...', false);
                const response = await fetch('@addPath', {
                    method: 'POST',
                    cache: 'no-store',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'fetch'
                    },
                    body: JSON.stringify({
                        name,
                        country: selectedSuggestion.country,
                        countryCode,
                        timeZone: selectedSuggestion.timeZone,
                        latitude: selectedSuggestion.latitude,
                        longitude: selectedSuggestion.longitude,
                        elevation: selectedSuggestion.elevation,
                        externalId: selectedSuggestion.externalId
                    })
                });

                if (!response.ok) {
                    throw new Error(await response.text() || `HTTP ${response.status}`);
                }

                setStatus(`Added ${name}.`, false);
                clearSuggestions();
                window.bdkDashboard.createRefresher({
                    contentUrl: '@contentPath',
                    contentSelector: '#weatherfiesta-city-management-content'
                }).refresh(false);
            } catch (error) {
                setStatus('City could not be added.', true);
                addButton.disabled = false;
            }
        });
    })();
</script>

@functions {
    public override string PageTitle => "City Management";
}
