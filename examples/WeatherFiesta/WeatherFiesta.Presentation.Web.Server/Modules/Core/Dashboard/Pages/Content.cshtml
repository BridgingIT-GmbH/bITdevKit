@using BridgingIT.DevKit.Examples.WeatherFiesta.Application.Modules.Core
@using BridgingIT.DevKit.Examples.WeatherFiesta.Application.Modules.Core.Models
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@inherits RazorSlice

@{
    var citiesModel = await CreateModelAsync();
}

@if (citiesModel.Errors.Count > 0)
{
    <div class="alert alert-danger py-2 mb-2">
        @foreach (var error in citiesModel.Errors)
        {
            <div>@error</div>
        }
    </div>
}

<div class="row g-2 mb-2">
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Cities</div>
                <div class="fs-4 fw-semibold">@citiesModel.Cities.Count</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Subscriptions</div>
                <div class="fs-4 fw-semibold">@citiesModel.TotalSubscriptions</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Countries</div>
                <div class="fs-4 fw-semibold">@citiesModel.CountryCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Most Subscribed</div>
                <div class="fs-6 fw-semibold text-truncate">@DisplayValue(citiesModel.MostSubscribedCity?.Name)</div>
                <div class="text-muted small">@FormatCount(citiesModel.MostSubscribedCity?.SubscriptionCount) subscriptions</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-2">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h6 class="card-title mb-0">Current Weather</h6>
                <div class="text-muted small">@DisplayValue(citiesModel.SelectedCity?.Name)</div>
            </div>
            @if (citiesModel.CurrentWeather is not null)
            {
                <span class="badge">@DisplayValue(citiesModel.CurrentWeather.WeatherDescription)</span>
            }
        </div>

        @if (citiesModel.Cities.Count == 0)
        {
            <div class="text-muted small">No city is available for weather selection.</div>
        }
        else if (citiesModel.CurrentWeather is null)
        {
            <div class="text-muted small">No current weather is available for the selected city.</div>
        }
        else
        {
            <div class="row g-2">
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Temperature</div>
                        <div class="fs-5 fw-semibold">@FormatTemperature(citiesModel.CurrentWeather.Temperature)</div>
                        <div class="text-muted small">Feels @FormatTemperature(citiesModel.CurrentWeather.ApparentTemperature)</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Humidity</div>
                        <div class="fs-5 fw-semibold">@citiesModel.CurrentWeather.Humidity%</div>
                        <div class="text-muted small">@citiesModel.CurrentWeather.CloudCover% cloud cover</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Wind</div>
                        <div class="fs-5 fw-semibold">@FormatDecimal(citiesModel.CurrentWeather.WindSpeed) km/h</div>
                        <div class="text-muted small">@citiesModel.CurrentWeather.WindDirection degrees, gusts @FormatDecimal(citiesModel.CurrentWeather.WindGusts) km/h</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Pressure</div>
                        <div class="fs-5 fw-semibold">@FormatDecimal(citiesModel.CurrentWeather.Pressure) hPa</div>
                        <div class="text-muted small">@FormatDecimal(citiesModel.CurrentWeather.Precipitation) mm precipitation</div>
                    </div>
                </div>
            </div>

            <div class="text-muted small mt-2">
                Retrieved @citiesModel.CurrentWeather.RetrievedAt.ToLocalTime().ToString("g", CultureInfo.InvariantCulture)
                @if (citiesModel.CurrentWeather.StaleDataWarning)
                {
                    <span class="text-warning ms-2">@DisplayValue(citiesModel.CurrentWeather.StaleDataWarningMessage)</span>
                }
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title mb-0">Cities</h6>
            <span class="badge">@citiesModel.Cities.Count</span>
        </div>

        @if (citiesModel.Cities.Count == 0)
        {
            <div class="text-muted small">No WeatherFiesta cities are available.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>City</th>
                        <th>Country</th>
                        <th>Timezone</th>
                        <th class="text-end">Subscriptions</th>
                        <th class="text-end">Coordinates</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var city in citiesModel.Cities)
                    {
                        <tr>
                            <td class="text-break">
                                <div class="fw-semibold">@DisplayValue(city.Name)</div>
                                <div class="text-muted small">@DisplayValue(city.Id)</div>
                            </td>
                            <td class="text-break">@DisplayCountry(city)</td>
                            <td class="text-break">@DisplayValue(city.TimeZone)</td>
                            <td class="text-end">@city.SubscriptionCount</td>
                            <td class="text-end text-nowrap">@FormatCoordinate(city.Latitude), @FormatCoordinate(city.Longitude)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private async Task<WeatherFiestaDashboardCitiesViewModel> CreateModelAsync()
    {
        var requester = this.HttpContext.RequestServices.GetService<IRequester>();
        var result = new WeatherFiestaDashboardCitiesViewModel
        {
            CapturedAtUtc = DateTimeOffset.UtcNow
        };

        if (requester is null)
        {
            result.Errors.Add("The requester service is not registered.");
            return result;
        }

        var citiesResult = await requester.SendAsync(new AdminCitiesQuery(), cancellationToken: this.HttpContext.RequestAborted);
        if (citiesResult.IsFailure)
        {
            result.Errors.AddRange(citiesResult.Errors.Select(error => error.Message));
            return result;
        }

        result.Cities.AddRange(citiesResult.Value
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase));

        result.SelectedCityId = GetSelectedCityId(result.Cities);
        result.SelectedCity = result.Cities.FirstOrDefault(city => string.Equals(city.Id, result.SelectedCityId, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(result.SelectedCityId))
        {
            var weatherResult = await requester.SendAsync(new AdminCityWeatherQuery(result.SelectedCityId), cancellationToken: this.HttpContext.RequestAborted);
            if (weatherResult.IsSuccess)
            {
                result.CurrentWeather = weatherResult.Value;
            }
            else
            {
                result.Errors.AddRange(weatherResult.Errors.Select(error => error.Message));
            }
        }

        return result;
    }

    private string GetSelectedCityId(IEnumerable<AdminCityModel> cities)
    {
        var cityIds = cities
            .Select(city => city.Id)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (this.HttpContext.Request.Query.TryGetValue("cityId", out var selectedCityId) &&
            cityIds.Contains(selectedCityId.ToString()))
        {
            return selectedCityId.ToString();
        }

        return cities
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault()?.Id;
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayCountry(AdminCityModel city)
    {
        if (city is null)
        {
            return "-";
        }

        return string.IsNullOrWhiteSpace(city.CountryCode)
            ? DisplayValue(city.Country)
            : $"{DisplayValue(city.Country)} ({city.CountryCode})";
    }

    private static string FormatCoordinate(decimal value)
    {
        return value.ToString("0.####", CultureInfo.InvariantCulture);
    }

    private static string FormatCount(int? value)
    {
        return value?.ToString("N0", CultureInfo.InvariantCulture) ?? "0";
    }

    private static string FormatTemperature(decimal value)
    {
        return $"{FormatDecimal(value)} °C";
    }

    private static string FormatDecimal(decimal value)
    {
        return value.ToString("0.#", CultureInfo.InvariantCulture);
    }

    private sealed class WeatherFiestaDashboardCitiesViewModel
    {
        public DateTimeOffset CapturedAtUtc { get; init; }

        public List<AdminCityModel> Cities { get; } = [];

        public List<string> Errors { get; } = [];

        public string SelectedCityId { get; set; }

        public AdminCityModel SelectedCity { get; set; }

        public CurrentWeatherModel CurrentWeather { get; set; }

        public int TotalSubscriptions => this.Cities.Sum(city => city.SubscriptionCount);

        public int CountryCount => this.Cities
            .Select(city => city.CountryCode ?? city.Country)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

        public AdminCityModel MostSubscribedCity => this.Cities
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
    }
}
