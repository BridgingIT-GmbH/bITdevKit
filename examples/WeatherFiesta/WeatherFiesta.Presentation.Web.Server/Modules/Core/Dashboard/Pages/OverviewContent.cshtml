@using BridgingIT.DevKit.Examples.WeatherFiesta.Application.Modules.Core
@using BridgingIT.DevKit.Examples.WeatherFiesta.Application.Modules.Core.Models
@using BridgingIT.DevKit.Domain
@using BridgingIT.DevKit.Domain.Repositories
@using BridgingIT.DevKit.Examples.WeatherFiesta.Domain.Modules.Core.Model
@using BridgingIT.DevKit.Examples.WeatherFiesta.Infrastructure
@using Microsoft.Extensions.DependencyInjection
@using System.Text.Json
@inherits DashboardContentSlice

@{
    var citiesModel = await CreateModelAsync();
    var forecastExportPath = !string.IsNullOrWhiteSpace(citiesModel.SelectedCityId)
        ? $"/api/core/cities/{Uri.EscapeDataString(citiesModel.SelectedCityId)}/weather/export"
        : null;
}

@if (citiesModel.Errors.Count > 0)
{
    <div class="alert alert-danger py-2 mb-2">
        @foreach (var error in citiesModel.Errors)
        {
            <div>@error</div>
        }
    </div>
}

<div class="row g-2 mb-2">
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Cities</div>
                <div class="fs-4 fw-semibold">@citiesModel.Cities.Count</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Subscriptions</div>
                <div class="fs-4 fw-semibold">@citiesModel.TotalSubscriptions</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Countries</div>
                <div class="fs-4 fw-semibold">@citiesModel.CountryCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Most Subscribed</div>
                <div class="fs-6 fw-semibold text-truncate">@DisplayValue(citiesModel.MostSubscribedCity?.Name)</div>
                <div class="text-muted small">@FormatCount(citiesModel.MostSubscribedCity?.SubscriptionCount) subscriptions</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-2">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h6 class="card-title mb-0">Current Weather</h6>
                <div class="text-muted small">@DisplayValue(citiesModel.SelectedCity?.Name)</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrWhiteSpace(forecastExportPath))
                {
                    <a id="export-selected-city-forecasts-csv"
                       class="btn btn-sm btn-outline-secondary"
                       href="@forecastExportPath">
                        Export CSV
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(citiesModel.SelectedCityWeatherJson))
                {
                    <button id="copy-selected-city-weather-json"
                            type="button"
                            class="btn btn-sm btn-outline-secondary"
                            onclick="const payload=document.getElementById('selected-city-weather-json');if(!payload){return false;}payload.focus();payload.select();payload.setSelectionRange(0,payload.value.length);const copied=document.execCommand('copy');const label=this.dataset.copyLabel||this.textContent;this.dataset.copyLabel=label;this.textContent=copied?'Copied':'Copy failed';window.setTimeout(()=>this.textContent=label,1600);return false;">Copy JSON</button>
                }
                @if (citiesModel.CurrentWeather is not null)
                {
                    <span class="badge">@DisplayValue(citiesModel.CurrentWeather.WeatherDescription)</span>
                }
            </div>
        </div>

        @if (citiesModel.Cities.Count == 0)
        {
            <div class="text-muted small">No city is available for weather selection.</div>
        }
        else if (citiesModel.CurrentWeather is null)
        {
            <div class="text-muted small">No current weather is available for the selected city.</div>
        }
        else
        {
            <div class="row g-2">
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Temperature</div>
                        <div class="fs-5 fw-semibold">@FormatTemperature(citiesModel.CurrentWeather.Temperature)</div>
                        <div class="text-muted small">Feels @FormatTemperature(citiesModel.CurrentWeather.ApparentTemperature)</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Humidity</div>
                        <div class="fs-5 fw-semibold">@citiesModel.CurrentWeather.Humidity%</div>
                        <div class="text-muted small">@citiesModel.CurrentWeather.CloudCover% cloud cover</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Wind</div>
                        <div class="fs-5 fw-semibold">@FormatDecimal(citiesModel.CurrentWeather.WindSpeed) km/h</div>
                        <div class="text-muted small">@citiesModel.CurrentWeather.WindDirection degrees, gusts @FormatDecimal(citiesModel.CurrentWeather.WindGusts) km/h</div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">Pressure</div>
                        <div class="fs-5 fw-semibold">@FormatDecimal(citiesModel.CurrentWeather.Pressure) hPa</div>
                        <div class="text-muted small">@FormatDecimal(citiesModel.CurrentWeather.Precipitation) mm precipitation</div>
                    </div>
                </div>
            </div>

            <div class="text-muted small mt-2">
                Retrieved @citiesModel.CurrentWeather.RetrievedAt.ToLocalTime().ToString("g", CultureInfo.InvariantCulture)
                @if (citiesModel.CurrentWeather.StaleDataWarning)
                {
                    <span class="text-warning ms-2">@DisplayValue(citiesModel.CurrentWeather.StaleDataWarningMessage)</span>
                }
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(citiesModel.SelectedCityWeatherJson))
{
    <textarea id="selected-city-weather-json" readonly style="position:fixed;left:-9999px;top:0;width:1px;height:1px;opacity:0;">@citiesModel.SelectedCityWeatherJson</textarea>
}

<div class="card mb-2">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div>
                <h6 class="card-title mb-0">Weather Reports</h6>
                <div class="text-muted small">@DisplayValue(citiesModel.SelectedCity?.Name)</div>
            </div>
            <span class="badge">@citiesModel.Reports.Count</span>
        </div>

        @if (citiesModel.Cities.Count == 0)
        {
            <div class="text-muted small">No city is available for report selection.</div>
        }
        else if (citiesModel.Reports.Count == 0)
        {
            <div class="text-muted small">No weather reports are available for the selected city.</div>
        }
        else
        {
            <div class="row g-2">
                @foreach (var report in citiesModel.Reports)
                {
                    <div class="col-12 col-lg-4">
                        <div class="border rounded p-2 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                <div class="fw-semibold">@FormatReportType(report.ReportType)</div>
                                <span class="badge text-nowrap">@FormatDateRange(report.ForecastDateStart, report.ForecastDateEndExclusive)</span>
                            </div>
                            <div class="small">@DisplayValue(report.Summary)</div>
                            <div class="text-muted small mt-2">Generated @report.GeneratedAt.ToLocalTime().ToString("g", CultureInfo.InvariantCulture)</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title mb-0">Cities</h6>
            <span class="badge">@citiesModel.Cities.Count</span>
        </div>

        @if (citiesModel.Cities.Count == 0)
        {
            <div class="text-muted small">No WeatherFiesta cities are available.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>City</th>
                        <th>Country</th>
                        <th>Timezone</th>
                        <th class="text-end">Subscriptions</th>
                        <th class="text-end">Coordinates</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var city in citiesModel.Cities)
                    {
                        <tr>
                            <td class="text-break">
                                <div class="fw-semibold">@DisplayValue(city.Name)</div>
                                <div class="text-muted small">@DisplayValue(city.Id)</div>
                            </td>
                            <td class="text-break">@DisplayCountry(city)</td>
                            <td class="text-break">@DisplayValue(city.TimeZone)</td>
                            <td class="text-end">@city.SubscriptionCount</td>
                            <td class="text-end text-nowrap">@FormatCoordinate(city.Latitude), @FormatCoordinate(city.Longitude)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private async Task<WeatherFiestaDashboardCitiesViewModel> CreateModelAsync()
    {
        var result = new WeatherFiestaDashboardCitiesViewModel
        {
            CapturedAtUtc = DateTimeOffset.UtcNow
        };

        var databaseReadyService = this.HttpContext.RequestServices.GetService<IDatabaseReadyService>();
        if (databaseReadyService?.IsReady(nameof(CoreDbContext)) == false)
        {
            result.Errors.Add("The database is still starting.");
            return result;
        }

        var requester = this.HttpContext.RequestServices.GetService<IRequester>();
        if (requester is null)
        {
            result.Errors.Add("The requester service is not registered.");
            return result;
        }

        var citiesResult = await requester.SendAsync(new AdminCitiesQuery(), cancellationToken: this.HttpContext.RequestAborted);
        if (citiesResult.IsFailure)
        {
            result.Errors.AddRange(citiesResult.Errors.Select(error => error.Message));
            return result;
        }

        result.Cities.AddRange(citiesResult.Value
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase));

        result.SelectedCityId = GetSelectedCityId(result.Cities);
        result.SelectedCity = result.Cities.FirstOrDefault(city => string.Equals(city.Id, result.SelectedCityId, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(result.SelectedCityId))
        {
            var weatherResult = await requester.SendAsync(new AdminCityWeatherQuery(result.SelectedCityId), cancellationToken: this.HttpContext.RequestAborted);
            if (weatherResult.IsSuccess)
            {
                result.CurrentWeather = weatherResult.Value;
            }
            else
            {
                result.Errors.AddRange(weatherResult.Errors.Select(error => error.Message));
            }
        }

        await LoadWeatherReportsAsync(result);
        await LoadForecastsAsync(result);
        result.SelectedCityWeatherJson = CreateSelectedCityWeatherJson(result);

        return result;
    }

    private async Task LoadForecastsAsync(WeatherFiestaDashboardCitiesViewModel model)
    {
        if (!Guid.TryParse(model.SelectedCityId, out var cityIdValue))
        {
            return;
        }

        var cityId = CityId.Create(cityIdValue);
        var options = new FindOptions<WeatherForecast>()
            .AddInclude(new IncludeOption<WeatherForecast>(forecast => forecast.HourlyForecasts));

        var forecastsResult = await WeatherForecast.FindAllAsync(
            new Specification<WeatherForecast>(forecast => forecast.CityId == cityId),
            options,
            this.HttpContext.RequestAborted);

        if (forecastsResult.IsFailure)
        {
            model.Errors.AddRange(forecastsResult.Errors.Select(error => error.Message));
            return;
        }

        model.Forecasts.AddRange(forecastsResult.Value
            .OrderBy(forecast => forecast.ForecastDate)
            .Select(MapForecast));
    }

    private async Task LoadWeatherReportsAsync(WeatherFiestaDashboardCitiesViewModel model)
    {
        if (!Guid.TryParse(model.SelectedCityId, out var cityIdValue))
        {
            return;
        }

        var cityId = CityId.Create(cityIdValue);
        var reportTypes = new[]
        {
            WeatherReportType.Today,
            WeatherReportType.Tomorrow,
            WeatherReportType.Week
        };

        var reportsResult = await WeatherReport.FindAllAsync(
            new Specification<WeatherReport>(report =>
                report.CityId == cityId &&
                reportTypes.Contains(report.ReportType)),
            null,
            this.HttpContext.RequestAborted);

        if (reportsResult.IsFailure)
        {
            model.Errors.AddRange(reportsResult.Errors.Select(error => error.Message));
            return;
        }

        model.Reports.AddRange(reportsResult.Value
            .GroupBy(report => report.ReportType)
            .Select(group => group
                .OrderByDescending(report => report.GeneratedAt)
                .ThenByDescending(report => report.PeriodStartUtc)
                .First())
            .OrderBy(report => GetReportTypeOrder(report.ReportType))
            .Select(report => new WeatherReportDashboardModel
            {
                ReportType = report.ReportType,
                ForecastDateStart = report.ForecastDateStart,
                ForecastDateEndExclusive = report.ForecastDateEndExclusive,
                Summary = report.Summary,
                GeneratedAt = report.GeneratedAt
            }));
    }

    private static WeatherForecastModel MapForecast(WeatherForecast forecast)
    {
        return new WeatherForecastModel
        {
            Id = forecast.Id.Value.ToString(),
            CityId = forecast.CityId.Value.ToString(),
            ForecastDate = forecast.ForecastDate,
            DayWeatherCode = forecast.DayWeatherCode,
            DayWeatherDescription = GetWeatherDescription(forecast.DayWeatherCode),
            DayWeatherIcon = GetWeatherIcon(forecast.DayWeatherCode),
            TemperatureMax = forecast.TemperatureMax,
            TemperatureMin = forecast.TemperatureMin,
            ApparentTemperatureMax = forecast.ApparentTemperatureMax,
            ApparentTemperatureMin = forecast.ApparentTemperatureMin,
            PrecipitationSum = forecast.PrecipitationSum,
            PrecipitationProbabilityMax = forecast.PrecipitationProbabilityMax,
            WindSpeedMax = forecast.WindSpeedMax,
            WindGustsMax = forecast.WindGustsMax,
            DominantWindDirection = forecast.DominantWindDirection,
            UvIndexMax = forecast.UvIndexMax,
            SunshineDurationSeconds = forecast.SunshineDurationSeconds,
            DaylightDurationSeconds = forecast.DaylightDurationSeconds,
            Sunrise = forecast.Sunrise,
            Sunset = forecast.Sunset,
            RetrievedAt = forecast.RetrievedAt,
            HourlyForecasts = forecast.HourlyForecasts
                .OrderBy(hourlyForecast => hourlyForecast.Hour)
                .Select(MapHourlyForecast)
                .ToList()
        };
    }

    private static HourlyForecastModel MapHourlyForecast(HourlyForecast hourlyForecast)
    {
        return new HourlyForecastModel
        {
            Id = hourlyForecast.Id,
            Hour = hourlyForecast.Hour,
            Temperature = hourlyForecast.Temperature,
            RelativeHumidity = hourlyForecast.RelativeHumidity,
            ApparentTemperature = hourlyForecast.ApparentTemperature,
            PrecipitationProbability = hourlyForecast.PrecipitationProbability,
            Precipitation = hourlyForecast.Precipitation,
            WeatherCode = hourlyForecast.WeatherCode,
            WeatherDescription = GetWeatherDescription(hourlyForecast.WeatherCode),
            WindSpeed = hourlyForecast.WindSpeed,
            WindDirection = hourlyForecast.WindDirection,
            WindGusts = hourlyForecast.WindGusts,
            CloudCover = hourlyForecast.CloudCover,
            Visibility = hourlyForecast.Visibility,
            IsDay = hourlyForecast.IsDay
        };
    }

    private static string CreateSelectedCityWeatherJson(WeatherFiestaDashboardCitiesViewModel model)
    {
        if (model.SelectedCity is null)
        {
            return null;
        }

        var payload = new
        {
            city = model.SelectedCity,
            current = model.CurrentWeather,
            forecasts = model.Forecasts
        };

        return JsonSerializer.Serialize(payload, new JsonSerializerOptions(JsonSerializerDefaults.Web)
        {
            WriteIndented = true
        });
    }

    private string GetSelectedCityId(IEnumerable<AdminCityModel> cities)
    {
        var cityIds = cities
            .Select(city => city.Id)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (this.HttpContext.Request.Query.TryGetValue("cityId", out var selectedCityId) &&
            cityIds.Contains(selectedCityId.ToString()))
        {
            return selectedCityId.ToString();
        }

        return cities
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault()?.Id;
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayCountry(AdminCityModel city)
    {
        if (city is null)
        {
            return "-";
        }

        return string.IsNullOrWhiteSpace(city.CountryCode)
            ? DisplayValue(city.Country)
            : $"{DisplayValue(city.Country)} ({city.CountryCode})";
    }

    private static string FormatCoordinate(decimal value)
    {
        return value.ToString("0.####", CultureInfo.InvariantCulture);
    }

    private static string FormatCount(int? value)
    {
        return value?.ToString("N0", CultureInfo.InvariantCulture) ?? "0";
    }

    private static string FormatTemperature(decimal value)
    {
        return $"{FormatDecimal(value)} °C";
    }

    private static string FormatDecimal(decimal value)
    {
        return value.ToString("0.#", CultureInfo.InvariantCulture);
    }

    private static string FormatReportType(WeatherReportType reportType)
    {
        return reportType switch
        {
            WeatherReportType.Today => "Today",
            WeatherReportType.Tomorrow => "Tomorrow",
            WeatherReportType.Week => "Week",
            WeatherReportType.Current => "Current",
            _ => reportType.ToString()
        };
    }

    private static string GetWeatherDescription(int weatherCode)
    {
        var condition = WeatherConditionCode.GetAll()
            .FirstOrDefault(c => c.Id == weatherCode);

        return condition?.Description ?? $"Unknown weather code {weatherCode}";
    }

    private static string GetWeatherIcon(int weatherCode)
    {
        var condition = WeatherConditionCode.GetAll()
            .FirstOrDefault(c => c.Id == weatherCode);

        return condition?.Icon ?? "?";
    }

    private static string FormatDateRange(DateOnly start, DateOnly endExclusive)
    {
        var endInclusive = endExclusive.AddDays(-1);
        return start == endInclusive
            ? start.ToString("MMM d", CultureInfo.InvariantCulture)
            : $"{start.ToString("MMM d", CultureInfo.InvariantCulture)}-{endInclusive.ToString("MMM d", CultureInfo.InvariantCulture)}";
    }

    private static int GetReportTypeOrder(WeatherReportType reportType)
    {
        return reportType switch
        {
            WeatherReportType.Today => 0,
            WeatherReportType.Tomorrow => 1,
            WeatherReportType.Week => 2,
            WeatherReportType.Current => 3,
            _ => 99
        };
    }

    private sealed class WeatherFiestaDashboardCitiesViewModel
    {
        public DateTimeOffset CapturedAtUtc { get; init; }

        public List<AdminCityModel> Cities { get; } = [];

        public List<string> Errors { get; } = [];

        public string SelectedCityId { get; set; }

        public AdminCityModel SelectedCity { get; set; }

        public CurrentWeatherModel CurrentWeather { get; set; }

        public List<WeatherReportDashboardModel> Reports { get; } = [];

        public List<WeatherForecastModel> Forecasts { get; } = [];

        public string SelectedCityWeatherJson { get; set; }

        public int TotalSubscriptions => this.Cities.Sum(city => city.SubscriptionCount);

        public int CountryCount => this.Cities
            .Select(city => city.CountryCode ?? city.Country)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

        public AdminCityModel MostSubscribedCity => this.Cities
            .OrderByDescending(city => city.SubscriptionCount)
            .ThenBy(city => city.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
    }

    private sealed class WeatherReportDashboardModel
    {
        public WeatherReportType ReportType { get; init; }

        public DateOnly ForecastDateStart { get; init; }

        public DateOnly ForecastDateEndExclusive { get; init; }

        public string Summary { get; init; }

        public DateTime GeneratedAt { get; init; }
    }
}
