<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Microsoft.AspNetCore.OpenApi.Generated</InterceptorsNamespaces>
    <AssemblyName>BridgingIT.DevKit.Examples.WeatherFiesta.Presentation.Web.Server</AssemblyName>
    <RootNamespace>BridgingIT.DevKit.Examples.WeatherFiesta.Presentation.Web.Server</RootNamespace>
    <IsPackable>false</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="logs\**" />
    <Content Remove="logs\**" />
    <EmbeddedResource Remove="logs\**" />
    <None Remove="logs\**" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="BridgingIT.DevKit.Examples.WeatherFiesta.UnitTests" />
  </ItemGroup>

  <!-- OpenAPI build-time generation configuration -->
  <PropertyGroup>
    <OpenApiGenerateDocuments>true</OpenApiGenerateDocuments>
    <OpenApiDocumentsDirectory>$(MSBuildProjectDirectory)/wwwroot</OpenApiDocumentsDirectory>
    <OpenApiGenerateDocumentsOptions>--file-name openapi</OpenApiGenerateDocumentsOptions>
  </PropertyGroup>
  <!-- OpenAPI generate document after build -->
  <Target Name="GenerateOpenApiAfterBuild" AfterTargets="Build" DependsOnTargets="GenerateOpenApiDocuments" Condition="'$(OpenApiGenerateDocuments)' == 'true'" />

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.ApiDescription.Server" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" />
    <PackageReference Include="OpenTelemetry.Instrumentation.SqlClient" />
    <PackageReference Include="Azure.Monitor.OpenTelemetry.Exporter" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" />
    <PackageReference Include="Scalar.AspNetCore" />
    <PackageReference Include="Serilog.AspNetCore" />
    <PackageReference Include="Serilog.Enrichers.Environment" />
    <PackageReference Include="Serilog.Enrichers.ShortTypeName" />
    <PackageReference Include="Serilog.Enrichers.Thread" />
    <PackageReference Include="Serilog.Sinks.Console" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Serilog.Sinks.MSSqlServer" />
    <PackageReference Include="Serilog.Sinks.Seq" />
    <PackageReference Include="Serilog.Sinks.Trace" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Application.Messaging\Application.Messaging.csproj" />
    <ProjectReference Include="..\..\..\src\Application.Storage.Jobs\Application.Storage.Jobs.csproj" />
    <ProjectReference Include="..\..\..\src\Application.Storage\Application.Storage.csproj" />
    <ProjectReference Include="..\..\..\src\Application.Utilities\Application.Utilities.csproj" />
    <ProjectReference Include="..\..\..\src\Application.DataPorter/Application.DataPorter.csproj" />
    <ProjectReference Include="..\..\..\src\Common.Extensions.Web\Common.Extensions.Web.csproj" />
    <ProjectReference Include="..\..\..\src\Common.Extensions\Common.Extensions.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Configuration\Presentation.Configuration.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Serilog\Presentation.Serilog.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.EntityFramework\Presentation.Web.EntityFramework.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Jobs\Presentation.Web.Jobs.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Messaging\Presentation.Web.Messaging.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Notifications\Presentation.Web.Notifications.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Orchestrations\Presentation.Web.Orchestrations.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Queueing\Presentation.Web.Queueing.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web.Storage\Presentation.Web.Storage.csproj" />
    <ProjectReference Include="..\..\..\src\Presentation.Web\Presentation.Web.csproj" />
    <ProjectReference Include="..\WeatherFiesta.Application\WeatherFiesta.Application.csproj" />
    <ProjectReference Include="..\WeatherFiesta.Infrastructure\WeatherFiesta.Infrastructure.csproj" />
  </ItemGroup>

</Project>
