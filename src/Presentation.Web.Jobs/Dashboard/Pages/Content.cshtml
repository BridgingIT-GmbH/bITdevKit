@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@using JobsDashboardEndpoints = BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard.DashboardEndpoints
@inherits RazorSlice

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var realtimeDataPath = JobsDashboardEndpoints.BuildJobsRealtimeDataPath(dashboardOptions);
    var historyDataPath = JobsDashboardEndpoints.BuildJobsHistoryDataPath(dashboardOptions);
}

<style>
    #jobs-dashboard-root {
        height: calc(100vh - 13rem);
        min-height: 560px;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        overflow: hidden;
    }

    #jobs-dashboard-root .jobs-card-grid {
        flex: 0 0 auto;
    }

    #jobs-dashboard-root > #dashboard-jobs-content {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        overflow: hidden;
    }

    #jobs-dashboard-root .jobs-data-zone {
        flex: 1 1 auto;
        min-height: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: .75rem;
        overflow: hidden;
    }

    #jobs-dashboard-root .jobs-panel {
        border: 1px solid var(--bs-border-color);
        border-radius: .375rem;
        background: var(--bs-body-bg);
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    #jobs-dashboard-root .jobs-panel-header {
        padding: .6rem .75rem;
        border-bottom: 1px solid var(--bs-border-color);
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .5rem;
    }

    #jobs-dashboard-root .jobs-panel-body {
        min-height: 0;
        overflow: auto;
        padding: .25rem .5rem .5rem .5rem;
    }

    #jobs-dashboard-root .jobs-graph-zone {
        flex: 0 0 auto;
        border: 1px solid var(--bs-border-color);
        border-radius: .375rem;
        background: var(--bs-body-bg);
        min-height: 275px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #jobs-dashboard-root .jobs-graph-canvas {
        height: 230px;
        width: 100%;
    }

    #jobs-dashboard-root .jobs-legend {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        font-size: .8rem;
        color: var(--bs-secondary-color);
        padding: .25rem .75rem .5rem .75rem;
    }

    #jobs-dashboard-root .jobs-dot {
        width: .65rem;
        height: .65rem;
        border-radius: 999px;
        display: inline-block;
        margin-right: .25rem;
    }

    #jobs-dashboard-root .jobs-history-window .btn {
        min-width: 4.25rem;
    }

    @@media (min-width: 1400px) {
        #jobs-dashboard-root .jobs-data-zone {
            grid-template-columns: 1.35fr .9fr;
        }
    }
</style>

<div id="jobs-dashboard-root" data-realtime-url="@realtimeDataPath" data-history-url="@historyDataPath">
    <div id="dashboard-jobs-content">
        @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard.Pages.Data>())
    </div>

    <section class="jobs-graph-zone">
        <ul class="nav nav-tabs px-2 pt-2" id="jobsGraphTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="jobs-graph-realtime-tab" data-bs-toggle="tab" data-bs-target="#jobs-graph-realtime" type="button" role="tab">
                    Realtime Graph
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="jobs-graph-history-tab" data-bs-toggle="tab" data-bs-target="#jobs-graph-history" type="button" role="tab">
                    History Graph
                </button>
            </li>
        </ul>

        <div class="tab-content flex-grow-1">
            <div class="tab-pane fade show active" id="jobs-graph-realtime" role="tabpanel" tabindex="0">
                <div class="jobs-graph-canvas" id="jobs-realtime-graph"></div>
                <div class="jobs-legend">
                    <span><i class="jobs-dot" style="background:#198754"></i>Running</span>
                    <span><i class="jobs-dot" style="background:#dc3545"></i>Failed</span>
                    <span><i class="jobs-dot" style="background:#0d6efd"></i>Due</span>
                    <span><i class="jobs-dot" style="background:#20c997"></i>Completed</span>
                </div>
            </div>
            <div class="tab-pane fade" id="jobs-graph-history" role="tabpanel" tabindex="0">
                <div class="d-flex justify-content-end p-2 jobs-history-window">
                    <div class="btn-group btn-group-sm" role="group" aria-label="History window">
                        <button class="btn btn-outline-secondary active" data-window="day" type="button">Day</button>
                        <button class="btn btn-outline-secondary" data-window="week" type="button">Week</button>
                        <button class="btn btn-outline-secondary" data-window="month" type="button">Month</button>
                    </div>
                </div>
                <div class="jobs-graph-canvas" id="jobs-history-graph"></div>
                <div class="jobs-legend">
                    <span><i class="jobs-dot" style="background:#198754"></i>Completed</span>
                    <span><i class="jobs-dot" style="background:#dc3545"></i>Failed</span>
                    <span><i class="jobs-dot" style="background:#0d6efd"></i>Running</span>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
    (() => {
        const root = document.getElementById('jobs-dashboard-root');
        if (!root) {
            return;
        }

        if (window.bdkJobsGraphState && typeof window.bdkJobsGraphState.dispose === 'function') {
            window.bdkJobsGraphState.dispose();
        }

        const realtimeUrl = root.getAttribute('data-realtime-url');
        const historyUrl = root.getAttribute('data-history-url');
        const realtimeHost = document.getElementById('jobs-realtime-graph');
        const historyHost = document.getElementById('jobs-history-graph');
        const historyButtons = Array.from(root.querySelectorAll('.jobs-history-window [data-window]'));
        const graphTabs = Array.from(root.querySelectorAll('[data-bs-toggle="tab"]'));
        const realtimeSessionStorageKey = 'bdk.dashboard.jobs.sessionId';
        const realtimeSessionId = getOrCreateRealtimeSessionId();

        let disposed = false;
        let realtimeTimer = null;
        let realtimeSamples = [];
        let historyWindow = 'day';
        const themeChanged = async () => {
            await renderRealtime();
            if (document.getElementById('jobs-graph-history-tab')?.classList.contains('active')) {
                await loadHistory();
            }
        };

        function dispose() {
            disposed = true;
            if (realtimeTimer !== null) {
                window.clearInterval(realtimeTimer);
                realtimeTimer = null;
            }
            document.removeEventListener('bdk-dashboard-theme-changed', themeChanged);

            if (window.Plotly) {
                if (realtimeHost) {
                    window.Plotly.purge(realtimeHost);
                }

                if (historyHost) {
                    window.Plotly.purge(historyHost);
                }
            }
        }

        function getOrCreateRealtimeSessionId() {
            try {
                const existing = sessionStorage.getItem(realtimeSessionStorageKey);
                if (existing) {
                    return existing;
                }

                const created = crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
                sessionStorage.setItem(realtimeSessionStorageKey, created);
                return created;
            } catch {
                return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
            }
        }

        async function ensurePlotly() {
            return window.bdkDashboard.loadPlotly();
        }

        function getPlotLayout() {
            return window.bdkDashboard.createPlotlyLayout({ showlegend: false });
        }

        async function renderPlot(host, traces) {
            if (!host || disposed) {
                return;
            }

            if (host.clientWidth === 0) {
                return;
            }

            try {
                const Plotly = await ensurePlotly();
                await Plotly.react(host, traces, getPlotLayout(), {
                    displayModeBar: false,
                    responsive: true,
                    staticPlot: true,
                });
            } catch {
                // best effort chart rendering
            }
        }

        function normalizeRealtimeSample(sample) {
            if (!sample || !sample.timestampUtc) {
                return null;
            }

            const timestamp = new Date(sample.timestampUtc);
            if (Number.isNaN(timestamp.getTime())) {
                return null;
            }

            return {
                timestampUtc: timestamp.toISOString(),
                running: Number(sample.running ?? 0),
                failed: Number(sample.failed ?? 0),
                due: Number(sample.due ?? 0),
                completed: Number(sample.completed ?? 0),
            };
        }

        function getDeltaSeries(samples, propertyName) {
            return samples.map((sample, index) => {
                if (index === 0) {
                    return 0;
                }

                const previous = samples[index - 1];
                return Math.max(0, Number(sample[propertyName] ?? 0) - Number(previous[propertyName] ?? 0));
            });
        }

        function trimRealtimeSamples(samples) {
            if (!Array.isArray(samples)) {
                return [];
            }

            const normalized = samples
                .map(normalizeRealtimeSample)
                .filter(x => x !== null);

            return normalized.length > 180
                ? normalized.slice(normalized.length - 180)
                : normalized;
        }

        async function renderRealtime() {
            if (realtimeSamples.length === 0) {
                return;
            }

            const x = realtimeSamples.map(x => new Date(x.timestampUtc));
            const theme = window.bdkDashboard.getChartTheme();
            await renderPlot(realtimeHost, [
                { x, y: realtimeSamples.map(x => x.running ?? 0), mode: 'lines', line: { color: theme.success, width: 2 }, type: 'scatter' },
                { x, y: realtimeSamples.map(x => x.due ?? 0), mode: 'lines', line: { color: theme.primary, width: 2 }, type: 'scatter' },
                { x, y: getDeltaSeries(realtimeSamples, 'completed'), mode: 'lines', line: { color: theme.info, width: 2 }, type: 'scatter' },
                { x, y: getDeltaSeries(realtimeSamples, 'failed'), mode: 'lines', line: { color: theme.danger, width: 2 }, type: 'scatter' },
            ]);
        }

        async function sampleRealtime() {
            if (disposed) {
                return;
            }

            try {
                const url = new URL(realtimeUrl, window.location.origin);
                url.searchParams.set('sessionId', realtimeSessionId);
                url.searchParams.set('_', Date.now().toString());
                const response = await fetch(url.toString(), {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'fetch' }
                });
                if (!response.ok) {
                    return;
                }

                const payload = await response.json();
                realtimeSamples = trimRealtimeSamples(Array.isArray(payload.samples) ? payload.samples : []);
                await renderRealtime();
            } catch {
                // best effort graph polling
            }
        }

        async function loadHistory() {
            if (disposed) {
                return;
            }

            try {
                const url = new URL(historyUrl, window.location.origin);
                url.searchParams.set('window', historyWindow);
                url.searchParams.set('_', Date.now().toString());
                const response = await fetch(url.toString(), {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'fetch' }
                });
                if (!response.ok) {
                    return;
                }

                const payload = await response.json();
                const buckets = Array.isArray(payload.buckets) ? payload.buckets : [];
                const x = buckets.map(x => new Date(x.startUtc));
                const theme = window.bdkDashboard.getChartTheme();

                await renderPlot(historyHost, [
                    { x, y: buckets.map(x => x.completed ?? 0), mode: 'lines', line: { color: theme.success, width: 2 }, type: 'scatter' },
                    { x, y: buckets.map(x => x.failed ?? 0), mode: 'lines', line: { color: theme.danger, width: 2 }, type: 'scatter' },
                    { x, y: buckets.map(x => x.running ?? 0), mode: 'lines', line: { color: theme.primary, width: 2 }, type: 'scatter' },
                ]);
            } catch {
                // best effort graph loading
            }
        }

        historyButtons.forEach(button => {
            button.addEventListener('click', async () => {
                historyButtons.forEach(x => x.classList.remove('active'));
                button.classList.add('active');
                historyWindow = button.getAttribute('data-window') || 'day';
                await loadHistory();
            });
        });

        graphTabs.forEach(tab => {
            tab.addEventListener('shown.bs.tab', async event => {
                const target = event.target;
                if (!(target instanceof HTMLElement)) {
                    return;
                }

                if (target.id === 'jobs-graph-history-tab') {
                    await loadHistory();
                }

                if (window.Plotly) {
                    const host = target.id === 'jobs-graph-history-tab' ? historyHost : realtimeHost;
                    if (host) {
                        window.Plotly.Plots.resize(host);
                    }
                }
            });
        });

        document.addEventListener('bdk-dashboard-theme-changed', themeChanged);

        sampleRealtime();
        realtimeTimer = window.setInterval(sampleRealtime, 5000);

        window.bdkJobsGraphState = { dispose };
    })();
</script>
