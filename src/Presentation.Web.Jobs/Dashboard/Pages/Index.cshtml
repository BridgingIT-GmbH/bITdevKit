@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@using JobsDashboardEndpoints = BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard.DashboardEndpoints
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = JobsDashboardEndpoints.BuildJobsDataContentPath(dashboardOptions);
}

<div class="d-flex justify-content-between align-items-center py-2 mb-2 border-bottom">
    <h4 class="m-0">Jobs</h4>
    <div class="d-flex align-items-center gap-2">
        <span id="jobs-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="jobs-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Jobs refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="jobs-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh jobs">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div id="dashboard-jobs-shell">
    @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Jobs.Dashboard.Pages.Content>())
</div>

<script>
    (() => {
        const contentUrl = '@contentPath';
        const storageKey = 'bdk.dashboard.jobs.refreshInterval';
        const shellElement = document.getElementById('dashboard-jobs-shell');
        const selectElement = document.getElementById('jobs-refresh-interval');
        const statusElement = document.getElementById('jobs-refresh-status');
        const refreshButton = document.getElementById('jobs-refresh-now');

        let timeoutId = null;
        let abortController = null;

        function getContentElement() {
            return shellElement?.querySelector('#dashboard-jobs-content') ?? null;
        }

        function getSelectedInterval() {
            const value = Number(selectElement.value);
            return Number.isFinite(value) && value > 0 ? value : null;
        }

        function setStatus(text, isError) {
            statusElement.textContent = text;
            statusElement.classList.toggle('text-danger', isError === true);
            statusElement.classList.toggle('text-muted', isError !== true);
        }

        function clearScheduledRefresh() {
            if (timeoutId !== null) {
                window.clearTimeout(timeoutId);
                timeoutId = null;
            }
        }

        function scheduleNextRefresh() {
            clearScheduledRefresh();
            const interval = getSelectedInterval();
            if (interval === null || document.hidden) {
                return;
            }
            timeoutId = window.setTimeout(() => refreshJobs(true), interval);
        }

        async function refreshJobs(scheduleAfter) {
            clearScheduledRefresh();

            const contentElement = getContentElement();
            if (!contentElement) {
                return;
            }

            if (abortController !== null) {
                abortController.abort();
            }
            abortController = new AbortController();

            try {
                const response = await fetch(contentUrl, {
                    headers: { 'X-Requested-With': 'fetch' },
                    signal: abortController.signal
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                contentElement.innerHTML = await response.text();

                window.bdkDashboard.clearRefreshError(contentElement);
                setStatus(`Updated ${new Date().toLocaleTimeString()}`, false);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    window.bdkDashboard.showRefreshError(contentElement);
                    setStatus('Refresh failed', true);
                }
            } finally {
                abortController = null;
                if (scheduleAfter) {
                    scheduleNextRefresh();
                }
            }
        }

        const savedInterval = localStorage.getItem(storageKey);
        if (savedInterval !== null) {
            selectElement.value = savedInterval;
        }

        selectElement.addEventListener('change', () => {
            localStorage.setItem(storageKey, selectElement.value);
            if (abortController !== null) {
                abortController.abort();
            }
            scheduleNextRefresh();
        });

        refreshButton.addEventListener('click', () => refreshJobs(false));

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                clearScheduledRefresh();
                return;
            }
            if (getSelectedInterval() !== null) {
                refreshJobs(true);
            }
        });

        scheduleNextRefresh();

        // Global action helper — called from inline buttons in Content.cshtml
        window.bdkJobsAction = async function(url) {
            const btn = document.activeElement;
            if (btn) {
                btn.disabled = true;
            }
            try {
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'fetch' }
                });
                if (!resp.ok) {
                    const txt = await resp.text().catch(() => `HTTP ${resp.status}`);
                    console.error('Job action failed:', txt);
                }
            } catch (err) {
                console.error('Job action error:', err);
            } finally {
                if (btn) {
                    btn.disabled = false;
                }
                await refreshJobs(false);
            }
        };
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Jobs" };
}
