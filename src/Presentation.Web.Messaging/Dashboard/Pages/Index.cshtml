@using MessagingDashboardEndpoints = BridgingIT.DevKit.Presentation.Web.Messaging.Dashboard.DashboardEndpoints
@using BridgingIT.DevKit.Application.Messaging
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = MessagingDashboardEndpoints.BuildMessagingContentPath(dashboardOptions);
    var actionBase = MessagingDashboardEndpoints.BuildMessagingActionBase(dashboardOptions);
    var aliveEnabled = this.HttpContext.RequestServices.GetService<MessagingAliveOptions>()?.Enabled == true;
}

<div class="d-flex justify-content-between align-items-center py-2 mb-2 border-bottom">
    <h4 class="m-0">Messaging</h4>
    <div class="d-flex align-items-center gap-2">
        @if (aliveEnabled)
        {
            <button type="button" class="btn btn-outline-primary btn-sm" title="Publish alive message" onclick="window.bdkMessagingAction('@($"{actionBase}/alive")')">
                <i class="bi bi-broadcast"></i>
            </button>
        }
        <span id="messaging-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="messaging-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Messaging refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="messaging-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh messaging">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div class="card mb-2">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-6 col-lg-2">
                <label class="form-label small mb-1" for="messaging-status-filter">Status</label>
                <select id="messaging-status-filter" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option>Pending</option>
                    <option>Processing</option>
                    <option>Succeeded</option>
                    <option>Failed</option>
                    <option>DeadLettered</option>
                    <option>Expired</option>
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label small mb-1" for="messaging-archive-filter">Archive</label>
                <select id="messaging-archive-filter" class="form-select form-select-sm">
                    <option value="active">Active</option>
                    <option value="archived">Archived</option>
                    <option value="all">All</option>
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label small mb-1" for="messaging-take-filter">Rows</label>
                <select id="messaging-take-filter" class="form-select form-select-sm">
                    <option>25</option>
                    <option selected>50</option>
                    <option>100</option>
                    <option>250</option>
                </select>
            </div>
            <div class="col-12 col-lg-2">
                <label class="form-label small mb-1" for="messaging-type-filter">Type</label>
                <input id="messaging-type-filter" class="form-control form-control-sm" placeholder="contains">
            </div>
            <div class="col-12 col-lg-2">
                <label class="form-label small mb-1" for="messaging-id-filter">Message Id</label>
                <input id="messaging-id-filter" class="form-control form-control-sm" placeholder="exact or contains">
            </div>
            <div class="col-12 col-lg-2 d-flex gap-2">
                <button type="button" id="messaging-filter-apply" class="btn btn-primary btn-sm flex-fill">Apply</button>
                <button type="button" id="messaging-filter-reset" class="btn btn-outline-secondary btn-sm">Reset</button>
            </div>
        </div>
    </div>
</div>

<div id="dashboard-messaging-shell">
    @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Messaging.Dashboard.Pages.Content>())
</div>

<script>
    (() => {
        const shellElement = document.getElementById('dashboard-messaging-shell');
        const resetButton = document.getElementById('messaging-filter-reset');

        function buildContentUrl() {
            const url = new URL('@contentPath', window.location.origin);
            const fields = [
                ['status', document.getElementById('messaging-status-filter')?.value],
                ['archive', document.getElementById('messaging-archive-filter')?.value],
                ['take', document.getElementById('messaging-take-filter')?.value],
                ['type', document.getElementById('messaging-type-filter')?.value],
                ['messageId', document.getElementById('messaging-id-filter')?.value],
            ];
            fields.forEach(([key, value]) => {
                if (value) {
                    url.searchParams.set(key, value);
                }
            });
            return url;
        }

        const refresher = window.bdkDashboard.createRefresher({
            buildUrl: buildContentUrl,
            contentSelector: () => shellElement?.querySelector('#dashboard-messaging-content') ?? null,
            statusSelector: '#messaging-refresh-status',
            intervalSelector: '#messaging-refresh-interval',
            refreshButtonSelector: '#messaging-refresh-now',
            storageKey: 'bdk.dashboard.messaging.refreshInterval'
        });

        document.getElementById('messaging-filter-apply').addEventListener('click', () => refresher.refresh(true));
        resetButton.addEventListener('click', () => {
            document.getElementById('messaging-status-filter').value = '';
            document.getElementById('messaging-archive-filter').value = 'active';
            document.getElementById('messaging-take-filter').value = '50';
            document.getElementById('messaging-type-filter').value = '';
            document.getElementById('messaging-id-filter').value = '';
            refresher.refresh(true);
        });

        window.bdkMessagingAction = async function(url) {
            await window.bdkDashboard.postAction(url, {
                refresh: refresher.refresh,
                errorMessage: 'Messaging action failed:'
            });
        };
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Messaging" };
}
