<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>BridgingIT.DevKit.Presentation.Web.Orchestrations</AssemblyName>
    <RootNamespace>BridgingIT.DevKit.Presentation.Web.Orchestrations</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RazorSlices" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Application.Orchestrations\Application.Orchestrations.csproj" />
    <ProjectReference Include="..\Common.Extensions.Web\Common.Extensions.Web.csproj" />
    <ProjectReference Include="..\Presentation.Web\Presentation.Web.csproj" />
  </ItemGroup>

</Project>
