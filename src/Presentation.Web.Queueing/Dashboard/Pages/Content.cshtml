@using QueueingDashboardEndpoints = BridgingIT.DevKit.Presentation.Web.Queueing.Dashboard.DashboardEndpoints
@inherits RazorSlice

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var realtimeDataPath = QueueingDashboardEndpoints.BuildQueueingRealtimeDataPath(dashboardOptions);
}

<style>
    #queueing-dashboard-root {
        height: calc(100vh - 14.25rem);
        min-height: 560px;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        overflow: hidden;
    }

    #queueing-dashboard-root > #dashboard-queueing-content {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        overflow: hidden;
    }

    #queueing-dashboard-root .queueing-data-zone {
        flex: 1 1 auto;
        min-height: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: .75rem;
        overflow: hidden;
    }

    #queueing-dashboard-root .queueing-panel {
        border: 1px solid var(--bs-border-color);
        border-radius: .375rem;
        background: var(--bs-body-bg);
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    #queueing-dashboard-root .queueing-panel-header {
        padding: .6rem .75rem;
        border-bottom: 1px solid var(--bs-border-color);
        font-weight: 600;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .5rem;
    }

    #queueing-dashboard-root .queueing-panel-body {
        min-height: 0;
        overflow: auto;
        padding: .25rem .5rem .5rem .5rem;
    }

    #queueing-dashboard-root .queueing-side-zone {
        min-height: 0;
        display: flex;
        flex-direction: column;
        gap: .75rem;
        overflow: hidden;
    }

    #queueing-dashboard-root .queueing-graph-zone {
        flex: 0 0 auto;
        border: 1px solid var(--bs-border-color);
        border-radius: .375rem;
        background: var(--bs-body-bg);
        min-height: 255px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #queueing-dashboard-root .queueing-graph-canvas {
        height: 220px;
        width: 100%;
    }

    @@media (min-width: 1400px) {
        #queueing-dashboard-root .queueing-data-zone {
            grid-template-columns: 1.35fr .75fr;
        }
    }
</style>

<div id="queueing-dashboard-root" data-realtime-url="@realtimeDataPath">
    <div id="dashboard-queueing-content">
        @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Queueing.Dashboard.Pages.Data>())
    </div>

    <section class="queueing-graph-zone">
        <div class="queueing-panel-header">
            <span>Queue Pressure</span>
            <span class="text-muted small">Realtime session</span>
        </div>
        <div class="queueing-graph-canvas" id="queueing-realtime-graph"></div>
    </section>
</div>

<script>
    (() => {
        const root = document.getElementById('queueing-dashboard-root');
        if (!root) {
            return;
        }

        if (window.bdkQueueingGraphState && typeof window.bdkQueueingGraphState.dispose === 'function') {
            window.bdkQueueingGraphState.dispose();
        }

        const realtimeUrl = root.getAttribute('data-realtime-url');
        const graphHost = document.getElementById('queueing-realtime-graph');
        const storageKey = 'bdk.dashboard.queueing.sessionId';
        const sessionId = getOrCreateSessionId();
        let disposed = false;
        let timer = null;
        const themeChanged = () => sample();

        function dispose() {
            disposed = true;
            if (timer !== null) {
                window.clearInterval(timer);
                timer = null;
            }
            document.removeEventListener('bdk-dashboard-theme-changed', themeChanged);
            if (window.Plotly && graphHost) {
                window.Plotly.purge(graphHost);
            }
        }

        function getOrCreateSessionId() {
            try {
                const existing = sessionStorage.getItem(storageKey);
                if (existing) {
                    return existing;
                }
                const created = crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
                sessionStorage.setItem(storageKey, created);
                return created;
            } catch {
                return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
            }
        }

        async function ensurePlotly() {
            return window.bdkDashboard.loadPlotly();
        }

        async function sample() {
            if (disposed || !graphHost || graphHost.clientWidth === 0) {
                return;
            }

            try {
                const url = new URL(realtimeUrl, window.location.origin);
                url.searchParams.set('sessionId', sessionId);
                url.searchParams.set('_', Date.now().toString());
                const response = await fetch(url.toString(), {
                    cache: 'no-store',
                    headers: { 'X-Requested-With': 'fetch' }
                });
                if (!response.ok) {
                    return;
                }

                const payload = await response.json();
                const samples = Array.isArray(payload.samples) ? payload.samples : [];
                const x = samples.map(sample => new Date(sample.timestampUtc));
                const Plotly = await ensurePlotly();
                const theme = window.bdkDashboard.getChartTheme();
                await Plotly.react(graphHost, [
                    { x, y: samples.map(s => s.pending ?? 0), name: 'Pending', mode: 'lines', line: { color: theme.primary, width: 2 }, type: 'scatter' },
                    { x, y: samples.map(s => s.waitingForHandler ?? 0), name: 'Waiting', mode: 'lines', line: { color: theme.secondary, width: 2 }, type: 'scatter' },
                    { x, y: samples.map(s => s.processing ?? 0), name: 'Processing', mode: 'lines', line: { color: theme.warning, width: 2 }, type: 'scatter' },
                    { x, y: samples.map(s => s.failed ?? 0), name: 'Failed', mode: 'lines', line: { color: theme.danger, width: 2 }, type: 'scatter' },
                    { x, y: samples.map(s => s.deadLettered ?? 0), name: 'Dead-lettered', mode: 'lines', line: { color: theme.accent, width: 2 }, type: 'scatter' },
                    { x, y: samples.map(s => s.openCircuits ?? 0), name: 'Open circuits', mode: 'lines', line: { color: theme.info, width: 2, dash: 'dot' }, type: 'scatter' }
                ], window.bdkDashboard.createPlotlyLayout(), {
                    displayModeBar: false,
                    responsive: true,
                    staticPlot: true
                });
            } catch {
                // best effort chart rendering
            }
        }

        sample();
        document.addEventListener('bdk-dashboard-theme-changed', themeChanged);
        timer = window.setInterval(sample, 5000);
        window.bdkQueueingGraphState = { dispose };
    })();
</script>
