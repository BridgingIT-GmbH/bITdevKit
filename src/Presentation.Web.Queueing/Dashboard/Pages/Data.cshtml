@using BridgingIT.DevKit.Application.Queueing
@using Microsoft.Extensions.Logging
@using QueueingDashboardEndpoints = BridgingIT.DevKit.Presentation.Web.Queueing.Dashboard.DashboardEndpoints
@using System.Text.Json
@inherits RazorSlice

@{
    var vm = await CreateModelAsync();
    var actionBase = vm.ActionBase;
}

@if (!vm.IsAvailable)
{
    <div class="alert alert-warning py-2 mb-0">
        Queueing is not registered. Call <code>AddQueueing()</code> to populate this page.
    </div>
}
else
{
    @if (vm.Errors.Count > 0)
    {
        <div class="alert alert-danger py-2 mb-2">
            @foreach (var error in vm.Errors)
            {
                <div>@error</div>
            }
        </div>
    }

    <div class="row g-2 queueing-card-grid">
        @RenderMetricCard("Total", vm.Stats.Total, null)
        @RenderMetricCard("Pending", vm.Stats.Pending, "text-info")
        @RenderMetricCard("Waiting", vm.Stats.WaitingForHandler, "text-warning")
        @RenderMetricCard("Processing", vm.Stats.Processing, "text-warning")
        @RenderMetricCard("Failed", vm.Stats.Failed, vm.Stats.Failed > 0 ? "text-danger" : null)
        @RenderMetricCard("Open circuits", vm.Stats.OpenCircuits?.Count ?? 0, vm.Stats.OpenCircuits?.Count > 0 ? "text-danger" : null)
    </div>

    <div class="queueing-data-zone">
        <section class="queueing-panel">
            <div class="queueing-panel-header">
                <span>Queue Messages</span>
                <span class="badge rounded-pill text-bg-secondary">@vm.Messages.Count</span>
            </div>
            <div class="queueing-panel-body">
            @if (vm.Messages.Count == 0)
            {
                <div class="text-muted small py-2">No queue messages matched the current filters.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Queue</th>
                                <th>Type</th>
                                <th>Message Id</th>
                                <th class="text-end">Attempts</th>
                                <th>Lease</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var message in vm.Messages)
                        {
                            vm.MessageContentById.TryGetValue(message.Id, out var content);
                            var retryUrl = $"{actionBase}/messages/{message.Id}/retry";
                            var archiveUrl = $"{actionBase}/messages/{message.Id}/archive";
                            <tr>
                                <td>
                                    @RenderStatusBadge(message.Status)
                                    @if (message.IsArchived)
                                    {
                                        <span class="badge text-bg-secondary ms-1">Archived</span>
                                    }
                                </td>
                                <td class="text-muted small" title="@FormatTimestamp(message.CreatedDate)">@FormatRelative(message.CreatedDate)</td>
                                <td>@DisplayValue(message.QueueName)</td>
                                <td title="@DisplayValue(message.Type)">@TrimValue(message.Type, 42)</td>
                                <td class="text-muted small" title="@DisplayValue(message.MessageId)">@TrimFromStart(message.MessageId, 24)</td>
                                <td class="text-end">@message.AttemptCount</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(message.LockedBy))
                                    {
                                        <span class="badge text-bg-warning" title="@($"{message.LockedBy} until {FormatTimestamp(message.LockedUntil)}")">Leased</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end text-nowrap">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            title="Show message details"
                                            data-queueing-message-context="@CreateMessageContext(message, content)">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                    @if (CanRetryMessage(message))
                                    {
                                        <button class="btn btn-sm btn-outline-warning ms-1" title="Retry message" onclick="window.bdkQueueingAction('@retryUrl')">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    }
                                    @if (CanArchiveMessage(message))
                                    {
                                        <button class="btn btn-sm btn-outline-secondary ms-1" title="Archive message" onclick="window.bdkQueueingAction('@archiveUrl')">
                                            <i class="bi bi-archive"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            </div>
        </section>

        <div class="queueing-side-zone">
            <section class="queueing-panel">
                <div class="queueing-panel-header">
                    <span>Subscriptions</span>
                    <span class="badge rounded-pill text-bg-secondary">@vm.Subscriptions.Count</span>
                </div>
                <div class="queueing-panel-body">
                @if (vm.Subscriptions.Count == 0)
                {
                    <div class="text-muted small py-2">No queue subscriptions are registered.</div>
                }
                else
                {
                    @foreach (var subscription in vm.Subscriptions)
                    {
                        var pauseQueueUrl = $"{actionBase}/queues/{Uri.EscapeDataString(subscription.QueueName)}/pause";
                        var resumeQueueUrl = $"{actionBase}/queues/{Uri.EscapeDataString(subscription.QueueName)}/resume";
                        var pauseTypeUrl = $"{actionBase}/types/{Uri.EscapeDataString(subscription.MessageType)}/pause";
                        var resumeTypeUrl = $"{actionBase}/types/{Uri.EscapeDataString(subscription.MessageType)}/resume";
                        var resetCircuitUrl = $"{actionBase}/types/{Uri.EscapeDataString(subscription.MessageType)}/circuit/reset";
                        <div class="border-bottom py-2">
                            <div class="fw-medium" title="@subscription.MessageType">@TrimValue(subscription.MessageType, 54)</div>
                            <div class="text-muted small">Queue: @DisplayValue(subscription.QueueName)</div>
                            <div class="text-muted small" title="@subscription.HandlerType">@TrimValue(subscription.HandlerType, 54)</div>
                            <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
                                @if (subscription.IsQueuePaused)
                                {
                                    <span class="badge text-bg-warning">Queue paused</span>
                                    <button class="btn btn-sm btn-outline-success" onclick="window.bdkQueueingAction('@resumeQueueUrl')">Resume queue</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" onclick="window.bdkQueueingAction('@pauseQueueUrl')">Pause queue</button>
                                }

                                @if (subscription.IsMessageTypePaused)
                                {
                                    <span class="badge text-bg-warning">Type paused</span>
                                    <button class="btn btn-sm btn-outline-success" onclick="window.bdkQueueingAction('@resumeTypeUrl')">Resume type</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning" onclick="window.bdkQueueingAction('@pauseTypeUrl')">Pause type</button>
                                }

                                <button class="btn btn-sm btn-outline-secondary" onclick="window.bdkQueueingAction('@resetCircuitUrl')">Reset circuit</button>
                            </div>
                        </div>
                    }
                }
                </div>
            </section>

            <section class="queueing-panel">
                <div class="queueing-panel-header">
                    <span>Waiting</span>
                    <span class="badge rounded-pill text-bg-secondary">@vm.WaitingMessages.Count</span>
                </div>
                <div class="queueing-panel-body">
                @if (vm.WaitingMessages.Count == 0)
                {
                    <div class="text-muted small py-2">No queue messages are waiting for handlers.</div>
                }
                else
                {
                    @foreach (var message in vm.WaitingMessages)
                    {
                        <div class="border-bottom py-2">
                            <div class="fw-medium" title="@message.Type">@TrimValue(message.Type, 54)</div>
                            <div class="text-muted small">Queue: @DisplayValue(message.QueueName)</div>
                            <div class="text-muted small">@TrimFromStart(message.MessageId, 28)</div>
                            <div class="text-muted small">@FormatRelative(message.CreatedDate)</div>
                        </div>
                    }
                }
                </div>
            </section>
        </div>
    </div>
}

@functions {
    private async Task<DashboardQueueingViewModel> CreateModelAsync()
    {
        var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
        var service = this.HttpContext.RequestServices.GetService<IQueueBrokerService>();
        var logger = this.HttpContext.RequestServices.GetService<ILogger<Data>>();
        var cancellationToken = this.HttpContext.RequestAborted;
        var model = new DashboardQueueingViewModel
        {
            ActionBase = QueueingDashboardEndpoints.BuildQueueingActionBase(dashboardOptions)
        };

        if (service is null)
        {
            model.IsAvailable = false;
            return model;
        }

        var status = TryParseEnum<QueueMessageStatus>(GetQuery("status"));
        var archive = GetArchiveFilter(GetQuery("archive"));
        var take = GetTake();
        var queue = GetQuery("queue");
        var type = GetQuery("type");

        try
        {
            model.Stats = await service.GetMessageStatsAsync(isArchived: archive, cancellationToken: cancellationToken);
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Queueing dashboard: stats failed.");
            model.Errors.Add("Queue message statistics could not be loaded.");
        }

        try
        {
            model.Summary = await service.GetSummaryAsync(cancellationToken);
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Queueing dashboard: summary failed.");
        }

        try
        {
            var messages = await service.GetMessagesAsync(
                status,
                type,
                queue,
                isArchived: archive,
                take: take,
                cancellationToken: cancellationToken);
            model.Messages = messages.OrderByDescending(message => message.CreatedDate).ToList();
            model.MessageContentById = await GetMessageContentsAsync(service, model.Messages, cancellationToken);
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Queueing dashboard: messages query failed.");
            model.Errors.Add("Queue messages could not be loaded.");
        }

        try
        {
            model.Subscriptions = (await service.GetSubscriptionsAsync(cancellationToken)).ToList();
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Queueing dashboard: subscriptions query failed.");
            model.Errors.Add("Subscriptions could not be loaded.");
        }

        try
        {
            model.WaitingMessages = (await service.GetWaitingMessagesAsync(25, cancellationToken)).ToList();
        }
        catch (Exception ex)
        {
            logger?.LogWarning(ex, "Queueing dashboard: waiting messages query failed.");
        }

        return model;
    }

    private static async Task<IReadOnlyDictionary<Guid, QueueMessageContentInfo>> GetMessageContentsAsync(
        IQueueBrokerService service,
        IReadOnlyList<QueueMessageInfo> messages,
        CancellationToken cancellationToken)
    {
        var result = new Dictionary<Guid, QueueMessageContentInfo>();
        foreach (var message in messages)
        {
            var content = await service.GetMessageContentAsync(message.Id, cancellationToken);
            if (content is not null)
            {
                result[message.Id] = content;
            }
        }

        return result;
    }

    private string GetQuery(string key) =>
        this.HttpContext.Request.Query.TryGetValue(key, out var value) ? value.ToString() : null;

    private int GetTake() =>
        int.TryParse(GetQuery("take"), NumberStyles.Integer, CultureInfo.InvariantCulture, out var take)
            ? Math.Clamp(take, 1, 500)
            : 50;

    private static TEnum? TryParseEnum<TEnum>(string value)
        where TEnum : struct =>
        Enum.TryParse<TEnum>(value, true, out var parsed) ? parsed : null;

    private static bool? GetArchiveFilter(string value) =>
        string.Equals(value, "all", StringComparison.OrdinalIgnoreCase) ? null :
        string.Equals(value, "archived", StringComparison.OrdinalIgnoreCase) ? true : false;

    private static Microsoft.AspNetCore.Html.IHtmlContent RenderMetricCard(string title, int value, string css)
    {
        var valueClass = string.IsNullOrWhiteSpace(css) ? "fs-4 fw-semibold" : $"fs-4 fw-semibold {css}";
        return new Microsoft.AspNetCore.Html.HtmlString($"""
            <div class="col-6 col-lg-2">
                <div class="card h-100">
                    <div class="card-body p-3">
                        <div class="text-muted small">{title}</div>
                        <div class="{valueClass}">{value.ToString("N0", CultureInfo.InvariantCulture)}</div>
                    </div>
                </div>
            </div>
            """);
    }

    private static Microsoft.AspNetCore.Html.IHtmlContent RenderStatusBadge(QueueMessageStatus status)
    {
        var css = status switch
        {
            QueueMessageStatus.Pending => "text-bg-info",
            QueueMessageStatus.WaitingForHandler => "text-bg-warning",
            QueueMessageStatus.Processing => "text-bg-warning",
            QueueMessageStatus.Succeeded => "text-bg-success",
            QueueMessageStatus.Failed => "text-bg-danger",
            QueueMessageStatus.DeadLettered => "text-bg-danger",
            QueueMessageStatus.Expired => "text-bg-secondary",
            _ => "text-bg-secondary"
        };

        return new Microsoft.AspNetCore.Html.HtmlString($"<span class=\"badge {css}\">{status}</span>");
    }

    private static bool CanRetryMessage(QueueMessageInfo message) =>
        !message.IsArchived && message.Status is QueueMessageStatus.Failed or QueueMessageStatus.DeadLettered or QueueMessageStatus.Expired or QueueMessageStatus.WaitingForHandler;

    private static bool CanArchiveMessage(QueueMessageInfo message) =>
        !message.IsArchived && message.Status is QueueMessageStatus.Succeeded or QueueMessageStatus.DeadLettered or QueueMessageStatus.Expired;

    private static string DisplayValue(string value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatTimestamp(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz", CultureInfo.InvariantCulture) ?? "-";

    private static string FormatRelative(DateTimeOffset? value)
    {
        if (value is null)
        {
            return "-";
        }

        var delta = DateTimeOffset.UtcNow - value.Value;
        var abs = delta.Duration();
        var suffix = delta.TotalSeconds >= 0 ? "ago" : "from now";
        if (abs.TotalMinutes < 1) return $"{Math.Max(1, (int)abs.TotalSeconds)}s {suffix}";
        if (abs.TotalHours < 1) return $"{(int)abs.TotalMinutes}m {suffix}";
        if (abs.TotalDays < 1) return $"{(int)abs.TotalHours}h {suffix}";
        return $"{(int)abs.TotalDays}d {suffix}";
    }

    private static string TrimValue(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= maxLength ? value : $"{value[..maxLength]}...";
    }

    private static string TrimFromStart(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= maxLength ? value : $"...{value[^maxLength..]}";
    }

    private static string CreateMessageContext(QueueMessageInfo message, QueueMessageContentInfo content)
    {
        var payload = new
        {
            id = message.Id,
            messageId = message.MessageId,
            queueName = message.QueueName,
            type = message.Type,
            status = message.Status.ToString(),
            isArchived = message.IsArchived,
            archivedDate = message.ArchivedDate,
            createdDate = message.CreatedDate,
            expiresOn = message.ExpiresOn,
            lockedBy = message.LockedBy,
            lockedUntil = message.LockedUntil,
            processingStartedDate = message.ProcessingStartedDate,
            processedDate = message.ProcessedDate,
            attemptCount = message.AttemptCount,
            registeredHandlerType = message.RegisteredHandlerType,
            lastError = message.LastError,
            contentHash = content?.ContentHash,
            content = content?.Content,
            properties = message.Properties?.ToDictionary(pair => pair.Key, pair => pair.Value?.ToString() ?? string.Empty) ?? new Dictionary<string, string>()
        };

        return JsonSerializer.Serialize(payload);
    }
}
