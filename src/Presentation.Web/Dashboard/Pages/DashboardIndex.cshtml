@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = DashboardPath.Combine(dashboardOptions.GroupPath, dashboardOptions.EndpointPaths.IndexContent);
}

<div class="d-flex justify-content-between align-items-center py-2 mb-2 border-bottom">
  <h4 class="m-0">Dashboard</h4>
  <div class="d-flex align-items-center gap-2">
      <span id="dashboard-index-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
      <select id="dashboard-index-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Dashboard card refresh interval">
          <option value="">Off</option>
          <option value="1000">1 sec</option>
          <option value="5000">5 sec</option>
          <option value="15000">15 sec</option>
          <option value="30000">30 sec</option>
      </select>
      <button type="button" id="dashboard-index-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh dashboard cards">
          <i class="bi bi-arrow-clockwise"></i>
      </button>
  </div>
</div>

<div id="dashboard-index-content">
    @(await RenderPartialAsync<DashboardIndexContent>())
</div>

<script>
    (() => {
        const contentUrl = '@contentPath';
        const storageKey = 'bdk.dashboard.index.refreshInterval';
        const contentElement = document.getElementById('dashboard-index-content');
        const selectElement = document.getElementById('dashboard-index-refresh-interval');
        const statusElement = document.getElementById('dashboard-index-refresh-status');
        const refreshButton = document.getElementById('dashboard-index-refresh-now');

        let timeoutId = null;
        let abortController = null;

        function getSelectedInterval() {
            const value = Number(selectElement.value);
            return Number.isFinite(value) && value > 0 ? value : null;
        }

        function setStatus(text, isError) {
            statusElement.textContent = text;
            statusElement.classList.toggle('text-danger', isError === true);
            statusElement.classList.toggle('text-muted', isError !== true);
        }

        function clearScheduledRefresh() {
            if (timeoutId !== null) {
                window.clearTimeout(timeoutId);
                timeoutId = null;
            }
        }

        function scheduleNextRefresh() {
            clearScheduledRefresh();

            const interval = getSelectedInterval();
            if (interval === null || document.hidden) {
                return;
            }

            timeoutId = window.setTimeout(() => refreshDashboardCards(true), interval);
        }

        async function refreshDashboardCards(scheduleAfter) {
            clearScheduledRefresh();

            if (abortController !== null) {
                abortController.abort();
            }

            abortController = new AbortController();

            try {
                const response = await fetch(contentUrl, {
                    headers: { 'X-Requested-With': 'fetch' },
                    signal: abortController.signal
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                contentElement.innerHTML = await response.text();
                setStatus(`Updated ${new Date().toLocaleTimeString()}`, false);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    setStatus('Refresh failed', true);
                }
            } finally {
                abortController = null;

                if (scheduleAfter) {
                    scheduleNextRefresh();
                }
            }
        }

        const savedInterval = localStorage.getItem(storageKey);
        if (savedInterval !== null) {
            selectElement.value = savedInterval;
        }

        selectElement.addEventListener('change', () => {
            localStorage.setItem(storageKey, selectElement.value);

            if (abortController !== null) {
                abortController.abort();
            }

            scheduleNextRefresh();
        });

        refreshButton.addEventListener('click', () => refreshDashboardCards(false));

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                clearScheduledRefresh();
                return;
            }

            if (getSelectedInterval() !== null) {
                refreshDashboardCards(true);
            }
        });

        scheduleNextRefresh();
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Dashboard" };
}
