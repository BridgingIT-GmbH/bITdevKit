@using BridgingIT.DevKit.Presentation.Web.Dashboard
@inherits RazorSlice

@{
    var cards = await this.HttpContext.GetDashboardPageCardsAsync();
    var groups = cards
        .OrderBy(card => card.GroupOrder)
        .ThenBy(card => card.Group, StringComparer.OrdinalIgnoreCase)
        .GroupBy(card => card.Group ?? "Dashboard")
        .ToArray();
}

@if (cards.Count == 0)
{
    <div class="alert alert-secondary py-2">
        No dashboard plugin cards are available.
    </div>
}
else
{
    @foreach (var group in groups)
    {
        <div class="mb-3">
            <h6 class="text-muted mb-2">@group.Key</h6>
            <div class="row g-2">
                @foreach (var card in group.OrderBy(card => card.Order).ThenBy(card => card.Title, StringComparer.OrdinalIgnoreCase))
                {
                    <div class="col-12 col-md-6 col-xl-4">
                        <a class="card h-100 text-decoration-none text-reset" href="@card.Url">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-start justify-content-between gap-2">
                                    <div class="min-w-0">
                                        <div class="text-muted small">@DisplayValue(card.Subtitle)</div>
                                        <h6 class="card-title mb-2">@card.Title</h6>
                                        @if (!string.IsNullOrWhiteSpace(card.Value))
                                        {
                                            <div class="fs-4 fw-semibold">@card.Value</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(card.Detail))
                                        {
                                            <div class="text-muted small text-truncate">@card.Detail</div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(card.Icon))
                                    {
                                        <i class="bi bi-@card.Icon fs-3 text-secondary"></i>
                                    }
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    }
}

@functions {
    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Plugin page" : value;
    }
}
