@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = CombinePath(dashboardOptions.GroupPath, dashboardOptions.EndpointPaths.MetricsContent);
}

<div class="d-flex justify-content-between align-items-center py-2 mb-2 border-bottom">
    <h4 class="m-0">Metrics</h4>
    <div class="d-flex align-items-center gap-2">
        <span id="metrics-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="metrics-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Metrics refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="metrics-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh metrics">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div id="dashboard-metrics-content">
    @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages.DashboardMetricsContent>())
</div>

<script>
    (() => {
        const contentUrl = '@contentPath';
        const storageKey = 'bdk.dashboard.metrics.refreshInterval';
        const contentElement = document.getElementById('dashboard-metrics-content');
        const selectElement = document.getElementById('metrics-refresh-interval');
        const statusElement = document.getElementById('metrics-refresh-status');
        const refreshButton = document.getElementById('metrics-refresh-now');

        let timeoutId = null;
        let abortController = null;

        function getSelectedInterval() {
            const value = Number(selectElement.value);
            return Number.isFinite(value) && value > 0 ? value : null;
        }

        function setStatus(text, isError) {
            statusElement.textContent = text;
            statusElement.classList.toggle('text-danger', isError === true);
            statusElement.classList.toggle('text-muted', isError !== true);
        }

        function clearScheduledRefresh() {
            if (timeoutId !== null) {
                window.clearTimeout(timeoutId);
                timeoutId = null;
            }
        }

        function scheduleNextRefresh() {
            clearScheduledRefresh();

            const interval = getSelectedInterval();
            if (interval === null || document.hidden) {
                return;
            }

            timeoutId = window.setTimeout(() => refreshMetrics(true), interval);
        }

        async function refreshMetrics(scheduleAfter) {
            clearScheduledRefresh();

            if (abortController !== null) {
                abortController.abort();
            }

            abortController = new AbortController();

            try {
                const response = await fetch(contentUrl, {
                    headers: { 'X-Requested-With': 'fetch' },
                    signal: abortController.signal
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                const activeTabTarget = contentElement.querySelector('.nav-link.active')?.getAttribute('data-bs-target');
                contentElement.innerHTML = await response.text();

                if (activeTabTarget !== null && activeTabTarget !== undefined) {
                    const activeTab = contentElement.querySelector(`[data-bs-target="${activeTabTarget}"]`);
                    if (activeTab !== null && window.bootstrap !== undefined) {
                        window.bootstrap.Tab.getOrCreateInstance(activeTab).show();
                    }
                }

                setStatus(`Updated ${new Date().toLocaleTimeString()}`, false);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    setStatus('Refresh failed', true);
                }
            } finally {
                abortController = null;

                if (scheduleAfter) {
                    scheduleNextRefresh();
                }
            }
        }

        const savedInterval = localStorage.getItem(storageKey);
        if (savedInterval !== null) {
            selectElement.value = savedInterval;
        }

        selectElement.addEventListener('change', () => {
            localStorage.setItem(storageKey, selectElement.value);

            if (abortController !== null) {
                abortController.abort();
            }

            scheduleNextRefresh();
        });

        refreshButton.addEventListener('click', () => refreshMetrics(false));

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                clearScheduledRefresh();
                return;
            }

            if (getSelectedInterval() !== null) {
                refreshMetrics(true);
            }
        });

        scheduleNextRefresh();
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Metrics" };

    private static string CombinePath(string groupPath, string endpointPath)
    {
        return $"/{(groupPath ?? string.Empty).Trim('/')}/{(endpointPath ?? string.Empty).Trim('/')}";
    }
}
