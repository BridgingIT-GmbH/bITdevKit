@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = DashboardPath.Combine(dashboardOptions.GroupPath, dashboardOptions.EndpointPaths.SystemContent);
}

<style>
    .dashboard-system-grid {
        display: grid;
        gap: .75rem;
        grid-template-columns: repeat(12, minmax(0, 1fr));
    }

    .dashboard-system-span-3 { grid-column: span 3; }
    .dashboard-system-span-4 { grid-column: span 4; }
    .dashboard-system-span-6 { grid-column: span 6; }
    .dashboard-system-span-8 { grid-column: span 8; }
    .dashboard-system-span-12 { grid-column: span 12; }

    .dashboard-system-kpi {
        min-height: 8.5rem;
    }

    .dashboard-system-label {
        color: var(--bs-secondary-color);
        font-size: .78rem;
        text-transform: uppercase;
    }

    .dashboard-system-value {
        font-size: clamp(1.5rem, 2vw, 2.25rem);
        font-weight: 650;
        line-height: 1.05;
    }

    .dashboard-system-subvalue {
        color: var(--bs-secondary-color);
        font-size: .84rem;
    }

    .dashboard-system-meter {
        background: rgba(var(--bs-secondary-rgb), .14);
        border-radius: 999px;
        height: .55rem;
        overflow: hidden;
    }

    .dashboard-system-meter > span {
        background: var(--bs-primary);
        display: block;
        height: 100%;
        width: var(--meter-value, 0%);
    }

    .dashboard-system-meter-success > span { background: var(--bs-success); }
    .dashboard-system-meter-warning > span { background: var(--bs-warning); }
    .dashboard-system-meter-danger > span { background: var(--bs-danger); }

    .dashboard-system-gauge {
        align-items: center;
        display: grid;
        grid-template-columns: 6.25rem 1fr;
        gap: .75rem;
    }

    .dashboard-system-gauge svg {
        height: 6.25rem;
        width: 6.25rem;
    }

    .dashboard-system-gauge-track {
        fill: none;
        stroke: rgba(var(--bs-secondary-rgb), .18);
        stroke-width: 10;
    }

    .dashboard-system-gauge-value {
        fill: none;
        stroke: var(--bs-primary);
        stroke-linecap: round;
        stroke-width: 10;
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
    }

    .dashboard-system-chart {
        border: 1px solid var(--bs-border-color);
        border-radius: .35rem;
        height: 9rem;
        overflow: hidden;
        width: 100%;
    }

    .dashboard-system-chart svg {
        display: block;
        height: 100%;
        width: 100%;
    }

    .dashboard-system-chart-grid {
        stroke: rgba(var(--bs-secondary-rgb), .18);
        stroke-width: 1;
    }

    .dashboard-system-chart-line {
        fill: none;
        stroke: var(--bs-primary);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 3;
    }

    .dashboard-system-chart-point {
        fill: var(--bs-primary);
        transition: opacity .15s ease;
    }

    .dashboard-system-statusbar {
        display: flex;
        height: .8rem;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(var(--bs-secondary-rgb), .14);
    }

    .dashboard-system-statusbar span {
        width: var(--segment-value, 0%);
    }

    .dashboard-system-chip {
        border: 1px solid var(--bs-border-color);
        border-radius: 999px;
        color: var(--bs-secondary-color);
        display: inline-flex;
        font-size: .8rem;
        gap: .35rem;
        padding: .25rem .5rem;
    }

    .dashboard-system-env-scroll {
        max-height: 28rem;
        overflow: auto;
    }

    .dashboard-system-env-table {
        table-layout: fixed;
    }

    .dashboard-system-env-table th:first-child,
    .dashboard-system-env-table td:first-child {
        width: clamp(16rem, 32%, 30rem);
    }

    .dashboard-system-env-key {
        font-family: var(--bs-font-monospace);
        font-size: .82rem;
        overflow-wrap: anywhere;
    }

    .dashboard-system-env-value {
        font-family: var(--bs-font-monospace);
        font-size: .82rem;
        overflow-wrap: anywhere;
        white-space: pre-wrap;
    }

    .dashboard-system-env-filter {
        max-width: 22rem;
        min-width: 16rem;
    }

    .dashboard-system-db-grid {
        display: grid;
        gap: .75rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    }

    .dashboard-system-db-heading {
        align-items: center;
        display: flex;
        gap: .7rem;
    }

    .dashboard-system-db-icon {
        align-items: center;
        background: rgba(var(--bs-primary-rgb), .12);
        border: 1px solid rgba(var(--bs-primary-rgb), .24);
        border-radius: .45rem;
        color: var(--bs-primary);
        display: inline-flex;
        height: 2.15rem;
        justify-content: center;
        width: 2.15rem;
    }

    .dashboard-system-db-summary {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        justify-content: flex-end;
    }

    .dashboard-system-db-pill {
        align-items: center;
        border: 1px solid var(--bs-border-color);
        border-radius: 999px;
        color: var(--bs-secondary-color);
        display: inline-flex;
        font-size: .78rem;
        gap: .35rem;
        padding: .25rem .55rem;
    }

    .dashboard-system-db-pill strong {
        color: var(--bs-body-color);
        font-weight: 650;
    }

    .dashboard-system-db-panel {
        border: 1px solid var(--bs-border-color);
        @* border-left: .25rem solid var(--bs-success); *@
        border-radius: .45rem;
        display: grid;
        gap: .85rem;
        padding: .95rem;
    }

    .dashboard-system-db-panel-unavailable {
        border-left-color: var(--bs-danger);
    }

    .dashboard-system-db-title {
        font-size: 1rem;
        font-weight: 650;
        line-height: 1.15;
    }

    .dashboard-system-db-provider {
        color: var(--bs-secondary-color);
        font-size: .78rem;
        margin-top: .1rem;
    }

    .dashboard-system-db-name {
        color: var(--bs-secondary-color);
        font-size: .82rem;
        overflow-wrap: anywhere;
    }

    .dashboard-system-db-status {
        align-items: center;
        border-radius: 999px;
        display: inline-flex;
        font-size: .74rem;
        font-weight: 650;
        gap: .35rem;
        padding: .27rem .6rem;
        white-space: nowrap;
    }

    .dashboard-system-db-status i {
        font-size: .65rem;
    }

    .dashboard-system-db-metrics {
        display: grid;
        gap: .45rem;
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .dashboard-system-db-metric {
        background: rgba(var(--bs-secondary-rgb), .045);
        border: 1px solid var(--bs-border-color);
        border-radius: .38rem;
        min-width: 0;
        padding: .55rem .65rem;
    }

    .dashboard-system-db-metric span {
        color: var(--bs-secondary-color);
        display: block;
        font-size: .72rem;
        line-height: 1.1;
    }

    .dashboard-system-db-metric strong {
        display: block;
        font-size: .95rem;
        font-weight: 650;
        line-height: 1.25;
        margin-top: .25rem;
        overflow-wrap: anywhere;
    }

    .dashboard-system-db-wide {
        grid-column: span 2;
    }

    .dashboard-system-db-alert {
        border: 1px solid rgba(var(--bs-danger-rgb), .35);
        border-radius: .38rem;
        color: var(--bs-danger);
        font-size: .82rem;
        padding: .55rem .65rem;
    }

    @@media (max-width: 1199.98px) {
        .dashboard-system-span-3,
        .dashboard-system-span-4,
        .dashboard-system-span-6,
        .dashboard-system-span-8 {
            grid-column: span 6;
        }
    }

    @@media (max-width: 767.98px) {
        .dashboard-system-grid {
            grid-template-columns: 1fr;
        }

        .dashboard-system-span-3,
        .dashboard-system-span-4,
        .dashboard-system-span-6,
        .dashboard-system-span-8,
        .dashboard-system-span-12 {
            grid-column: span 1;
        }

        .dashboard-system-db-metrics {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 459.98px) {
        .dashboard-system-db-summary {
            justify-content: flex-start;
            width: 100%;
        }

        .dashboard-system-db-metrics {
            grid-template-columns: 1fr;
        }

        .dashboard-system-db-wide {
            grid-column: span 1;
        }
    }
</style>

<div class="d-flex justify-content-end align-items-center py-2 mb-2 border-bottom">
    <div class="d-flex align-items-center gap-2">
        <span id="system-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="system-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="System refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="system-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh system metrics">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div id="dashboard-system-content">
    @(await RenderPartialAsync<SystemOverviewContent>())
</div>

<script>
    (() => {
        const storageKey = 'bdk.dashboard.system.samples';
        const maxSamples = 48;

        function readSamples() {
            try {
                const raw = localStorage.getItem(storageKey);
                return raw ? JSON.parse(raw) : [];
            } catch {
                return [];
            }
        }

        function writeSamples(samples) {
            localStorage.setItem(storageKey, JSON.stringify(samples.slice(-maxSamples)));
        }

        function numberFrom(element, name) {
            const value = Number(element?.dataset?.[name]);
            return Number.isFinite(value) ? value : 0;
        }

        function buildPoints(samples, key, maxValue) {
            if (samples.length === 0) {
                return '';
            }

            const width = 300;
            const height = 92;
            const max = Math.max(maxValue || 0, ...samples.map(item => Number(item[key]) || 0), 1);
            return samples.map((item, index) => {
                const x = samples.length === 1 ? width : (index / (samples.length - 1)) * width;
                const y = height - ((Number(item[key]) || 0) / max) * height;
                return `${x.toFixed(1)},${y.toFixed(1)}`;
            }).join(' ');
        }

        function drawChart(id, samples, key, maxValue) {
            const path = document.querySelector(`#${id} polyline[data-system-line]`);
            if (path) {
                path.setAttribute('points', buildPoints(samples, key, maxValue));
            }

            const point = document.querySelector(`#${id} circle[data-system-point]`);
            if (!point) {
                return;
            }

            if (samples.length !== 1) {
                point.setAttribute('opacity', '0');
                return;
            }

            const width = 300;
            const height = 92;
            const value = Number(samples[0][key]) || 0;
            const max = Math.max(maxValue || 0, value, 1);
            point.setAttribute('cx', (width / 2).toFixed(1));
            point.setAttribute('cy', (height - (value / max) * height).toFixed(1));
            point.setAttribute('opacity', '1');
        }

        function applyEnvironmentFilter(contentElement) {
            const filter = contentElement?.querySelector('[data-system-env-filter]');
            const rows = Array.from(contentElement?.querySelectorAll('[data-system-env-row]') || []);
            const count = contentElement?.querySelector('[data-system-env-count]');
            if (!filter || rows.length === 0) {
                return;
            }

            const query = filter.value.trim().toLowerCase();
            let visible = 0;

            rows.forEach(row => {
                const isMatch = !query || (row.dataset.systemEnvSearch || '').toLowerCase().includes(query);
                row.hidden = !isMatch;
                if (isMatch) {
                    visible++;
                }
            });

            if (count) {
                count.textContent = query
                    ? `${visible} of ${rows.length} variable(s)`
                    : `${rows.length} variable(s)`;
            }
        }

        function bindEnvironmentFilter(contentElement) {
            const filter = contentElement?.querySelector('[data-system-env-filter]');
            if (!filter) {
                return;
            }

            filter.value = sessionStorage.getItem('bdk.dashboard.system.envFilter') || '';
            filter.addEventListener('input', () => {
                sessionStorage.setItem('bdk.dashboard.system.envFilter', filter.value);
                applyEnvironmentFilter(contentElement);
            });
            applyEnvironmentFilter(contentElement);
        }

        window.bdkDashboard.updateSystemOverview = function(contentElement) {
            const snapshot = contentElement?.querySelector('.dashboard-system-snapshot');
            if (!snapshot) {
                return;
            }

            const samples = readSamples();
            const next = {
                capturedAt: snapshot.dataset.capturedAt,
                cpu: numberFrom(snapshot, 'cpu'),
                memory: numberFrom(snapshot, 'workingSet'),
                rpm: numberFrom(snapshot, 'requestsPerMinute'),
                latency: numberFrom(snapshot, 'averageLatency')
            };

            if (samples.length === 0 || samples[samples.length - 1].capturedAt !== next.capturedAt) {
                samples.push(next);
                writeSamples(samples);
            }

            const current = samples.slice(-maxSamples);
            drawChart('system-cpu-history', current, 'cpu', 100);
            drawChart('system-memory-history', current, 'memory');
            drawChart('system-request-history', current, 'rpm');
            drawChart('system-latency-history', current, 'latency');
            bindEnvironmentFilter(contentElement);
        };

        const refresher = window.bdkDashboard.createRefresher({
            contentUrl: '@contentPath',
            contentSelector: '#dashboard-system-content',
            statusSelector: '#system-refresh-status',
            intervalSelector: '#system-refresh-interval',
            refreshButtonSelector: '#system-refresh-now',
            storageKey: 'bdk.dashboard.system.refreshInterval',
            onSuccess: window.bdkDashboard.updateSystemOverview
        });

        window.bdkDashboard.updateSystemOverview(document.querySelector('#dashboard-system-content'));
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "System" };
}
