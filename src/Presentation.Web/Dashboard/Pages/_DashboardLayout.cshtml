            gap: .45rem !important;
            font-size: .72rem !important;
            padding: .18rem .55rem .38rem !important;
        }

        .dashboard-main [class$="-dot"] {
            border-radius: .1rem !important;
            height: .5rem !important;
            width: .5rem !important;
        }

        .dashboard-main .dashboard-system-meter,
        .dashboard-main .dashboard-system-statusbar,
        .dashboard-main .dashboard-system-chip,
        .dashboard-main .dashboard-system-db-pill,
        .dashboard-main .dashboard-system-db-status,
        .dashboard-main .dashboard-health-tag {
            border-radius: .1rem !important;
        }

        .dashboard-main .dashboard-system-chip,
        .dashboard-main .dashboard-system-db-pill,
        .dashboard-main .dashboard-health-tag {
            border-color: var(--dashboard-panel-border-hover) !important;
            padding: .16rem .36rem !important;
        }

        /* Theming */
        .btn {
            --bs-btn-border-radius: .1rem;
            font-weight: 650;
        }

        .btn-sm {
            --bs-btn-padding-y: .18rem;
            --bs-btn-padding-x: .4rem;
            --bs-btn-font-size: .74rem;
        }

        .btn-primary {
            background-color: var(--bs-primary);
            border-color: var(--bs-primary);
            color: #111;
        }

            .btn-primary:hover {
                background-color: var(--bs-secondary);
                border-color: var(--bs-secondary);
                color: #111;
            }

        .btn-outline-secondary {
            color: var(--bs-secondary);
            border-color: var(--bs-secondary);
        }

            .btn-outline-secondary:hover {
                background-color: var(--bs-secondary);
                border-color: var(--bs-secondary);
            }

        .btn-primary, .btn-outline-primary,
        .btn-secondary, .btn-outline-secondary,
        .btn-outline-success, .btn-outline-warning,
        .btn-outline-danger, .btn-outline-info {
            --bs-btn-border-radius: .1rem;
            --bs-btn-padding-y: .28rem;
            --bs-btn-padding-x: .55rem;
            --bs-btn-color: var(--bs-body-color);
            --bs-btn-border-color: var(--bs-primary);
            --bs-btn-hover-color: #111;
            --bs-btn-hover-bg: var(--bs-secondary);
            --bs-btn-hover-border-color: var(--bs-secondary);
            --bs-btn-active-color: #111;
            --bs-btn-active-bg: var(--bs-secondary);
            --bs-btn-active-border-color: var(--bs-secondary);
            --bs-btn-disabled-color: var(--bs-primary);
            --bs-btn-disabled-border-color: var(--bs-primary);
        }

        .btn-outline-success {
            --bs-btn-color: var(--bs-success);
            --bs-btn-border-color: var(--bs-success);
            --bs-btn-hover-bg: var(--bs-success);
            --bs-btn-hover-border-color: var(--bs-success);
            --bs-btn-active-bg: var(--bs-success);
            --bs-btn-active-border-color: var(--bs-success);
        }

        .btn-outline-warning {
            --bs-btn-color: var(--bs-warning);
            --bs-btn-border-color: var(--bs-warning);
            --bs-btn-hover-bg: var(--bs-warning);
            --bs-btn-hover-border-color: var(--bs-warning);
            --bs-btn-active-bg: var(--bs-warning);
            --bs-btn-active-border-color: var(--bs-warning);
        }

        .btn-outline-danger {
            --bs-btn-color: var(--bs-danger);
            --bs-btn-border-color: var(--bs-danger);
            --bs-btn-hover-bg: var(--bs-danger);
            --bs-btn-hover-border-color: var(--bs-danger);
            --bs-btn-active-bg: var(--bs-danger);
            --bs-btn-active-border-color: var(--bs-danger);
        }

        .form-control,
        .form-select {
            border-radius: .1rem;
            background-color: var(--dashboard-surface);
            border-color: var(--bs-border-color);
            padding-top: .28rem;
            padding-bottom: .28rem;
        }

        .form-control-sm,
        .form-select-sm {
            min-height: 1.75rem;
            padding-top: .18rem;
            padding-bottom: .18rem;
            font-size: .75rem;
        }

        .form-label {
            color: var(--bs-secondary-color);
            font-size: .68rem;
            letter-spacing: .04em;
            margin-bottom: .2rem;
            text-transform: uppercase;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--bs-primary);
            box-shadow: none;
        }

        .badge {
            --bs-badge-color: #fff;
            --bs-badge-bg: var(--bs-primary);
            border: 1px solid transparent;
            border-radius: .1rem;
            font-weight: 700;
        }

        .badge:not([class*="bg-"]):not([class*="text-bg-"]) {
            background-color: rgba(var(--bs-primary-rgb), .12) !important;
            border-color: rgba(var(--bs-primary-rgb), .35);
            color: var(--bs-primary);
        }

        .badge.bg-primary,
        .badge.text-bg-primary {
            background-color: rgba(var(--bs-primary-rgb), .14) !important;
            border-color: rgba(var(--bs-primary-rgb), .4);
            color: var(--bs-primary) !important;
        }

        .badge.bg-secondary,
        .badge.text-bg-secondary {
            background-color: rgba(var(--dashboard-border-rgb), .08) !important;
            border-color: var(--dashboard-panel-border-hover);
            color: var(--bs-secondary-color) !important;
        }

        .badge.bg-success,
        .badge.text-bg-success {
            background-color: rgba(var(--bs-success-rgb), .13) !important;
            border-color: rgba(var(--bs-success-rgb), .35);
            color: var(--bs-success) !important;
        }

        .badge.bg-warning,
        .badge.text-bg-warning {
            background-color: rgba(var(--bs-warning-rgb), .14) !important;
            border-color: rgba(var(--bs-warning-rgb), .4);
            color: var(--bs-warning) !important;
        }

        .badge.bg-danger,
        .badge.text-bg-danger {
            background-color: rgba(var(--bs-danger-rgb), .13) !important;
            border-color: rgba(var(--bs-danger-rgb), .35);
            color: var(--bs-danger) !important;
        }

        .badge.rounded-pill {
            border-radius: .1rem !important;
        }

        .alert {
            border-radius: .1rem;
            padding: .42rem .55rem;
        }

        .modal-content,
        .dropdown-menu,
        .list-group-item {
            border-radius: .1rem;
            background-color: var(--dashboard-surface);
            border-color: var(--bs-border-color);
        }

        [data-bs-theme="dark"] .btn-close,
        [data-bs-theme="catppuccin"] .btn-close,
        [data-bs-theme="darkforest"] .btn-close,
        [data-bs-theme="carbon"] .btn-close,
        [data-bs-theme="tokioknights"] .btn-close,
        [data-bs-theme="matrix"] .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        .modal-header,
        .modal-footer {
            padding: .55rem .7rem;
            border-color: var(--bs-border-color);
        }

        .modal-body {
            padding: .7rem;
        }

        .nav-tabs {
            border-color: var(--bs-border-color);
        }

        .nav-tabs .nav-link {
            border-radius: 0;
            color: var(--bs-secondary-color);
            padding: .32rem .55rem;
        }

        .nav-tabs .nav-link:hover {
            border-color: transparent;
            color: var(--bs-body-color);
        }

        .nav-tabs .nav-link.active {
            background: transparent;
            border-color: var(--bs-border-color) var(--bs-border-color) var(--bs-body-bg);
        }

        code,
        pre,
        kbd {
            color: #e6db74;
        }

        pre {
            background: var(--dashboard-code-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: .1rem;
            padding: .55rem;
        }

        a {
            color: var(--bs-primary);
        }

            a:hover {
                color: var(--bs-secondary);
            }

        .alert-primary {
            --bs-alert-color: var(--bs-primary);
            --bs-alert-bg: rgba(var(--bs-primary-rgb), 0.1);
            --bs-alert-border-color: rgba(var(--bs-primary-rgb), 0.2);
        }

        .progress {
            --bs-progress-bar-bg: var(--bs-primary);
        }

        .list-group-item.active {
            background-color: var(--bs-primary);
            border-color: var(--bs-primary);
        }

        .nav-tabs .nav-link.active {
            color: var(--bs-primary);
            border-color: var(--bs-primary);
        }
    </style>
</head>

<body>
    <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
        <div class="dashboard-navbar-heading">
            <a class="navbar-brand me-0 px-3" href="@dashboardHomePath" title="@dashboardTitle">@dashboardTitle</a>
            <div class="dashboard-navbar-title" title="@pageTitle">@pageTitle</div>
        </div>
        @if (!hideSideBar)
        {
            <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        }

        <div class="navbar-nav">
            <div class="nav-item text-nowrap d-flex align-items-center">
                <span id="dashboard-connection-indicator" class="badge rounded-pill text-bg-warning d-none me-2" title="Dashboard connection issue">
                    <i class="bi bi-wifi-off me-1"></i>Offline
                </span>
                <button class="btn dashboard-window-toggle" type="button" aria-label="Open current dashboard page in a new window" title="Open in new window">
                    <i class="bi bi-box-arrow-up-right"></i>
                </button>
                <div class="dropdown dashboard-theme-picker">
                    <button class="btn theme-toggle d-inline-flex align-items-center gap-2" type="button" aria-haspopup="true" aria-expanded="false" aria-label="Select dashboard theme">
                        <i class="bi bi-terminal"></i>
                        <span data-theme-label>Dark</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="dark"><span class="dashboard-theme-swatch" style="--theme-bg:#151414;--theme-swatch:#66d9ef;--theme-accent:#fd971f"></span>Dark</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="catppuccin"><span class="dashboard-theme-swatch" style="--theme-bg:#11111b;--theme-swatch:#89b4fa;--theme-accent:#f5c2e7"></span>Catppuccin</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="darkforest"><span class="dashboard-theme-swatch" style="--theme-bg:#07120d;--theme-swatch:#9ece6a;--theme-accent:#e0af68"></span>Darkforest</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="carbon"><span class="dashboard-theme-swatch" style="--theme-bg:#161616;--theme-swatch:#78a9ff;--theme-accent:#ff7eb6"></span>Carbon</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="tokioknights"><span class="dashboard-theme-swatch" style="--theme-bg:#0f1021;--theme-swatch:#7aa2f7;--theme-accent:#bb9af7"></span>Tokyo Night</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="matrix"><span class="dashboard-theme-swatch" style="--theme-bg:#020802;--theme-swatch:#00ff66;--theme-accent:#39ff14"></span>Matrix</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="light"><span class="dashboard-theme-swatch" style="--theme-bg:#f7f7f2;--theme-swatch:#0f62fe;--theme-accent:#8a3ffc"></span>Light</button></li>
                        <li><button class="dropdown-item d-flex align-items-center gap-2" type="button" data-theme-option="system"><span class="dashboard-theme-swatch" style="--theme-bg:#151414;--theme-swatch:#a59f99;--theme-accent:#f7f7f2"></span>System</button></li>
                    </ul>
                </div>
                <button class="btn dashboard-texture-toggle" type="button" aria-label="Toggle terminal texture" aria-pressed="false" title="Toggle terminal texture">
                    <i class="bi bi-grid-3x3-gap"></i>
                </button>
                @if (isAuthenticated)
                {
                    <form method="post" action="@signOutPath" class="m-0 ms-2">
                        <input type="hidden" name="returnUrl" value="@currentDashboardUrl" />
                        <button class="btn dashboard-signout-toggle" type="submit" aria-label="Sign out of dashboard" title="Sign out">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                }
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            @if (!hideSideBar)
            {
                var pageSidebarItems = new List<DashboardSidebarItem>();
                foreach (var page in this.HttpContext.GetDashboardPages().Where(page => page.ShowInSidebar))
                {
                    pageSidebarItems.Add(new DashboardSidebarItem(page.Title, page.Icon, page.Url)
                    {
                        Group = page.Group,
                        GroupOrder = page.GroupOrder,
                        Order = page.Order,
                        Tooltip = string.IsNullOrWhiteSpace(page.Tooltip) ? page.Description : page.Tooltip,
                        HasBadge = page.Badge is not null,
                        BadgeCount = page.Badge is null ? null : await page.Badge(this.HttpContext)
                    });
                }
                var customSidebarItems = this.HttpContext.RequestServices
                    .GetServices<IDashboardNavigationProvider>()
                    .SelectMany(provider => provider.GetItems(this.HttpContext))
                    .Where(item => item is not null);
                var sidebarItems = pageSidebarItems
                    .Concat(customSidebarItems)
                    .ToArray();

                @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardSideBar, DashboardSidebarItem[]>(
                    sidebarItems))
                @await RenderSectionAsync("nav-menu")
                <button class="btn sidebar-toggle d-none d-md-flex" type="button" aria-label="Toggle sidebar">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
            }

            <main class="dashboard-main @(hideSideBar ? "dashboard-main-full col-12" : "") px-md-4">
                <div class="@(!hideSideBar ? "container-fluid px-0" : "")">
                    @await RenderBodyAsync()
                </div>
            </main>
        </div>
    </div>

    <script>
        const themeManager = {
            themes: {
                light: 'light',
                dark: 'dark',
                catppuccin: 'catppuccin',
                darkforest: 'darkforest',
                carbon: 'carbon',
                tokioknights: 'tokioknights',
                matrix: 'matrix',
                system: 'system'
            },
            labels: {
                light: 'Light',
                dark: 'Dark',
                catppuccin: 'Catppuccin',
                darkforest: 'Darkforest',
                carbon: 'Carbon',
                tokioknights: 'Tokyo Night',
                matrix: 'Matrix',
                system: 'System'
            },

            initialize() {
                this.applyTheme(this.getCurrentTheme());
                this.setupSystemThemeListener();
                this.setupThemePicker();
            },

            getSystemTheme() {
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? this.themes.dark : this.themes.light;
            },

            getCurrentTheme() {
                const theme = localStorage.getItem('theme') || this.themes.dark;
                return Object.values(this.themes).includes(theme) ? theme : this.themes.dark;
            },

            applyTheme(theme) {
                const effectiveTheme = theme === this.themes.system ? this.getSystemTheme() : theme;
                document.documentElement.setAttribute('data-bs-theme', effectiveTheme);
                document.documentElement.setAttribute('data-dashboard-theme', theme);
                localStorage.setItem('theme', theme);
                this.updateThemePicker(theme);
                document.dispatchEvent(new CustomEvent('bdk-dashboard-theme-changed', {
                    detail: { theme, effectiveTheme }
                }));
            },

            setupSystemThemeListener() {
                window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
                    if (this.getCurrentTheme() === this.themes.system) {
                        this.applyTheme(this.themes.system);
                    }
                });
            },

            setupThemePicker() {
                const picker = document.querySelector('.dashboard-theme-picker');
                const toggle = picker?.querySelector('.theme-toggle');
                if (!picker || !toggle) {
                    return;
                }

                toggle.addEventListener('click', event => {
                    event.stopPropagation();
                    const isOpen = picker.classList.toggle('is-open');
                    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });

                document.querySelectorAll('[data-theme-option]').forEach(option => {
                    option.addEventListener('click', event => {
                        event.stopPropagation();
                        this.applyTheme(option.dataset.themeOption);
                        picker.classList.remove('is-open');
                        toggle.setAttribute('aria-expanded', 'false');
                    });
                });

                document.addEventListener('click', event => {
                    if (!picker.contains(event.target)) {
                        picker.classList.remove('is-open');
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                });

                document.addEventListener('keydown', event => {
                    if (event.key === 'Escape') {
                        picker.classList.remove('is-open');
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                });
            },

            updateThemePicker(theme) {
                const label = document.querySelector('[data-theme-label]');
                if (label) {
                    label.textContent = this.labels[theme] || this.labels.dark;
                }

                document.querySelectorAll('[data-theme-option]').forEach(option => {
                    const isActive = option.dataset.themeOption === theme;
                    option.classList.toggle('active', isActive);
                    option.setAttribute('aria-current', isActive ? 'true' : 'false');
                });
            }
        };

        function setupSidebarToggle() {
            const toggle = document.querySelector('.sidebar-toggle');
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('main');
            if (!toggle || !sidebar || !mainContent) {
                return;
            }

            const icon = toggle.querySelector('i');

            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isCollapsed) {
                sidebar.classList.add('sidebar-collapsed');
                mainContent.classList.add('expanded');
                toggle.classList.add('sidebar-toggle-collapsed');
                icon.classList.replace('bi-layout-sidebar', 'bi-layout-sidebar-inset');
            }

            syncSidebarTooltips();

            toggle.addEventListener('click', () => {
                sidebar.classList.toggle('sidebar-collapsed');
                mainContent.classList.toggle('expanded');
                toggle.classList.toggle('sidebar-toggle-collapsed');
                const isNowCollapsed = sidebar.classList.contains('sidebar-collapsed');
                localStorage.setItem('sidebarCollapsed', isNowCollapsed);

                if (isNowCollapsed) {
                    icon.classList.replace('bi-layout-sidebar', 'bi-layout-sidebar-inset');
                } else {
                    icon.classList.replace('bi-layout-sidebar-inset', 'bi-layout-sidebar');
                }

                applySidebarGroupState();
                syncSidebarTooltips();
            });
        }

        function getSidebarGroupState() {
            try {
                return JSON.parse(localStorage.getItem('dashboardSidebarGroups') || '{}') || {};
            } catch {
                return {};
            }
        }

        function setSidebarGroupState(state) {
            localStorage.setItem('dashboardSidebarGroups', JSON.stringify(state || {}));
        }

        function applySidebarGroupState() {
            const sidebar = document.querySelector('.sidebar');
            if (!sidebar) {
                return;
            }

            const state = getSidebarGroupState();
            const sidebarIsCollapsed = sidebar.classList.contains('sidebar-collapsed');

            sidebar.querySelectorAll('[data-sidebar-group]').forEach(group => {
                const key = group.dataset.sidebarGroupKey;
                const toggle = group.querySelector('[data-sidebar-group-toggle]');
                const items = group.querySelector('[data-sidebar-group-items]');
                if (!toggle || !items) {
                    return;
                }

                const expanded = sidebarIsCollapsed || state[key] !== false;
                toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                items.hidden = !expanded;
            });
        }

        function setupSidebarGroups() {
            const sidebar = document.querySelector('.sidebar');
            if (!sidebar) {
                return;
            }

            applySidebarGroupState();

            sidebar.addEventListener('click', event => {
                const toggle = event.target.closest('[data-sidebar-group-toggle]');
                if (!toggle || sidebar.classList.contains('sidebar-collapsed')) {
                    return;
                }

                const group = toggle.closest('[data-sidebar-group]');
                const items = group?.querySelector('[data-sidebar-group-items]');
                if (!group || !items) {
                    return;
                }

                const key = group.dataset.sidebarGroupKey;
                const expanded = toggle.getAttribute('aria-expanded') === 'true';
                const state = getSidebarGroupState();
                state[key] = !expanded;
                setSidebarGroupState(state);
                applySidebarGroupState();
            });
        }

        function setupTooltips() {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(element => {
                bootstrap.Tooltip.getOrCreateInstance(element, {
                    trigger: 'hover focus',
                    container: 'body'
                });
            });
            syncSidebarTooltips();
        }

        function setupTextureToggle() {
            const toggle = document.querySelector('.dashboard-texture-toggle');
            if (!toggle) {
                return;
            }

            const applyTexture = enabled => {
                document.documentElement.setAttribute('data-dashboard-texture', enabled ? 'on' : 'off');
                localStorage.setItem('dashboardTexture', enabled ? 'true' : 'false');
                toggle.setAttribute('aria-pressed', enabled ? 'true' : 'false');
            };

            applyTexture(localStorage.getItem('dashboardTexture') === 'true');
            toggle.addEventListener('click', () => {
                applyTexture(document.documentElement.getAttribute('data-dashboard-texture') !== 'on');
            });
        }

        function setupDashboardWindowToggle() {
            const toggle = document.querySelector('.dashboard-window-toggle');
            if (!toggle) {
                return;
            }

            toggle.addEventListener('click', () => {
                const url = new URL(window.location.href);
                url.searchParams.set('dashboardView', 'window');
                const popup = window.open(
                    url.toString(),
                    '_blank',
                    'popup=yes,width=1280,height=900,resizable=yes,scrollbars=yes,noopener'
                );
                popup?.focus();
            });
        }

        function setupDashboardDatePickers() {
            document.addEventListener('click', event => {
                const button = event.target.closest('[data-dashboard-date-picker-button]');
                if (!button) {
                    return;
                }

                const targetId = button.getAttribute('data-dashboard-date-picker-button');
                const input = (targetId ? document.getElementById(targetId) : null)
                    || button.closest('.input-group')?.querySelector('input[type="date"]');
                if (!input) {
                    return;
                }

                if (typeof input.showPicker === 'function') {
                    input.showPicker();
                    return;
                }

                input.focus();
            });
        }

        function syncSidebarTooltips() {
            const sidebar = document.querySelector('.sidebar');
            if (!sidebar) {
                return;
            }

            const enabled = sidebar.classList.contains('sidebar-collapsed');
            sidebar.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(element => {
                const tooltip = bootstrap.Tooltip.getOrCreateInstance(element, {
                    trigger: 'hover focus',
                    container: 'body'
                });

                if (enabled) {
                    tooltip.enable();
                } else {
                    tooltip.hide();
                    tooltip.disable();
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            themeManager.initialize();
            setupTextureToggle();
            setupDashboardWindowToggle();
            setupDashboardDatePickers();
            setupSidebarToggle();
            setupSidebarGroups();
            setupTooltips();
            window.bdkDashboard.updateConnectionIndicator();
        });
    </script>
</body>
</html>
