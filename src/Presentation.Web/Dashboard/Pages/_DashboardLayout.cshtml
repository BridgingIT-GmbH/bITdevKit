@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using Microsoft.Extensions.DependencyInjection
@inherits RazorLayoutSlice<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages.DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var dashboardTitle = string.IsNullOrWhiteSpace(Model.ProductName) ? dashboardOptions.Title : Model.ProductName;
    var pageTitle = string.IsNullOrWhiteSpace(Model.Title) ? dashboardTitle : Model.Title;
    var detachedView = string.Equals(this.HttpContext.Request.Query["dashboardView"].ToString(), "window", StringComparison.OrdinalIgnoreCase);
    var hideSideBar = Model.HideSideBar || detachedView;
    var isAuthenticated = this.HttpContext.User?.Identity?.IsAuthenticated == true;
    var signOutPath = DashboardPath.Combine(dashboardOptions.GroupPath, dashboardOptions.EndpointPaths.SignOut);
    var dashboardHomePath = DashboardPath.Combine(this.HttpContext.Request.PathBase, dashboardOptions.GroupPath);
    var currentDashboardUrl = $"{this.HttpContext.Request.PathBase}{this.HttpContext.Request.Path}{this.HttpContext.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@dashboardTitle - @pageTitle</title>
    <base href="/" />
    <script>
        (function() { // prevents screen flashing on navigation
            const theme = localStorage.getItem('theme') || 'dark';
            const dashboardThemes = ['light', 'dark', 'catppuccin', 'darkforest', 'carbon', 'tokioknights', 'matrix', 'system'];
            const selectedTheme = dashboardThemes.includes(theme) ? theme : 'dark';
            const effectiveTheme = selectedTheme === 'system' ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : selectedTheme;
            document.documentElement.setAttribute('data-bs-theme', effectiveTheme);
            document.documentElement.setAttribute('data-dashboard-theme', selectedTheme);
            document.documentElement.setAttribute('data-dashboard-texture', localStorage.getItem('dashboardTexture') === 'true' ? 'on' : 'off');
        })();

        window.bdkDashboard = window.bdkDashboard || {};
        window.bdkDashboard.refreshErrors = window.bdkDashboard.refreshErrors || new Set();
        window.bdkDashboard.updateConnectionIndicator = function() {
            const indicator = document.getElementById('dashboard-connection-indicator');
            if (!indicator) {
                return;
            }

            const hasErrors = window.bdkDashboard.refreshErrors.size > 0;
            indicator.classList.toggle('d-none', !hasErrors);
        };
        window.bdkDashboard.showRefreshError = function(contentElement, message) {
            if (contentElement === null || contentElement === undefined) {
                return;
            }

            const id = `${contentElement.id || 'dashboard-content'}-refresh-error`;
            window.bdkDashboard.refreshErrors.add(id);
            window.bdkDashboard.updateConnectionIndicator();
        };

        window.bdkDashboard.clearRefreshError = function(contentElement) {
            if (contentElement === null || contentElement === undefined) {
                return;
            }

            window.bdkDashboard.refreshErrors.delete(`${contentElement.id || 'dashboard-content'}-refresh-error`);
            window.bdkDashboard.updateConnectionIndicator();
        };

        window.bdkDashboard.assets = window.bdkDashboard.assets || {
            plotly: 'https://cdn.plot.ly/plotly-2.35.2.min.js'
        };

        window.bdkDashboard.loadedScripts = window.bdkDashboard.loadedScripts || {};
        window.bdkDashboard.loadScriptOnce = function(key, src) {
            if (window.bdkDashboard.loadedScripts[key]) {
                return window.bdkDashboard.loadedScripts[key];
            }

            window.bdkDashboard.loadedScripts[key] = new Promise((resolve, reject) => {
                const existing = document.querySelector(`script[data-bdk-script="${key}"]`);
                if (existing) {
                    existing.addEventListener('load', () => resolve(existing), { once: true });
                    existing.addEventListener('error', () => reject(new Error(`Failed to load ${src}.`)), { once: true });
                    return;
                }

                const script = document.createElement('script');
                script.src = src;
                script.async = true;
                script.dataset.bdkScript = key;
                script.onload = () => resolve(script);
                script.onerror = () => reject(new Error(`Failed to load ${src}.`));
                document.head.appendChild(script);
            });

            return window.bdkDashboard.loadedScripts[key];
        };

        window.bdkDashboard.loadPlotly = async function() {
            if (window.Plotly) {
                return window.Plotly;
            }

            await window.bdkDashboard.loadScriptOnce('plotly', window.bdkDashboard.assets.plotly);
            return window.Plotly;
        };

        window.bdkDashboard.getCssValue = function(name, fallback) {
            const value = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
            return value || fallback;
        };

        window.bdkDashboard.getChartTheme = function() {
            const css = window.bdkDashboard.getCssValue;
            return {
                text: css('--bs-body-color', '#f8f8f2'),
                muted: css('--bs-secondary-color', '#a59f99'),
                grid: css('--dashboard-panel-border', 'rgba(248,248,242,.16)'),
                primary: css('--bs-primary', '#66d9ef'),
                secondary: css('--bs-secondary', '#fd971f'),
                success: css('--bs-success', '#a6e22e'),
                info: css('--bs-info', '#66d9ef'),
                warning: css('--bs-warning', '#fd971f'),
                danger: css('--bs-danger', '#f92672'),
                accent: css('--dashboard-active-fg', css('--bs-secondary', '#fd971f')),
                quiet: css('--bs-secondary-color', '#a59f99')
            };
        };

        window.bdkDashboard.createPlotlyLayout = function(options) {
            const settings = options || {};
            const theme = window.bdkDashboard.getChartTheme();

            return {
                margin: settings.margin || { l: 36, r: 16, t: 16, b: 28 },
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(0,0,0,0)',
                font: { color: theme.muted, size: 11 },
                xaxis: {
                    showgrid: settings.xGrid === true,
                    zeroline: false,
                    gridcolor: theme.grid,
                    color: theme.muted
                },
                yaxis: {
                    rangemode: 'tozero',
                    showgrid: settings.yGrid !== false,
                    gridcolor: theme.grid,
                    zeroline: false,
                    color: theme.muted
                },
                legend: settings.legend || { orientation: 'h', x: 0, y: -0.2 },
                showlegend: settings.showlegend,
                dragmode: false
            };
        };

        window.bdkDashboard.resolveElement = function(value) {
            if (typeof value === 'function') {
                return value();
            }

            if (typeof value === 'string') {
                return document.querySelector(value);
            }

            return value || null;
        };

        window.bdkDashboard.createRefresher = function(options) {
            const settings = options || {};
            const selectElement = window.bdkDashboard.resolveElement(settings.intervalSelector || settings.intervalElement);
            const statusElement = window.bdkDashboard.resolveElement(settings.statusSelector || settings.statusElement);
            const refreshButton = window.bdkDashboard.resolveElement(settings.refreshButtonSelector || settings.refreshButton);
            const cacheBust = settings.cacheBust !== false;

            let timeoutId = null;
            let abortController = null;

            function getContentElement() {
                return window.bdkDashboard.resolveElement(settings.contentSelector || settings.contentElement);
            }

            function getSelectedInterval() {
                if (!selectElement) {
                    return null;
                }

                const value = Number(selectElement.value);
                return Number.isFinite(value) && value > 0 ? value : null;
            }

            function setStatus(text, isError) {
                if (!statusElement) {
                    return;
                }

                statusElement.textContent = text;
                statusElement.classList.toggle('text-danger', isError === true);
                statusElement.classList.toggle('text-muted', isError !== true);
            }

            function clearScheduledRefresh() {
                if (timeoutId !== null) {
                    window.clearTimeout(timeoutId);
                    timeoutId = null;
                }
            }

            function buildUrl() {
                const rawUrl = typeof settings.buildUrl === 'function'
                    ? settings.buildUrl()
                    : settings.contentUrl;

                const url = rawUrl instanceof URL
                    ? rawUrl
                    : new URL(rawUrl, window.location.origin);

                if (cacheBust) {
                    url.searchParams.set('_', Date.now().toString());
                }

                return url.toString();
            }

            function restoreActiveTab(contentElement, activeTabTarget) {
                if (!settings.preserveActiveTab || activeTabTarget === null || activeTabTarget === undefined) {
                    return;
                }

                const activeTab = contentElement.querySelector(`[data-bs-target="${activeTabTarget}"]`);
                if (activeTab !== null && window.bootstrap !== undefined) {
                    window.bootstrap.Tab.getOrCreateInstance(activeTab).show();
                }
            }

            function scheduleNextRefresh() {
                clearScheduledRefresh();
                const interval = getSelectedInterval();
                if (interval === null || document.hidden) {
                    return;
                }

                timeoutId = window.setTimeout(() => refresh(true), interval);
            }

            async function refresh(scheduleAfter = true) {
                clearScheduledRefresh();

                if (typeof settings.shouldRefresh === 'function' && settings.shouldRefresh() === false) {
                    if (scheduleAfter) {
                        scheduleNextRefresh();
                    }

                    return;
                }

                const contentElement = getContentElement();
                if (!contentElement) {
                    if (scheduleAfter) {
                        scheduleNextRefresh();
                    }

                    return;
                }

                if (abortController !== null) {
                    abortController.abort();
                }

                abortController = new AbortController();

                try {
                    const activeTabTarget = settings.preserveActiveTab
                        ? contentElement.querySelector('.nav-link.active')?.getAttribute('data-bs-target')
                        : null;
                    const response = await fetch(buildUrl(), {
                        cache: 'no-store',
                        headers: { 'X-Requested-With': 'fetch' },
                        signal: abortController.signal
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    contentElement.innerHTML = await response.text();
                    restoreActiveTab(contentElement, activeTabTarget);

                    if (typeof settings.onSuccess === 'function') {
                        settings.onSuccess(contentElement);
                    }

                    window.bdkDashboard.clearRefreshError(contentElement);
                    setStatus(`Updated ${new Date().toLocaleTimeString()}`, false);
                } catch (error) {
                    if (error.name !== 'AbortError') {
                        window.bdkDashboard.showRefreshError(contentElement);
                        setStatus(settings.errorText || 'Refresh failed', true);
                    }
                } finally {
                    abortController = null;
                    if (scheduleAfter) {
                        scheduleNextRefresh();
                    }
                }
            }

            if (selectElement && settings.storageKey) {
                const savedInterval = localStorage.getItem(settings.storageKey);
                if (savedInterval !== null) {
                    selectElement.value = savedInterval;
                }

                selectElement.addEventListener('change', () => {
                    localStorage.setItem(settings.storageKey, selectElement.value);

                    if (abortController !== null) {
                        abortController.abort();
                    }

                    scheduleNextRefresh();
                });
            }

            if (refreshButton) {
                refreshButton.addEventListener('click', () => refresh(true));
            }

            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    clearScheduledRefresh();
                    return;
                }

                if (getSelectedInterval() !== null) {
                    refresh(true);
                }
            });

            scheduleNextRefresh();

            return {
                refresh,
                schedule: scheduleNextRefresh,
                clear: clearScheduledRefresh,
                getSelectedInterval
            };
        };

        window.bdkDashboard.postAction = async function(url, options) {
            const settings = options || {};
            const button = settings.button || document.activeElement;
            if (button) {
                button.disabled = true;
            }

            try {
                const response = await fetch(url, {
                    method: settings.method || 'POST',
                    headers: { 'X-Requested-With': 'fetch' }
                });

                if (!response.ok) {
                    console.error(settings.errorMessage || 'Dashboard action failed:', await response.text().catch(() => response.statusText));
                }
            } catch (error) {
                console.error(settings.errorMessage || 'Dashboard action error:', error);
            } finally {
                if (button) {
                    button.disabled = false;
                }

                if (settings.refresh) {
                    await settings.refresh(true);
                }
            }
        };
    </script>
