@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@inherits RazorSlice<DashboardSidebarItem[]>

<nav id="sidebarMenu" class="d-md-block sidebar collapse">
    <div class="sidebar-sticky">
        @{
            var groups = Model
                .OrderBy(item => item.GroupOrder)
                .ThenBy(item => item.Group, StringComparer.OrdinalIgnoreCase)
                .GroupBy(item => item.Group ?? "Dashboard")
                .ToArray();
            var requestPath = this.HttpContext.Request.Path.Value?.TrimEnd('/') ?? string.Empty;
            var activeItem = Model
                .Where(item => IsPathMatch(requestPath, item.Url))
                .OrderByDescending(item => item.Url.Split('?')[0].TrimEnd('/').Length)
                .FirstOrDefault();
        }

        @for (var groupIndex = 0; groupIndex < groups.Length; groupIndex++)
        {
            var group = groups[groupIndex];
            var groupId = $"dashboard-sidebar-group-{groupIndex}";
            var groupKey = $"{group.Key}:{group.First().GroupOrder}";
            <section class="dashboard-sidebar-group @(groupIndex > 0 ? "border-top" : "")"
                     data-sidebar-group
                     data-sidebar-group-key="@groupKey">
            <button type="button"
                    class="sidebar-heading dashboard-sidebar-group-toggle"
                    data-sidebar-group-toggle
                    aria-expanded="true"
                    aria-controls="@groupId">
                <span>@group.Key</span>
                <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </button>
            <ul id="@groupId" class="nav flex-column dashboard-sidebar-group-items" data-sidebar-group-items>
            @foreach (var item in group.OrderBy(item => item.Order).ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase))
            {
                var isActive = ReferenceEquals(item, activeItem);
                var tooltip = string.IsNullOrWhiteSpace(item.Tooltip) ? item.Title : item.Tooltip;
                <li class="nav-item">
                    <a class="nav-link @(isActive ? "active" : "")" href="@item.Url" aria-label="@tooltip" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="@tooltip">
                        <i class="bi bi-@(item.Icon) me-2"></i>
                        <span class="nav-link-title">@item.Title</span>
                        @if (item.HasBadge && item.BadgeCount.HasValue)
                        {
                            <span class="badge rounded-pill bg-primary ms-2">@item.BadgeCount</span>
                        }
                    </a>
                </li>
            }
            </ul>
            </section>
        }
    </div>
</nav>

@functions {
    private static bool IsPathMatch(string requestPath, string itemUrl)
    {
        var itemPath = itemUrl.Split('?')[0].TrimEnd('/');
        return string.Equals(requestPath, itemPath, StringComparison.OrdinalIgnoreCase)
            || (itemPath.Count(ch => ch == '/') > 2 && requestPath.StartsWith($"{itemPath}/", StringComparison.OrdinalIgnoreCase));
    }
}
