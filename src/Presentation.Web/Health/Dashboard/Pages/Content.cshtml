@using BridgingIT.DevKit.Presentation.Web
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Diagnostics.HealthChecks
@using RazorSlices
@using System.Globalization
@inherits RazorSlice

@{
    var healthModel = await CreateModelAsync();
}

@if (!healthModel.IsHealthCheckServiceRegistered)
{
    <div class="alert alert-warning py-2 mb-2">
        Health checks unavailable: register health checks with <code>AddHealthChecks()</code> to populate this page.
    </div>
}

@if (healthModel.Errors.Count > 0)
{
    <div class="alert alert-danger py-2 mb-2">
        @foreach (var error in healthModel.Errors)
        {
            <div>@error</div>
        }
    </div>
}

<div class="row g-2 mb-2">
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Overall Status</div>
                <div class="fs-4 fw-semibold @GetStatusTextClass(healthModel.Status)">@healthModel.StatusText</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Checks</div>
                <div class="fs-4 fw-semibold">@healthModel.Entries.Count</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Unhealthy</div>
                <div class="fs-4 fw-semibold text-danger">@healthModel.UnhealthyCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body p-3">
                <div class="text-muted small">Duration</div>
                <div class="fs-4 fw-semibold">@FormatDuration(healthModel.TotalDuration)</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title mb-0">Registered Health Checks</h6>
            <span class="badge @GetStatusBadgeClass(healthModel.Status)">@healthModel.StatusText</span>
        </div>

        @if (healthModel.Entries.Count == 0)
        {
            <div class="text-muted small">No health check entries are available.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Tags</th>
                        <th class="text-end">Duration</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var entry in healthModel.Entries.OrderBy(entry => entry.Status).ThenBy(entry => entry.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <tr>
                            <td class="text-break">
                                <div class="fw-semibold">@entry.Name</div>
                                @if (!string.IsNullOrWhiteSpace(entry.Exception))
                                {
                                    <div class="text-danger small text-break">@entry.Exception</div>
                                }
                            </td>
                            <td><span class="badge @GetStatusBadgeClass(entry.Status)">@entry.Status</span></td>
                            <td class="text-break">@DisplayValue(entry.Description)</td>
                            <td class="text-break">@DisplayTags(entry.Tags)</td>
                            <td class="text-end text-nowrap">@FormatDuration(entry.Duration)</td>
                        </tr>
                        @if (entry.Data.Count > 0)
                        {
                            <tr>
                                <td></td>
                                <td colspan="4">
                                    <div class="small text-muted">
                                        @foreach (var item in entry.Data)
                                        {
                                            <span class="me-3"><code>@item.Key</code>: @DisplayValue(item.Value)</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private async Task<DashboardHealthViewModel> CreateModelAsync()
    {
        var healthCheckService = this.HttpContext.RequestServices.GetService<HealthCheckService>();
        var result = new DashboardHealthViewModel
        {
            CapturedAtUtc = DateTimeOffset.UtcNow,
            IsHealthCheckServiceRegistered = healthCheckService is not null
        };

        if (healthCheckService is null)
        {
            return result;
        }

        try
        {
            var report = await healthCheckService.CheckHealthAsync(this.HttpContext.RequestAborted);
            result.Status = report.Status;
            result.TotalDuration = report.TotalDuration;
            result.Entries.AddRange(report.Entries.Select(entry => new DashboardHealthEntryViewModel
            {
                Name = entry.Key,
                Status = entry.Value.Status,
                Description = entry.Value.Description,
                Duration = entry.Value.Duration,
                Exception = entry.Value.Exception?.Message,
                Tags = entry.Value.Tags?.ToArray() ?? [],
                Data = entry.Value.Data.ToDictionary(item => item.Key, item => item.Value?.ToString())
            }));
        }
        catch (OperationCanceledException) when (this.HttpContext.RequestAborted.IsCancellationRequested)
        {
            throw;
        }
        catch (Exception ex)
        {
            result.Status = HealthStatus.Unhealthy;
            result.Errors.Add(ex.Message);
        }

        return result;
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayTags(IReadOnlyCollection<string> tags)
    {
        return tags is null || tags.Count == 0 ? "-" : string.Join(", ", tags);
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration.TotalMilliseconds < 1000
            ? $"{duration.TotalMilliseconds.ToString("N0", CultureInfo.InvariantCulture)} ms"
            : $"{duration.TotalSeconds.ToString("N2", CultureInfo.InvariantCulture)} s";
    }

    private static string GetStatusBadgeClass(HealthStatus status)
    {
        return status switch
        {
            HealthStatus.Healthy => "bg-success",
            HealthStatus.Degraded => "bg-warning text-dark",
            HealthStatus.Unhealthy => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private static string GetStatusTextClass(HealthStatus status)
    {
        return status switch
        {
            HealthStatus.Healthy => "text-success",
            HealthStatus.Degraded => "text-warning",
            HealthStatus.Unhealthy => "text-danger",
            _ => string.Empty
        };
    }

    private sealed class DashboardHealthViewModel
    {
        public DateTimeOffset CapturedAtUtc { get; init; }

        public bool IsHealthCheckServiceRegistered { get; init; }

        public HealthStatus Status { get; set; }

        public string StatusText => this.IsHealthCheckServiceRegistered ? this.Status.ToString() : "Unavailable";

        public TimeSpan TotalDuration { get; set; }

        public List<DashboardHealthEntryViewModel> Entries { get; } = [];

        public List<string> Errors { get; } = [];

        public int UnhealthyCount => this.Entries.Count(entry => entry.Status == HealthStatus.Unhealthy);
    }

    private sealed class DashboardHealthEntryViewModel
    {
        public string Name { get; init; }

        public HealthStatus Status { get; init; }

        public string Description { get; init; }

        public TimeSpan Duration { get; init; }

        public string Exception { get; init; }

        public IReadOnlyCollection<string> Tags { get; init; } = [];

        public Dictionary<string, string> Data { get; init; } = [];
    }
}
