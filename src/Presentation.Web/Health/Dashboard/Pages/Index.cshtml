@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using BridgingIT.DevKit.Presentation.Web.Health.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Health.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@using System.Globalization
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = BridgingIT.DevKit.Presentation.Web.Health.Dashboard.DashboardEndpoints.BuildHealthContentPath(dashboardOptions);
}

<style>
    .dashboard-health-checks {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
        gap: .75rem;
    }

    .dashboard-health-card {
        min-height: 12rem;
        overflow: hidden;
    }

    .dashboard-health-card-status {
        border-left: .25rem solid var(--bs-secondary);
    }

    .dashboard-health-card-status-healthy {
        border-left-color: var(--bs-success);
    }

    .dashboard-health-card-status-degraded {
        border-left-color: var(--bs-warning);
    }

    .dashboard-health-card-status-unhealthy {
        border-left-color: var(--bs-danger);
    }

    .dashboard-health-card-name {
        overflow-wrap: anywhere;
    }

    .dashboard-health-tags,
    .dashboard-health-data {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
    }

    .dashboard-health-tag {
        border: 1px solid var(--bs-border-color);
        border-radius: 999px;
        color: var(--bs-secondary-color);
        font-size: .75rem;
        line-height: 1;
        padding: .25rem .45rem;
    }

    .dashboard-health-data-item {
        border: 1px solid var(--bs-border-color);
        border-radius: .35rem;
        color: var(--bs-secondary-color);
        font-size: .78rem;
        line-height: 1.35;
        max-width: 100%;
        overflow-wrap: anywhere;
        padding: .25rem .4rem;
    }

    .dashboard-health-data-item code {
        color: var(--bs-pink);
        font-size: inherit;
    }

    @@media (max-width: 575.98px) {
        .dashboard-health-checks {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="d-flex justify-content-end align-items-center py-2 mb-2 border-bottom">
    <div class="d-flex align-items-center gap-2">
        <span id="health-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="health-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Health refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="health-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh health checks">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div id="dashboard-health-content">
    @(await RenderPartialAsync<Content>())
</div>

<script>
    (() => {
        window.bdkDashboard.createRefresher({
            contentUrl: '@contentPath',
            contentSelector: '#dashboard-health-content',
            statusSelector: '#health-refresh-status',
            intervalSelector: '#health-refresh-interval',
            refreshButtonSelector: '#health-refresh-now',
            storageKey: 'bdk.dashboard.health.refreshInterval'
        });
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Health" };

}
