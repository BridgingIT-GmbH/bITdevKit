@using BridgingIT.DevKit.Application.Utilities
@using BridgingIT.DevKit.Presentation.Web.Logging.Dashboard
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Logging
@using RazorSlices
@inherits RazorSlice

@{
    var model = await CreateModelAsync();
}

@if (!model.IsServiceRegistered)
{
    <div class="alert alert-warning py-2 mb-2">
        Log entries unavailable: register <code>ILogEntryService</code> to populate this page.
    </div>
}

@if (model.Errors.Count > 0)
{
    <div class="alert alert-danger py-2 mb-2">
        @foreach (var error in model.Errors)
        {
            <div>@error</div>
        }
    </div>
}

<div class="row g-2 mb-2">
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Shown</div><div class="fs-4 fw-semibold">@(model.Response.Items.Count)</div></div></div></div>
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Debug</div><div class="fs-4 fw-semibold">@LevelCount(model.Statistics, LogLevel.Debug)</div></div></div></div>
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Information</div><div class="fs-4 fw-semibold">@LevelCount(model.Statistics, LogLevel.Information)</div></div></div></div>
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Warning</div><div class="fs-4 fw-semibold text-warning">@LevelCount(model.Statistics, LogLevel.Warning)</div></div></div></div>
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Error</div><div class="fs-4 fw-semibold text-danger">@LevelCount(model.Statistics, LogLevel.Error)</div></div></div></div>
    <div class="col-6 col-lg-2"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Fatal</div><div class="fs-4 fw-semibold text-danger">@LevelCount(model.Statistics, LogLevel.Critical)</div></div></div></div>
</div>

<div class="card">
    <div class="card-body p-2">
        @if (model.Response.Items.Count == 0)
        {
            <div class="text-muted small p-2">No log entries matched the current filters.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th class="dashboard-logentries-toggle-column"></th>
                        <th>Time</th>
                        <th>Level</th>
                        <th>Message</th>
                        <th>Correlation</th>
                        <th>Module</th>
                    </tr>
                    </thead>
                    <tbody id="logentries-table-body">
                        @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.Pages.Rows>())
                    </tbody>
                </table>
            </div>
        }

        <div class="d-flex justify-content-center py-2">
            @if (!string.IsNullOrWhiteSpace(model.Response.ContinuationToken))
            {
                <button type="button" class="btn btn-outline-secondary btn-sm" data-logentries-load-more data-continuation-token="@(model.Response.ContinuationToken)">Load more</button>
            }
        </div>
    </div>
</div>

@functions {
    private async Task<LogEntriesContentModel> CreateModelAsync()
    {
        var service = this.HttpContext.RequestServices.GetService<ILogEntryService>();
        var result = new LogEntriesContentModel { IsServiceRegistered = service is not null };
        if (service is null)
        {
            return result;
        }

        var filter = LogEntriesDashboard.CreateFilter(this.HttpContext);

        try
        {
            result.Response = await service.QueryAsync(LogEntriesDashboard.CreateRequest(filter), this.HttpContext.RequestAborted);
        }
        catch (Exception ex)
        {
            result.Errors.Add(ex.Message);
        }

        try
        {
            result.Statistics = await service.GetStatisticsAsync(filter.StartTime, filter.EndTime, null, this.HttpContext.RequestAborted);
        }
        catch
        {
            result.Statistics = new LogEntryStatisticsModel();
        }

        return result;
    }

    private static int LevelCount(LogEntryStatisticsModel model, LogLevel level)
    {
        return model?.LevelCounts.TryGetValue(level, out var count) == true ? count : 0;
    }

    private sealed class LogEntriesContentModel
    {
        public bool IsServiceRegistered { get; init; }

        public LogEntryQueryResponse Response { get; set; } = new();

        public LogEntryStatisticsModel Statistics { get; set; } = new();

        public List<string> Errors { get; } = [];
    }
}
