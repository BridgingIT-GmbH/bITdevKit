@using BridgingIT.DevKit.Application.Utilities
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Logging.Dashboard
@using Microsoft.AspNetCore.Html
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Logging
@using RazorSlices
@using System.Text.Encodings.Web
@inherits RazorSlice

@{
    var model = await CreateModelAsync();
    var filter = LogEntriesDashboard.CreateFilter(this.HttpContext);
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var logEntriesPath = BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.DashboardEndpoints.BuildLogEntriesPath(dashboardOptions);
}

<style>
    details[data-error-item] > summary {
        cursor: pointer;
        list-style: none;
    }

    details[data-error-item] > summary::-webkit-details-marker {
        display: none;
    }

    details[data-error-item] .dashboard-error-chevron {
        transition: transform .12s ease-in-out;
    }

    details[data-error-item][open] .dashboard-error-chevron {
        transform: rotate(90deg);
    }
</style>

@if (!model.IsServiceRegistered)
{
    <div class="alert alert-warning py-2 mb-2">
        Errors unavailable: register <code>ILogEntryService</code> to populate this page.
    </div>
}

@if (model.Errors.Count > 0)
{
    <div class="alert alert-danger py-2 mb-2">
        @foreach (var error in model.Errors)
        {
            <div>@error</div>
        }
    </div>
}

<div class="row g-2 mb-2">
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Shown</div><div class="fs-4 fw-semibold">@(model.Items.Count)</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Errors</div><div class="fs-4 fw-semibold text-danger">@LevelCount(model.Statistics, LogLevel.Error)</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Fatal</div><div class="fs-4 fw-semibold text-danger">@LevelCount(model.Statistics, LogLevel.Critical)</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body p-3"><div class="text-muted small">Related lookups</div><div class="fs-4 fw-semibold">@(model.RelatedLookupCount)</div></div></div></div>
</div>

@if (model.Items.Count == 0)
{
    <div class="card">
        <div class="card-body p-3">
            <div class="text-muted small">No error entries matched the current filters.</div>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-2" data-error-list>
        @foreach (var item in model.Items)
        {
            var entry = item.Entry;
            <details class="card" data-error-item data-log-id="@entry.Id">
                <summary class="card-body p-3">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <i class="bi bi-chevron-right dashboard-error-chevron" aria-hidden="true"></i>
                        <span class="badge @LogEntriesDashboard.GetLevelBadgeClass(entry.Level)">@LogEntriesDashboard.DisplayLevel(entry.Level)</span>
                        <span class="text-nowrap" title="@LogEntriesDashboard.FormatTimestamp(entry.TimeStamp)">@LogEntriesDashboard.FormatTimestamp(entry.TimeStamp)</span>
                        <span class="text-break flex-grow-1">@LogEntriesDashboard.DisplayValue(entry.Message)</span>
                    </div>
                </summary>
                <div class="border-top p-3">
                    <div class="row g-2">
                        <div class="col-12 col-xl-7">
                            <h6 class="mb-2">Details</h6>
                            <table class="table table-sm align-middle mb-2">
                                <tbody>
                                <tr><td class="text-muted">Id</td><td class="text-break">@entry.Id</td></tr>
                                <tr><td class="text-muted">Type</td><td class="text-break">@LogEntriesDashboard.DisplayValue(entry.ShortTypeName)</td></tr>
                                <tr><td class="text-muted">Thread</td><td class="text-break">@LogEntriesDashboard.DisplayValue(entry.ThreadId)</td></tr>
                                </tbody>
                            </table>

                            @if (!string.IsNullOrWhiteSpace(entry.Exception))
                            {
                                <h6 class="mb-2">Exception</h6>
                                <pre class="small text-danger mb-2">@entry.Exception</pre>
                            }

                            @if (entry.LogEvents?.Count > 0)
                            {
                                <h6 class="mb-2">Properties</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <tbody>
                                        @foreach (var property in entry.LogEvents.OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <tr>
                                                <td class="text-muted text-nowrap">@property.Key</td>
                                                <td class="text-break">@property.Value</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                        <div class="col-12 col-xl-5">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0">Related Logs</h6>
                                <span class="badge">@item.Related.Items.Count</span>
                            </div>
                            <div class="d-flex flex-wrap align-items-center gap-2 small mb-2">
                                @RenderLogEntriesLink(logEntriesPath, filter, "correlationId", "Correlation", entry.CorrelationId)
                                @RenderLogEntriesLink(logEntriesPath, filter, "traceId", "Trace", entry.TraceId)
                                @RenderLogEntriesLink(logEntriesPath, filter, "spanId", "Span", entry.SpanId)
                                @RenderLogEntriesLink(logEntriesPath, filter, "moduleName", "Module", entry.ModuleName)
                            </div>
                            @if (item.Related.Items.Count == 0)
                            {
                                <div class="text-muted small">No related logs found.</div>
                            }
                            else
                            {
                                <div class="list-group list-group-flush">
                                    @foreach (var related in item.Related.Items)
                                    {
                                        <div class="list-group-item px-0">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-nowrap" title="@LogEntriesDashboard.FormatTimestamp(related.TimeStamp)">@LogEntriesDashboard.FormatShortTimestamp(related.TimeStamp)</span>
                                                <span class="badge @LogEntriesDashboard.GetLevelBadgeClass(related.Level)">@LogEntriesDashboard.DisplayLevel(related.Level)</span>
                                            </div>
                                            <div class="text-break mt-1">@LogEntriesDashboard.DisplayValue(related.Message)</div>
                                            @if (!string.IsNullOrWhiteSpace(related.Exception))
                                            {
                                                <details class="small text-danger mt-1">
                                                    <summary>Exception</summary>
                                                    <pre class="mb-0">@related.Exception</pre>
                                                </details>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </details>
        }
    </div>
}

<div class="d-flex justify-content-center py-2">
    @if (!string.IsNullOrWhiteSpace(model.ContinuationToken))
    {
        <button type="button" class="btn btn-outline-secondary btn-sm" data-errors-load-more data-continuation-token="@(model.ContinuationToken)">Load more</button>
    }
</div>

@functions {
    private const int RelatedLogPageSize = 25;

    private async Task<ErrorsContentModel> CreateModelAsync()
    {
        var service = this.HttpContext.RequestServices.GetService<ILogEntryService>();
        var result = new ErrorsContentModel { IsServiceRegistered = service is not null };
        if (service is null)
        {
            return result;
        }

        var filter = LogEntriesDashboard.CreateFilter(this.HttpContext);
        var request = LogEntriesDashboard.CreateRequest(filter);
        request.Level = LogLevel.Error;

        try
        {
            var response = await service.QueryAsync(request, this.HttpContext.RequestAborted);
            result.ContinuationToken = response.ContinuationToken;
            result.Items.AddRange(await CreateErrorItemsAsync(service, filter, response.Items));
            result.RelatedLookupCount = result.Items.Select(item => item.Related.CacheKey).Where(key => key is not null).Distinct(StringComparer.Ordinal).Count();
        }
        catch (Exception ex)
        {
            result.Errors.Add(ex.Message);
        }

        try
        {
            result.Statistics = await service.GetStatisticsAsync(filter.StartTime, filter.EndTime, null, this.HttpContext.RequestAborted);
        }
        catch
        {
            result.Statistics = new LogEntryStatisticsModel();
        }

        return result;
    }

    private async Task<List<ErrorLogItem>> CreateErrorItemsAsync(
        ILogEntryService service,
        LogEntriesDashboardFilter filter,
        IReadOnlyList<LogEntryModel> entries)
    {
        var relatedLogs = new Dictionary<string, RelatedLogModel>(StringComparer.Ordinal);
        var result = new List<ErrorLogItem>();

        foreach (var entry in entries)
        {
            var descriptor = CreateRelatedDescriptor(entry);
            if (descriptor.CacheKey is null)
            {
                result.Add(new ErrorLogItem(entry, new RelatedLogModel(null, [])));
                continue;
            }

            if (!relatedLogs.TryGetValue(descriptor.CacheKey, out var related))
            {
                related = await QueryRelatedAsync(service, filter, entry.Id, descriptor);
                relatedLogs[descriptor.CacheKey] = related;
            }

            result.Add(new ErrorLogItem(entry, related));
        }

        return result;
    }

    private async Task<RelatedLogModel> QueryRelatedAsync(
        ILogEntryService service,
        LogEntriesDashboardFilter filter,
        long currentId,
        RelatedLogDescriptor descriptor)
    {
        var request = new LogEntryQueryRequest
        {
            StartTime = filter.StartTime,
            EndTime = filter.EndTime,
            PageSize = RelatedLogPageSize,
            CorrelationId = descriptor.FilterName == "correlationId" ? descriptor.Value : null,
            TraceId = descriptor.FilterName == "traceId" ? descriptor.Value : null,
            SpanId = descriptor.FilterName == "spanId" ? descriptor.Value : null
        };

        var response = await service.QueryAsync(request, this.HttpContext.RequestAborted);
        var items = response.Items
            .Where(log => log.Id != currentId)
            .ToArray();

        return new RelatedLogModel(descriptor.CacheKey, items);
    }

    private static RelatedLogDescriptor CreateRelatedDescriptor(LogEntryModel entry)
    {
        if (!string.IsNullOrWhiteSpace(entry.CorrelationId))
        {
            return new RelatedLogDescriptor("CorrelationId", "correlationId", entry.CorrelationId);
        }

        if (!string.IsNullOrWhiteSpace(entry.TraceId))
        {
            return new RelatedLogDescriptor("TraceId", "traceId", entry.TraceId);
        }

        if (!string.IsNullOrWhiteSpace(entry.SpanId))
        {
            return new RelatedLogDescriptor("SpanId", "spanId", entry.SpanId);
        }

        return new RelatedLogDescriptor(null, null, null);
    }

    private static int LevelCount(LogEntryStatisticsModel model, LogLevel level)
    {
        return model?.LevelCounts.TryGetValue(level, out var count) == true ? count : 0;
    }

    private static IHtmlContent RenderLogEntriesLink(
        string path,
        LogEntriesDashboardFilter source,
        string name,
        string label,
        string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new HtmlString($"""<span class="text-muted">{label}: -</span>""");
        }

        var target = new LogEntriesDashboardFilter
        {
            Level = null,
            PageSize = source.PageSize,
            StartTime = source.StartTime,
            EndTime = source.EndTime,
            CorrelationId = string.Equals(name, "correlationId", StringComparison.Ordinal) ? value : null,
            TraceId = string.Equals(name, "traceId", StringComparison.Ordinal) ? value : null,
            SpanId = string.Equals(name, "spanId", StringComparison.Ordinal) ? value : null,
            ModuleName = string.Equals(name, "moduleName", StringComparison.Ordinal) ? value : null
        };

        var href = $"{path}{LogEntriesDashboard.BuildQuery(target)}";
        return new HtmlString($"""
            <a class="btn btn-link btn-sm p-0 text-decoration-none" href="{HtmlEncoder.Default.Encode(href)}">{HtmlEncoder.Default.Encode(label)}: {HtmlEncoder.Default.Encode(LogEntriesDashboard.ShortId(value))}</a>
            """);
    }

    private sealed class ErrorsContentModel
    {
        public bool IsServiceRegistered { get; init; }

        public List<ErrorLogItem> Items { get; } = [];

        public LogEntryStatisticsModel Statistics { get; set; } = new();

        public string ContinuationToken { get; set; }

        public int RelatedLookupCount { get; set; }

        public List<string> Errors { get; } = [];
    }

    private sealed record ErrorLogItem(LogEntryModel Entry, RelatedLogModel Related);

    private sealed record RelatedLogDescriptor(string Label, string FilterName, string Value)
    {
        public string CacheKey => string.IsNullOrWhiteSpace(this.FilterName) || string.IsNullOrWhiteSpace(this.Value)
            ? null
            : $"{this.FilterName}:{this.Value}";
    }

    private sealed record RelatedLogModel(string CacheKey, IReadOnlyList<LogEntryModel> Items);
}
