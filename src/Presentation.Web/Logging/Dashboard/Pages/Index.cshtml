@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using BridgingIT.DevKit.Presentation.Web.Logging.Dashboard
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@using System.Globalization
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.DashboardEndpoints.BuildLogEntriesContentPath(dashboardOptions);
    var rowsPath = BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.DashboardEndpoints.BuildLogEntriesRowsPath(dashboardOptions);
    var exportPath = BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.DashboardEndpoints.BuildLogEntriesExportPath(dashboardOptions);
    var purgePath = BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.DashboardEndpoints.BuildLogEntriesPurgePath(dashboardOptions);
    var filter = LogEntriesDashboard.CreateFilter(this.HttpContext);
}

<style>
    .dashboard-logentries-toggle-column {
        width: 1.75rem;
    }

    .dashboard-logentries-toggle-cell {
        text-align: center;
        width: 1.75rem;
    }

    .dashboard-logentries-toggle i {
        display: inline-block;
        transition: transform .12s ease;
    }

    .dashboard-logentries-toggle[aria-expanded="true"] i {
        transform: rotate(90deg);
    }

    .dashboard-logentry-details-cell {
        background: color-mix(in srgb, var(--bs-body-bg) 92%, var(--bs-body-color) 8%);
        border-top: 0;
        padding: .75rem 1rem;
    }

    .dashboard-logentry-details {
        display: grid;
        gap: .75rem 1rem;
        grid-template-columns: minmax(16rem, .9fr) minmax(20rem, 1.1fr);
    }

    .dashboard-logentry-detail-block {
        grid-column: 1 / -1;
    }

    .dashboard-logentry-details-title {
        color: var(--bs-secondary-color);
        font-size: .75rem;
        font-weight: 600;
        margin-bottom: .4rem;
        text-transform: uppercase;
    }

    .dashboard-logentry-details-list {
        display: grid;
        grid-template-columns: max-content minmax(0, 1fr);
        margin: 0;
    }

    .dashboard-logentry-details-list dt,
    .dashboard-logentry-details-list dd {
        border-bottom: 1px solid var(--bs-border-color);
        margin: 0;
        padding: .28rem .4rem;
    }

    .dashboard-logentry-details-list dt {
        color: var(--bs-secondary-color);
        font-weight: 500;
        white-space: nowrap;
    }

    .dashboard-logentry-details-list dd {
        overflow-wrap: anywhere;
    }

    .dashboard-logentry-properties {
        max-height: 18rem;
        overflow: auto;
    }

    .dashboard-logentry-pre {
        border: 1px solid var(--bs-border-color);
        border-radius: .35rem;
        font-size: .78rem;
        margin: 0;
        max-height: 18rem;
        overflow: auto;
        padding: .5rem;
        white-space: pre-wrap;
    }

    @@media (max-width: 991.98px) {
        .dashboard-logentry-details {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="d-flex justify-content-end align-items-center py-2 mb-2 border-bottom">
    <div class="d-flex align-items-center gap-2">
        <div class="form-check form-switch m-0">
            <input id="logentries-tail" class="form-check-input" type="checkbox" role="switch">
            <label class="form-check-label small" for="logentries-tail">Tail</label>
        </div>
        <span id="logentries-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <a id="logentries-export" class="btn btn-outline-secondary btn-sm" href="@(exportPath + LogEntriesDashboard.BuildQuery(filter))" title="Export filtered log entries">
            <i class="bi bi-download"></i>
        </a>
        <button type="button" id="logentries-purge" class="btn btn-outline-danger btn-sm" title="Purge log entries">
            <i class="bi bi-trash3"></i>
        </button>
        <button type="button" id="logentries-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh log entries">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<form id="logentries-filter-form" class="card mb-2" method="get">
    <div class="card-body p-3">
        <div class="row g-2">
            <div class="col-12 col-lg-3">
                <label class="form-label small" for="logentries-q">Search</label>
                <input id="logentries-q" name="q" value="@filter.SearchText" class="form-control form-control-sm" placeholder="message, trace, span, correlation, module">
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label small" for="logentries-level">Minimum level</label>
                <select id="logentries-level" name="level" class="form-select form-select-sm">
                    @if (filter.Level is null)
                    {
                        <option value="All" selected>All levels</option>
                    }
                    else
                    {
                        <option value="All">All levels</option>
                    }
                    @foreach (var level in new[] { "Trace", "Debug", "Information", "Warning", "Error", "Critical" })
                    {
                        if (string.Equals(filter.Level?.ToString(), level, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@level" selected>@LogEntriesDashboard.DisplayLevel(level)</option>
                        }
                        else
                        {
                            <option value="@level">@LogEntriesDashboard.DisplayLevel(level)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-1">
                <label class="form-label small" for="logentries-page-size">Rows</label>
                <select id="logentries-page-size" name="pageSize" class="form-select form-select-sm">
                    @foreach (var size in new[] { 50, 100, 250, 500 })
                    {
                        if (filter.PageSize == size)
                        {
                            <option value="@size" selected>@size</option>
                        }
                        else
                        {
                            <option value="@size">@size</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label small" for="logentries-from">From</label>
                <div class="input-group input-group-sm">
                    <input id="logentries-from" name="from" type="date" value="@LogEntriesDashboard.FormatDate(filter.StartTime)" class="form-control form-control-sm" data-dashboard-date-picker>
                    <button type="button" class="btn btn-outline-secondary" data-dashboard-date-picker-button="logentries-from" aria-label="Open from date picker" title="Open date picker">
                        <i class="bi bi-calendar3"></i>
                    </button>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label small" for="logentries-to">To</label>
                <div class="input-group input-group-sm">
                    <input id="logentries-to" name="to" type="date" value="@LogEntriesDashboard.FormatDate(filter.EndTime)" class="form-control form-control-sm" data-dashboard-date-picker>
                    <button type="button" class="btn btn-outline-secondary" data-dashboard-date-picker-button="logentries-to" aria-label="Open to date picker" title="Open date picker">
                        <i class="bi bi-calendar3"></i>
                    </button>
                </div>
            </div>
            <div class="col-12 col-lg-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">Apply</button>
                <button type="button" id="logentries-reset" class="btn btn-outline-secondary btn-sm" title="Reset filters" aria-label="Reset filters">
                    <i class="bi bi-x-circle"></i>
                </button>
            </div>
        </div>
        <div class="row g-2 mt-1">
            <div class="col-6 col-lg-2"><input name="correlationId" value="@filter.CorrelationId" class="form-control form-control-sm" placeholder="CorrelationId"></div>
            <div class="col-6 col-lg-2"><input name="traceId" value="@filter.TraceId" class="form-control form-control-sm" placeholder="TraceId"></div>
            <div class="col-6 col-lg-2"><input name="spanId" value="@filter.SpanId" class="form-control form-control-sm" placeholder="SpanId"></div>
            <div class="col-6 col-lg-2"><input name="logKey" value="@filter.LogKey" class="form-control form-control-sm" placeholder="LogKey"></div>
            <div class="col-6 col-lg-2"><input name="moduleName" value="@filter.ModuleName" class="form-control form-control-sm" placeholder="ModuleName"></div>
            <div class="col-6 col-lg-2"><input name="shortTypeName" value="@filter.ShortTypeName" class="form-control form-control-sm" placeholder="ShortTypeName"></div>
        </div>
    </div>
</form>

<div id="dashboard-logentries-content">
    @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Logging.Dashboard.Pages.Content>())
</div>

<script>
    (() => {
        const contentUrl = '@contentPath';
        const rowsUrl = '@rowsPath';
        const exportUrl = '@exportPath';
        const contentElement = document.getElementById('dashboard-logentries-content');
        const formElement = document.getElementById('logentries-filter-form');
        const resetElement = document.getElementById('logentries-reset');
        const statusElement = document.getElementById('logentries-refresh-status');
        const refreshButton = document.getElementById('logentries-refresh-now');
        const tailElement = document.getElementById('logentries-tail');
        const exportElement = document.getElementById('logentries-export');
        const purgeElement = document.getElementById('logentries-purge');

        let tailTimeoutId = null;
        let abortController = null;

        function formQuery() {
            const data = new FormData(formElement);
            const query = new URLSearchParams();
            for (const [key, value] of data.entries()) {
                if (value !== null && value.toString().trim() !== '') {
                    query.set(key, value.toString().trim());
                }
            }

            return query;
        }

        function setStatus(text, isError) {
            statusElement.textContent = text;
            statusElement.classList.toggle('text-danger', isError === true);
            statusElement.classList.toggle('text-muted', isError !== true);
        }

        function updatePageUrl(query) {
            const url = new URL(window.location.href);
            url.search = query.toString();
            window.history.replaceState(null, '', url.toString());
        }

        function updateExportUrl(query) {
            exportElement.href = query.toString() ? `${exportUrl}?${query}` : exportUrl;
        }

        function localDateInputValue(date) {
            const offsetDate = new Date(date.getTime() - (date.getTimezoneOffset() * 60000));
            return offsetDate.toISOString().slice(0, 10);
        }

        function resetFilters() {
            formElement.querySelectorAll('input').forEach(input => {
                input.value = '';
            });

            const level = formElement.elements.namedItem('level');
            if (level) {
                level.value = 'Information';
            }

            const pageSize = formElement.elements.namedItem('pageSize');
            if (pageSize) {
                pageSize.value = '100';
            }

            const from = formElement.elements.namedItem('from');
            if (from) {
                from.value = localDateInputValue(new Date());
            }
        }

        function maxLogId() {
            const ids = [...contentElement.querySelectorAll('[data-log-id]')]
                .map(row => Number(row.getAttribute('data-log-id')))
                .filter(value => Number.isFinite(value));

            return ids.length === 0 ? null : Math.max(...ids);
        }

        function collectLogRowGroups(fragment) {
            return [...fragment.querySelectorAll('tr[data-log-id]')].map(row => {
                const detailsRow = row.nextElementSibling?.matches('[data-logentry-details]') === true
                    ? row.nextElementSibling
                    : null;

                return { row, detailsRow };
            });
        }

        function clearTail() {
            if (tailTimeoutId !== null) {
                window.clearTimeout(tailTimeoutId);
                tailTimeoutId = null;
            }
        }

        async function fetchHtml(url) {
            if (abortController !== null) {
                abortController.abort();
            }

            abortController = new AbortController();
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'fetch' },
                signal: abortController.signal
            });

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            return await response.text();
        }

        async function refreshContent() {
            clearTail();
            const query = formQuery();
            updatePageUrl(query);
            updateExportUrl(query);

            try {
                contentElement.innerHTML = await fetchHtml(`${contentUrl}?${query}`);
                window.bdkDashboard.clearRefreshError(contentElement);
                setStatus(`Updated ${new Date().toLocaleTimeString()}`, false);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    window.bdkDashboard.showRefreshError(contentElement);
                    setStatus('Refresh failed', true);
                }
            } finally {
                abortController = null;
                scheduleTail();
            }
        }

        async function loadOlder(button) {
            const continuationToken = button.getAttribute('data-continuation-token');
            if (!continuationToken) {
                return;
            }

            button.disabled = true;
            const query = formQuery();
            query.set('continuationToken', continuationToken);

            try {
                const html = await fetchHtml(`${rowsUrl}?${query}`);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const marker = template.content.querySelector('[data-next-continuation-token]');
                const rowGroups = collectLogRowGroups(template.content);
                const tbody = contentElement.querySelector('#logentries-table-body');
                rowGroups.forEach(group => {
                    tbody.appendChild(group.row);
                    if (group.detailsRow) {
                        tbody.appendChild(group.detailsRow);
                    }
                });

                const next = marker?.getAttribute('data-next-continuation-token');
                if (next) {
                    button.setAttribute('data-continuation-token', next);
                    button.disabled = false;
                } else {
                    button.remove();
                }

                window.bdkDashboard.clearRefreshError(contentElement);
                setStatus(`Loaded ${rowGroups.length} older entries`, false);
            } catch (error) {
                button.disabled = false;
                if (error.name !== 'AbortError') {
                    window.bdkDashboard.showRefreshError(contentElement);
                    setStatus('Load failed', true);
                }
            } finally {
                abortController = null;
            }
        }

        async function loadNewer() {
            if (!tailElement.checked || document.hidden) {
                scheduleTail();
                return;
            }

            const afterId = maxLogId();
            if (afterId === null) {
                await refreshContent();
                return;
            }

            const query = formQuery();
            query.set('afterId', afterId.toString());

            try {
                const html = await fetchHtml(`${rowsUrl}?${query}`);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const rowGroups = collectLogRowGroups(template.content);
                const tbody = contentElement.querySelector('#logentries-table-body');
                rowGroups.reverse().forEach(group => {
                    if (group.detailsRow) {
                        tbody.prepend(group.detailsRow);
                    }

                    tbody.prepend(group.row);
                });

                window.bdkDashboard.clearRefreshError(contentElement);
                if (rowGroups.length > 0) {
                    setStatus(`Added ${rowGroups.length} new entries`, false);
                }
            } catch (error) {
                if (error.name !== 'AbortError') {
                    window.bdkDashboard.showRefreshError(contentElement);
                    setStatus('Tail failed', true);
                }
            } finally {
                abortController = null;
                scheduleTail();
            }
        }

        function scheduleTail() {
            clearTail();
            if (!tailElement.checked || document.hidden) {
                return;
            }

            tailTimeoutId = window.setTimeout(loadNewer, 2000);
        }

        formElement.addEventListener('submit', event => {
            event.preventDefault();
            refreshContent();
        });

        resetElement.addEventListener('click', () => {
            resetFilters();
            updateExportUrl(formQuery());
            refreshContent();
        });

        refreshButton.addEventListener('click', refreshContent);

        purgeElement.addEventListener('click', async () => {
            if (!window.confirm('Purge retained log entries? This cannot be undone.')) {
                return;
            }

            await window.bdkDashboard.postAction('@purgePath', {
                refresh: refreshContent,
                errorMessage: 'Log purge failed:'
            });
        });

        tailElement.addEventListener('change', scheduleTail);

        formElement.addEventListener('input', () => updateExportUrl(formQuery()));
        formElement.addEventListener('change', () => updateExportUrl(formQuery()));

        contentElement.addEventListener('click', event => {
            const loadMoreButton = event.target.closest('[data-logentries-load-more]');
            if (loadMoreButton) {
                loadOlder(loadMoreButton);
                return;
            }

            const toggleButton = event.target.closest('[data-logentry-toggle]');
            if (toggleButton) {
                const detailsRow = document.getElementById(toggleButton.getAttribute('data-logentry-toggle'));
                const expanded = toggleButton.getAttribute('aria-expanded') === 'true';
                toggleButton.setAttribute('aria-expanded', (!expanded).toString());
                toggleButton.title = expanded ? 'Show log entry details' : 'Hide log entry details';
                detailsRow?.classList.toggle('d-none', expanded);
                return;
            }

            const filterButton = event.target.closest('[data-filter-name]');
            if (filterButton) {
                const input = formElement.elements.namedItem(filterButton.getAttribute('data-filter-name'));
                if (input) {
                    input.value = filterButton.getAttribute('data-filter-value') ?? '';
                    updateExportUrl(formQuery());
                    refreshContent();
                }
            }
        });

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                clearTail();
                return;
            }

            scheduleTail();
        });
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Logs" };
}
