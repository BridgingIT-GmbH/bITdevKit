@using BridgingIT.DevKit.Presentation.Web
@using BridgingIT.DevKit.Presentation.Web.Dashboard
@using BridgingIT.DevKit.Presentation.Web.Dashboard.Pages
@using BridgingIT.DevKit.Presentation.Web.Metrics.Dashboard.Pages
@using Microsoft.Extensions.DependencyInjection
@using RazorSlices
@inherits RazorSlice
@implements IUsesLayout<BridgingIT.DevKit.Presentation.Web.Dashboard.Pages._DashboardLayout, DashboardLayoutModel>

@{
    var dashboardOptions = this.HttpContext.RequestServices.GetService<DashboardEndpointsOptions>() ?? new DashboardEndpointsOptions();
    var contentPath = DashboardPath.Combine(dashboardOptions.GroupPath, dashboardOptions.EndpointPaths.MetricsContent);
}

<div class="d-flex justify-content-end align-items-center py-2 mb-2 border-bottom">
    <div class="d-flex align-items-center gap-2">
        <span id="metrics-refresh-status" class="text-muted small">Updated @DateTimeOffset.UtcNow.LocalDateTime.ToString("T", CultureInfo.InvariantCulture)</span>
        <select id="metrics-refresh-interval" class="form-select form-select-sm" style="width: 9rem" aria-label="Metrics refresh interval">
            <option value="">Off</option>
            <option value="1000">1 sec</option>
            <option value="5000">5 sec</option>
            <option value="15000">15 sec</option>
            <option value="30000">30 sec</option>
        </select>
        <button type="button" id="metrics-refresh-now" class="btn btn-outline-secondary btn-sm" title="Refresh metrics">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div id="dashboard-metrics-content">
    @(await RenderPartialAsync<BridgingIT.DevKit.Presentation.Web.Metrics.Dashboard.Pages.Content>())
</div>

<script>
    (() => {
        window.bdkDashboard.createRefresher({
            contentUrl: '@contentPath',
            contentSelector: '#dashboard-metrics-content',
            statusSelector: '#metrics-refresh-status',
            intervalSelector: '#metrics-refresh-interval',
            refreshButtonSelector: '#metrics-refresh-now',
            storageKey: 'bdk.dashboard.metrics.refreshInterval',
            preserveActiveTab: true
        });
    })();
</script>

@functions {
    public DashboardLayoutModel LayoutModel => new() { Title = "Metrics" };

}
